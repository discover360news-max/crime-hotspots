---
/**
 * Search Modal
 * Site-wide search powered by Pagefind
 * Searches crime headlines, locations, and crime types
 */
---

<dialog
  id="searchModal"
  class="m-auto p-0 bg-white dark:bg-[hsl(0_0%_8%)] backdrop-blur-xl rounded-2xl shadow-2xl border-0 outline-none"
  aria-labelledby="searchModalTitle"
  data-pagefind-ignore
>
  <!-- Header -->
  <div class="sticky top-0 bg-white/90 dark:bg-[hsl(0_0%_8%)]/95 backdrop-blur-md border-b border-slate-200 dark:border-[hsl(0_0%_18%)] px-6 py-4 flex items-center justify-between rounded-t-2xl">
    <h2 id="searchModalTitle" class="text-heading font-bold text-slate-700 dark:text-[hsl(0_0%_92%)]">Search Crime Hotspots</h2>
    <button
      id="closeSearchModal"
      class="w-8 h-8 flex items-center justify-center rounded-lg hover:bg-slate-100 dark:hover:bg-[hsl(0_0%_14%)] active:bg-slate-200 transition text-slate-500 dark:text-[hsl(0_0%_55%)] hover:text-slate-700 dark:hover:text-[hsl(0_0%_85%)]"
      aria-label="Close"
    >
      <span class="text-2xl leading-none">×</span>
    </button>
  </div>

  <!-- Search Container -->
  <div class="flex-1 overflow-y-auto p-6">
    <div id="search"></div>

    <!-- Suggestions panel — shown when search input is empty -->
    <div id="searchSuggestions" class="mt-2 space-y-5">

      <!-- Recent searches (rendered by JS if localStorage has entries) -->
      <div id="recentSearchesSection" class="hidden">
        <p class="text-xs font-semibold text-slate-400 dark:text-[hsl(0_0%_45%)] uppercase tracking-wide mb-2">Recent</p>
        <div id="recentChips" class="flex flex-wrap gap-2"></div>
      </div>

      <!-- Latest crimes (rendered by JS after fetch) -->
      <div id="latestCrimesSection" class="hidden">
        <p class="text-xs font-semibold text-slate-400 dark:text-[hsl(0_0%_45%)] uppercase tracking-wide mb-2">Latest Crimes</p>
        <div id="latestCrimeCards" class="space-y-2"></div>
      </div>

      <!-- Static prompt chips -->
      <div>
        <p class="text-xs font-semibold text-slate-400 dark:text-[hsl(0_0%_45%)] uppercase tracking-wide mb-2">Try searching for</p>
        <div class="flex flex-wrap gap-2">
          {["Murder", "Shooting", "Robbery", "Burglary", "Assault", "Kidnapping", "Seizures", "Port of Spain", "Laventille", "San Fernando"].map(term => (
            <button
              class="search-chip px-3 py-1.5 rounded-lg border border-slate-200 dark:border-[hsl(0_0%_20%)] text-slate-600 dark:text-[hsl(0_0%_70%)] text-xs font-medium hover:border-rose-500 hover:text-rose-600 dark:hover:border-rose-500 dark:hover:text-rose-400 hover:bg-rose-50 dark:hover:bg-rose-950/30 active:bg-rose-100 transition"
              data-term={term}
            >
              {term}
            </button>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- Footer Help Text -->
  <div class="px-6 pb-6 pt-2 border-t border-slate-200 dark:border-[hsl(0_0%_18%)]">
    <p class="text-xs text-slate-400 dark:text-[hsl(0_0%_45%)] text-center">
      Search through all crime incidents · Search by location, crime type, or keywords
    </p>
  </div>
</dialog>

<style is:global>
  /* ── Dialog sizing & flex layout ─────────────────────────────────────────── */
  #searchModal {
    width: calc(100% - 2rem);
    max-width: 48rem; /* same as max-w-3xl */
    max-height: 85vh;
  }

  #searchModal[open] {
    display: flex;
    flex-direction: column;
  }

  /* Open animation — browser picks up @starting-style as the FROM state */
  #searchModal[open] {
    opacity: 1;
    transform: scale(1);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  @starting-style {
    #searchModal[open] {
      opacity: 0;
      transform: scale(0.95);
    }
  }

  /* Close animation — JS adds this class, removes it after transitionend */
  #searchModal.is-closing {
    opacity: 0;
    transform: scale(0.95);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  /* Backdrop */
  #searchModal::backdrop {
    background: rgb(0 0 0 / 0.5);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    opacity: 1;
    transition: opacity 0.3s ease;
  }
  @starting-style {
    #searchModal[open]::backdrop {
      opacity: 0;
    }
  }
  #searchModal.is-closing::backdrop {
    opacity: 0;
  }

  /* ── Pagefind UI — Light mode ───────────────────────────────────────────── */
  #search .pagefind-ui__search-input {
    width: 100%;
    padding: 0.75rem 1rem 0.75rem 2.5rem;
    border: 2px solid #e2e8f0;
    border-radius: 0.5rem;
    font-size: 1rem;
    color: #334155;
    background: white;
    transition: all 0.2s;
  }

  #search .pagefind-ui__search-input:focus {
    outline: none;
    border-color: #e11d48;
    box-shadow: 0 0 0 3px rgba(225, 29, 72, 0.1);
  }

  #search .pagefind-ui__result {
    border: 1px solid #e2e8f0;
    border-radius: 0.5rem;
    padding: 1rem;
    margin-bottom: 0.75rem;
    background: white;
    transition: all 0.2s;
  }

  #search .pagefind-ui__result:hover {
    border-color: #e11d48;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
  }

  #search .pagefind-ui__result-title {
    font-size: 1rem;
    font-weight: 600;
    color: #334155;
    margin-bottom: 0.5rem;
  }

  #search .pagefind-ui__result-link {
    text-decoration: none;
    color: inherit;
  }

  #search .pagefind-ui__result-link:hover .pagefind-ui__result-title {
    color: #e11d48;
  }

  #search .pagefind-ui__result-excerpt {
    font-size: 0.875rem;
    color: #64748b;
    line-height: 1.5;
  }

  #search .pagefind-ui__message {
    text-align: center;
    padding: 2rem;
    color: #64748b;
    font-size: 0.875rem;
  }

  #search mark {
    background-color: #fef3c7;
    color: #92400e;
    padding: 0.125rem 0.25rem;
    border-radius: 0.25rem;
    font-weight: 600;
  }

  #search .pagefind-ui__button {
    background: #e11d48;
    color: white;
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
    border: none;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
  }

  #search .pagefind-ui__button:hover {
    background: #be123c;
  }

  /* ── Pagefind UI — Dark mode ────────────────────────────────────────────── */
  .dark #search .pagefind-ui__search-input {
    background: hsl(0 0% 12%);
    border-color: hsl(0 0% 22%);
    color: hsl(0 0% 90%);
  }

  .dark #search .pagefind-ui__search-input::placeholder {
    color: hsl(0 0% 45%);
  }

  .dark #search .pagefind-ui__search-input:focus {
    border-color: #e11d48;
    box-shadow: 0 0 0 3px rgba(225, 29, 72, 0.15);
  }

  .dark #search .pagefind-ui__result {
    background: hsl(0 0% 11%);
    border-color: hsl(0 0% 20%);
  }

  .dark #search .pagefind-ui__result:hover {
    border-color: #e11d48;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.4);
  }

  .dark #search .pagefind-ui__result-title {
    color: hsl(0 0% 90%);
  }

  .dark #search .pagefind-ui__result-link:hover .pagefind-ui__result-title {
    color: #fb7185;
  }

  .dark #search .pagefind-ui__result-excerpt {
    color: hsl(0 0% 60%);
  }

  .dark #search .pagefind-ui__message {
    color: hsl(0 0% 55%);
  }

  .dark #search mark {
    background-color: hsl(38 80% 20%);
    color: hsl(38 80% 75%);
  }

  .dark #search .pagefind-ui__search-clear {
    color: hsl(0 0% 50%);
  }

  .dark #search .pagefind-ui__search-clear:hover {
    color: hsl(0 0% 80%);
  }

  .dark #search .pagefind-ui__button {
    background: #e11d48;
  }

  .dark #search .pagefind-ui__button:hover {
    background: #be123c;
  }
</style>

<script>
  // NOTE: Module script — runs ONCE per session.
  // pagefindUI and latestCrimesFetched are reset in astro:page-load so
  // Pagefind re-mounts cleanly into the fresh DOM after each SPA nav.

  const HISTORY_KEY = 'ch_search_history';
  const MAX_HISTORY = 5;
  let pagefindUI: any = null;
  let latestCrimesFetched = false;

  // ── History helpers ──────────────────────────────────────────────────────
  function getHistory(): string[] {
    try { return JSON.parse(localStorage.getItem(HISTORY_KEY) || '[]'); } catch { return []; }
  }

  function saveToHistory(term: string) {
    if (!term || term.trim().length < 2) return;
    const clean = term.trim();
    let history = getHistory().filter(t => t.toLowerCase() !== clean.toLowerCase());
    history.unshift(clean);
    history = history.slice(0, MAX_HISTORY);
    try { localStorage.setItem(HISTORY_KEY, JSON.stringify(history)); } catch {}
  }

  function renderRecentChips() {
    const section = document.getElementById('recentSearchesSection');
    const container = document.getElementById('recentChips');
    if (!section || !container) return;
    const history = getHistory();
    if (history.length === 0) { section.classList.add('hidden'); return; }
    section.classList.remove('hidden');
    container.innerHTML = history.map(term => `
      <button class="search-chip recent-chip px-3 py-1.5 rounded-lg border border-slate-200 dark:border-[hsl(0_0%_20%)] text-slate-600 dark:text-[hsl(0_0%_70%)] text-xs font-medium hover:border-rose-500 hover:text-rose-600 dark:hover:border-rose-500 dark:hover:text-rose-400 hover:bg-rose-50 dark:hover:bg-rose-950/30 active:bg-rose-100 transition flex items-center gap-1.5" data-term="${term.replace(/"/g, '&quot;')}">
        <svg class="w-3 h-3 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        ${term}
      </button>
    `).join('');
    bindChips(container);
  }

  // ── Latest crimes ────────────────────────────────────────────────────────
  async function fetchAndRenderLatestCrimes() {
    if (latestCrimesFetched) return;
    latestCrimesFetched = true;
    const section = document.getElementById('latestCrimesSection');
    const container = document.getElementById('latestCrimeCards');
    if (!section || !container) return;
    try {
      const res = await fetch('/api/latest-crimes.json');
      if (!res.ok) return;
      const { crimes } = await res.json();
      if (!crimes || crimes.length === 0) return;
      container.innerHTML = crimes.map((c: any) => `
        <a href="/trinidad/crime/${c.slug}/"
           class="flex items-start gap-3 p-3 rounded-lg border border-slate-200 dark:border-[hsl(0_0%_20%)] hover:border-rose-500 dark:hover:border-rose-500 hover:bg-rose-50 dark:hover:bg-rose-950/30 transition group"
        >
          <span class="mt-0.5 flex-shrink-0 w-2 h-2 rounded-full bg-rose-500 dark:bg-rose-400 opacity-70 group-hover:opacity-100 transition"></span>
          <div class="min-w-0">
            <p class="text-xs font-semibold text-slate-700 dark:text-[hsl(0_0%_88%)] group-hover:text-rose-600 dark:group-hover:text-rose-400 truncate transition">${c.headline}</p>
            <p class="text-xs text-slate-400 dark:text-[hsl(0_0%_50%)] mt-0.5">${c.area} &middot; ${c.crimeType} &middot; ${c.date}</p>
          </div>
        </a>
      `).join('');
      section.classList.remove('hidden');
    } catch {
      // Silently fail — latest crimes are non-critical
    }
  }

  // ── Chip interaction ─────────────────────────────────────────────────────
  function triggerSearch(term: string) {
    const searchInput = document.querySelector<HTMLInputElement>('#search input');
    if (!searchInput) return;
    searchInput.value = term;
    searchInput.dispatchEvent(new Event('input', { bubbles: true }));
    searchInput.focus();
    hideSuggestions();
  }

  function bindChips(container: Element | null) {
    if (!container) return;
    container.querySelectorAll<HTMLElement>('.search-chip').forEach(btn => {
      btn.addEventListener('click', () => {
        if (btn.dataset.term) triggerSearch(btn.dataset.term);
      });
    });
  }

  // ── Show / hide suggestions ──────────────────────────────────────────────
  function showSuggestions() {
    document.getElementById('searchSuggestions')?.classList.remove('hidden');
  }

  function hideSuggestions() {
    document.getElementById('searchSuggestions')?.classList.add('hidden');
  }

  function watchSearchInput() {
    const searchInput = document.querySelector<HTMLInputElement>('#search input');
    if (!searchInput) return;

    let saveTimer: ReturnType<typeof setTimeout>;
    searchInput.addEventListener('input', () => {
      const val = searchInput.value.trim();
      if (val.length > 0) {
        hideSuggestions();
        clearTimeout(saveTimer);
        saveTimer = setTimeout(() => saveToHistory(val), 1500);
      } else {
        renderRecentChips();
        showSuggestions();
      }
    });

    searchInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        const val = searchInput.value.trim();
        if (val) { clearTimeout(saveTimer); saveToHistory(val); }
      }
    });

    document.querySelector('#search')?.addEventListener('click', (e) => {
      if ((e.target as Element).closest('a')) {
        const val = searchInput.value.trim();
        if (val) saveToHistory(val);
      }
    });
  }

  // ── Close animation ──────────────────────────────────────────────────────
  function closeModal() {
    const dialog = document.getElementById('searchModal') as HTMLDialogElement | null;
    if (!dialog || !dialog.open || dialog.classList.contains('is-closing')) return;
    dialog.classList.add('is-closing');
    dialog.addEventListener('transitionend', () => {
      dialog.classList.remove('is-closing');
      dialog.close();
      document.body.style.overflow = '';
    }, { once: true });
  }

  // ── Open ─────────────────────────────────────────────────────────────────
  (window as any).openSearchModal = function() {
    const dialog = document.getElementById('searchModal') as HTMLDialogElement | null;
    if (!dialog) return;

    document.body.style.overflow = 'hidden';
    dialog.showModal();

    // Initialize Pagefind UI on first open (pagefindUI is reset to null on each SPA nav)
    if (!pagefindUI && (window as any).PagefindUI) {
      try {
        pagefindUI = new (window as any).PagefindUI({
          element: "#search",
          showSubResults: true,
          showImages: false,
          excerptLength: 30,
          resetStyles: false,
          bundlePath: "/pagefind/"
        });
        setTimeout(() => {
          renderRecentChips();
          fetchAndRenderLatestCrimes();
          showSuggestions();
          watchSearchInput();
          document.querySelector<HTMLInputElement>('#search input')?.focus();
        }, 200);
      } catch (error) {
        console.error('Failed to initialize Pagefind UI:', error);
        const searchDiv = document.getElementById('search');
        if (searchDiv) searchDiv.innerHTML = '<p class="text-center text-slate-500 dark:text-[hsl(0_0%_50%)] p-4">Search is currently unavailable. Please try again later.</p>';
        hideSuggestions();
      }
    } else if (pagefindUI) {
      renderRecentChips();
      fetchAndRenderLatestCrimes();
      const val = document.querySelector<HTMLInputElement>('#search input')?.value?.trim() || '';
      if (val.length === 0) showSuggestions();
      setTimeout(() => document.querySelector<HTMLInputElement>('#search input')?.focus(), 100);
    }
  };

  // ── Re-attach listeners after each SPA nav ────────────────────────────────
  document.addEventListener('astro:page-load', () => {
    // Reset so Pagefind re-mounts into the fresh DOM
    pagefindUI = null;
    latestCrimesFetched = false;

    const dialog = document.getElementById('searchModal') as HTMLDialogElement | null;
    const closeBtn = document.getElementById('closeSearchModal');

    // Bind static suggestion chips
    bindChips(document.getElementById('searchSuggestions'));

    closeBtn?.addEventListener('click', closeModal);

    dialog?.addEventListener('click', (e) => {
      if (e.target === dialog) closeModal();
    });

    dialog?.addEventListener('cancel', (e) => {
      e.preventDefault();
      closeModal();
    });
  });

  // ── Keyboard shortcuts (added once — document persists across SPA nav) ────
  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      (window as any).openSearchModal();
    }
  });

  // Restore scroll lock if SPA nav happens while modal is open
  document.addEventListener('astro:before-preparation', () => {
    document.body.style.overflow = '';
  });
</script>
