---
/**
 * Search Modal
 * Site-wide search powered by /api/search (D1 FTS5 for crimes, static for MPs + areas).
 * Replaces Pagefind — no build-time indexing required.
 */
---

<dialog
  id="searchModal"
  class="m-auto p-0 bg-white dark:bg-[hsl(0_0%_8%)] backdrop-blur-xl rounded-2xl shadow-2xl border-0 outline-none"
  aria-labelledby="searchModalTitle"
>
  <!-- Header -->
  <div class="sticky top-0 bg-white/90 dark:bg-[hsl(0_0%_8%)]/95 backdrop-blur-md border-b border-slate-200 dark:border-[hsl(0_0%_18%)] px-6 py-4 flex items-center justify-between rounded-t-2xl">
    <h2 id="searchModalTitle" class="text-heading font-bold text-slate-700 dark:text-[hsl(0_0%_92%)]">Search Crime Hotspots</h2>
    <button
      id="closeSearchModal"
      class="w-8 h-8 flex items-center justify-center rounded-lg hover:bg-slate-100 dark:hover:bg-[hsl(0_0%_14%)] active:bg-slate-200 transition text-slate-500 dark:text-[hsl(0_0%_55%)] hover:text-slate-700 dark:hover:text-[hsl(0_0%_85%)]"
      aria-label="Close"
    >
      <span class="text-2xl leading-none">×</span>
    </button>
  </div>

  <!-- Search Container -->
  <div class="flex-1 overflow-y-auto p-6">

    <!-- Search Input -->
    <div class="relative mb-4">
      <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400 dark:text-[hsl(0_0%_45%)] pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
      </svg>
      <input
        id="searchInput"
        type="search"
        placeholder="Search crimes, MPs, areas..."
        class="w-full pl-9 pr-10 py-3 border-2 border-slate-200 dark:border-[hsl(0_0%_22%)] rounded-lg text-base text-slate-700 dark:text-[hsl(0_0%_90%)] bg-white dark:bg-[hsl(0_0%_12%)] placeholder-slate-400 dark:placeholder-[hsl(0_0%_45%)] focus:outline-none focus:border-rose-500 dark:focus:border-rose-500 focus:shadow-[0_0_0_3px_rgba(225,29,72,0.1)] dark:focus:shadow-[0_0_0_3px_rgba(225,29,72,0.15)] transition"
        autocomplete="off"
        spellcheck="false"
      />
      <!-- Loading spinner -->
      <div id="searchSpinner" class="hidden absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none">
        <svg class="w-4 h-4 animate-spin text-rose-500" fill="none" viewBox="0 0 24 24" aria-hidden="true">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
        </svg>
      </div>
    </div>

    <!-- Search results (shown when a query is active) -->
    <div id="searchResults" class="hidden mt-2 space-y-2"></div>

    <!-- Suggestions panel — shown when search input is empty -->
    <div id="searchSuggestions" class="mt-2 space-y-5">

      <!-- Recent searches (rendered by JS if localStorage has entries) -->
      <div id="recentSearchesSection" class="hidden">
        <p class="text-xs font-semibold text-slate-400 dark:text-[hsl(0_0%_45%)] uppercase tracking-wide mb-2">Recent</p>
        <div id="recentChips" class="flex flex-wrap gap-2"></div>
      </div>

      <!-- Latest crimes (rendered by JS after fetch) -->
      <div id="latestCrimesSection" class="hidden">
        <p class="text-xs font-semibold text-slate-400 dark:text-[hsl(0_0%_45%)] uppercase tracking-wide mb-2">Latest Crimes</p>
        <div id="latestCrimeCards" class="space-y-2"></div>
      </div>

      <!-- Static prompt chips -->
      <div>
        <p class="text-xs font-semibold text-slate-400 dark:text-[hsl(0_0%_45%)] uppercase tracking-wide mb-2">Try searching for</p>
        <div class="flex flex-wrap gap-2">
          {["Murder", "Shooting", "Robbery", "Burglary", "Assault", "Kidnapping", "Seizures", "Port of Spain", "Laventille", "San Fernando"].map(term => (
            <button
              class="search-chip px-3 py-1.5 rounded-lg border border-slate-200 dark:border-[hsl(0_0%_20%)] text-slate-600 dark:text-[hsl(0_0%_70%)] text-xs font-medium hover:border-rose-500 hover:text-rose-600 dark:hover:border-rose-500 dark:hover:text-rose-400 hover:bg-rose-50 dark:hover:bg-rose-950/30 active:bg-rose-100 transition"
              data-term={term}
            >
              {term}
            </button>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- Footer Help Text -->
  <div class="px-6 pb-6 pt-2 border-t border-slate-200 dark:border-[hsl(0_0%_18%)]">
    <p class="text-xs text-slate-400 dark:text-[hsl(0_0%_45%)] text-center">
      Search through all crime incidents, MPs, and areas
    </p>
  </div>
</dialog>

<style is:global>
  /* ── Dialog sizing & flex layout ─────────────────────────────────────────── */
  #searchModal {
    width: calc(100% - 2rem);
    max-width: 48rem;
    max-height: 85vh;
  }

  #searchModal[open] {
    display: flex;
    flex-direction: column;
  }

  /* Open animation */
  #searchModal[open] {
    opacity: 1;
    transform: scale(1);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  @starting-style {
    #searchModal[open] {
      opacity: 0;
      transform: scale(0.95);
    }
  }

  /* Close animation */
  #searchModal.is-closing {
    opacity: 0;
    transform: scale(0.95);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  /* Backdrop */
  #searchModal::backdrop {
    background: rgb(0 0 0 / 0.5);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    opacity: 1;
    transition: opacity 0.3s ease;
  }
  @starting-style {
    #searchModal[open]::backdrop {
      opacity: 0;
    }
  }
  #searchModal.is-closing::backdrop {
    opacity: 0;
  }

  /* ── Result cards ────────────────────────────────────────────────────────── */
  .search-result-card {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.75rem;
    border-radius: 0.5rem;
    border: 1px solid #e2e8f0;
    background: white;
    transition: all 0.15s;
    text-decoration: none;
    color: inherit;
  }
  .search-result-card:hover {
    border-color: #e11d48;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
  }
  .dark .search-result-card {
    background: hsl(0 0% 11%);
    border-color: hsl(0 0% 20%);
  }
  .dark .search-result-card:hover {
    border-color: #e11d48;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.4);
  }

  /* Type badge */
  .search-type-badge {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-top: 0.125rem;
  }
  .search-type-badge--crime {
    background: #ffe4e6;
    color: #be123c;
  }
  .dark .search-type-badge--crime {
    background: rgba(159, 18, 57, 0.2);
    color: #fb7185;
  }
  .search-type-badge--mp {
    background: #e2e8f0;
    color: #475569;
  }
  .dark .search-type-badge--mp {
    background: hsl(0 0% 18%);
    color: hsl(0 0% 65%);
  }
  .search-type-badge--area {
    background: #d1fae5;
    color: #065f46;
  }
  .dark .search-type-badge--area {
    background: rgba(6, 78, 59, 0.25);
    color: #34d399;
  }

  .search-result-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: #334155;
    transition: color 0.15s;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .search-result-card:hover .search-result-title { color: #e11d48; }
  .dark .search-result-title { color: hsl(0 0% 88%); }
  .dark .search-result-card:hover .search-result-title { color: #fb7185; }

  .search-result-meta {
    font-size: 0.75rem;
    color: #94a3b8;
    margin-top: 0.125rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .dark .search-result-meta { color: hsl(0 0% 50%); }
</style>

<script>
  // NOTE: Module script — runs ONCE per session.
  // State is reset in astro:page-load so the modal re-initialises after each SPA nav.

  import { escapeHtml } from '../lib/escapeHtml';

  const HISTORY_KEY = 'ch_search_history';
  const MAX_HISTORY = 5;
  const SEARCH_DEBOUNCE_MS = 300;

  let latestCrimesFetched = false;
  let searchDebounceTimer: ReturnType<typeof setTimeout> | null = null;
  let lastQuery = '';

  // ── History helpers ──────────────────────────────────────────────────────
  function getHistory(): string[] {
    try { return JSON.parse(localStorage.getItem(HISTORY_KEY) || '[]'); } catch { return []; }
  }

  function saveToHistory(term: string) {
    if (!term || term.trim().length < 2) return;
    const clean = term.trim();
    let history = getHistory().filter(t => t.toLowerCase() !== clean.toLowerCase());
    history.unshift(clean);
    history = history.slice(0, MAX_HISTORY);
    try { localStorage.setItem(HISTORY_KEY, JSON.stringify(history)); } catch {}
  }

  function renderRecentChips() {
    const section = document.getElementById('recentSearchesSection');
    const container = document.getElementById('recentChips');
    if (!section || !container) return;
    const history = getHistory();
    if (history.length === 0) { section.classList.add('hidden'); return; }
    section.classList.remove('hidden');
    container.innerHTML = history.map(term => `
      <button class="search-chip recent-chip px-3 py-1.5 rounded-lg border border-slate-200 dark:border-[hsl(0_0%_20%)] text-slate-600 dark:text-[hsl(0_0%_70%)] text-xs font-medium hover:border-rose-500 hover:text-rose-600 dark:hover:border-rose-500 dark:hover:text-rose-400 hover:bg-rose-50 dark:hover:bg-rose-950/30 active:bg-rose-100 transition flex items-center gap-1.5" data-term="${term.replace(/"/g, '&quot;')}">
        <svg class="w-3 h-3 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        ${escapeHtml(term)}
      </button>
    `).join('');
    bindChips(container);
  }

  // ── Latest crimes ────────────────────────────────────────────────────────
  async function fetchAndRenderLatestCrimes() {
    if (latestCrimesFetched) return;
    latestCrimesFetched = true;
    const section = document.getElementById('latestCrimesSection');
    const container = document.getElementById('latestCrimeCards');
    if (!section || !container) return;
    try {
      const res = await fetch('/api/latest-crimes.json');
      if (!res.ok) return;
      const { crimes } = await res.json();
      if (!crimes || crimes.length === 0) return;
      container.innerHTML = crimes.map((c: any) => `
        <a href="/trinidad/crime/${c.slug}/"
           class="flex items-start gap-3 p-3 rounded-lg border border-slate-200 dark:border-[hsl(0_0%_20%)] hover:border-rose-500 dark:hover:border-rose-500 hover:bg-rose-50 dark:hover:bg-rose-950/30 transition group"
        >
          <span class="mt-0.5 flex-shrink-0 w-2 h-2 rounded-full bg-rose-500 dark:bg-rose-400 opacity-70 group-hover:opacity-100 transition"></span>
          <div class="min-w-0">
            <p class="text-xs font-semibold text-slate-700 dark:text-[hsl(0_0%_88%)] group-hover:text-rose-600 dark:group-hover:text-rose-400 truncate transition">${c.headline}</p>
            <p class="text-xs text-slate-400 dark:text-[hsl(0_0%_50%)] mt-0.5">${c.area} &middot; ${c.crimeType} &middot; ${c.date}</p>
          </div>
        </a>
      `).join('');
      section.classList.remove('hidden');
    } catch {
      // Silently fail — latest crimes are non-critical
    }
  }

  // ── Suggestions show/hide ────────────────────────────────────────────────
  function showSuggestions() {
    document.getElementById('searchSuggestions')?.classList.remove('hidden');
    document.getElementById('searchResults')?.classList.add('hidden');
  }

  function hideSuggestions() {
    document.getElementById('searchSuggestions')?.classList.add('hidden');
  }

  // ── Search results rendering ─────────────────────────────────────────────
  function typeBadgeClass(type: string): string {
    if (type === 'crime') return 'search-type-badge--crime';
    if (type === 'mp')    return 'search-type-badge--mp';
    return 'search-type-badge--area';
  }

  function typeLabel(type: string): string {
    if (type === 'crime') return 'Crime';
    if (type === 'mp')    return 'MP';
    return 'Area';
  }

  function renderResults(results: any[], q: string) {
    const container = document.getElementById('searchResults');
    if (!container) return;

    if (results.length === 0) {
      container.innerHTML = `<p class="text-center text-slate-400 dark:text-[hsl(0_0%_50%)] py-6 text-sm">No results for &ldquo;${escapeHtml(q)}&rdquo;</p>`;
      container.classList.remove('hidden');
      return;
    }

    container.innerHTML = results.map(r => `
      <a href="${escapeHtml(r.url)}"
         class="search-result-card"
      >
        <span class="search-type-badge ${typeBadgeClass(r.type)}">${typeLabel(r.type)}</span>
        <div class="min-w-0 flex-1">
          <p class="search-result-title">${escapeHtml(r.title)}</p>
          ${r.excerpt ? `<p class="search-result-meta">${escapeHtml(r.excerpt)}</p>` : ''}
          ${r.meta && r.meta !== r.excerpt ? `<p class="search-result-meta" style="opacity:0.75">${escapeHtml(r.meta)}</p>` : ''}
        </div>
      </a>
    `).join('');
    container.classList.remove('hidden');
  }

  // ── Search execution ─────────────────────────────────────────────────────
  async function performSearch(q: string) {
    const spinner = document.getElementById('searchSpinner');
    const results = document.getElementById('searchResults');
    if (!q || q.trim().length < 2) {
      results?.classList.add('hidden');
      return;
    }

    lastQuery = q;
    spinner?.classList.remove('hidden');
    hideSuggestions();

    try {
      const res = await fetch(`/api/search/?q=${encodeURIComponent(q.trim())}`);
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const { results: data } = await res.json();
      // Only render if query hasn't changed while we were fetching
      if (q === lastQuery) {
        renderResults(data ?? [], q);
      }
    } catch {
      if (q === lastQuery && results) {
        results.innerHTML = '<p class="text-center text-slate-400 dark:text-[hsl(0_0%_50%)] py-6 text-sm">Search is unavailable. Please try again.</p>';
        results.classList.remove('hidden');
      }
    } finally {
      spinner?.classList.add('hidden');
    }
  }

  // ── Chip interaction ─────────────────────────────────────────────────────
  function triggerSearch(term: string) {
    const searchInput = document.querySelector<HTMLInputElement>('#searchInput');
    if (!searchInput) return;
    searchInput.value = term;
    hideSuggestions();
    saveToHistory(term);
    performSearch(term);
    searchInput.focus();
  }

  function bindChips(container: Element | null) {
    if (!container) return;
    container.querySelectorAll<HTMLElement>('.search-chip').forEach(btn => {
      btn.addEventListener('click', () => {
        if (btn.dataset.term) triggerSearch(btn.dataset.term);
      });
    });
  }

  // ── Input watcher ────────────────────────────────────────────────────────
  function watchSearchInput() {
    const searchInput = document.querySelector<HTMLInputElement>('#searchInput');
    if (!searchInput) return;

    searchInput.addEventListener('input', () => {
      const val = searchInput.value.trim();
      if (val.length === 0) {
        renderRecentChips();
        showSuggestions();
        document.getElementById('searchResults')?.classList.add('hidden');
        lastQuery = '';
        if (searchDebounceTimer) clearTimeout(searchDebounceTimer);
        return;
      }
      if (searchDebounceTimer) clearTimeout(searchDebounceTimer);
      searchDebounceTimer = setTimeout(() => {
        saveToHistory(val);
        performSearch(val);
      }, SEARCH_DEBOUNCE_MS);
    });

    searchInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        const val = searchInput.value.trim();
        if (val) {
          if (searchDebounceTimer) clearTimeout(searchDebounceTimer);
          saveToHistory(val);
          performSearch(val);
        }
      }
    });

    // Result link clicks — save history and close modal
    document.getElementById('searchResults')?.addEventListener('click', (e) => {
      const target = e.target as Element;
      if (target.closest('a')) {
        const val = searchInput.value.trim();
        if (val) saveToHistory(val);
        closeModal();
      }
    });
  }

  // ── Close animation ──────────────────────────────────────────────────────
  function closeModal() {
    const dialog = document.getElementById('searchModal') as HTMLDialogElement | null;
    if (!dialog || !dialog.open || dialog.classList.contains('is-closing')) return;
    dialog.classList.add('is-closing');
    dialog.addEventListener('transitionend', () => {
      dialog.classList.remove('is-closing');
      dialog.close();
      document.body.style.overflow = '';
    }, { once: true });
  }

  // ── Open ─────────────────────────────────────────────────────────────────
  (window as any).openSearchModal = function() {
    const dialog = document.getElementById('searchModal') as HTMLDialogElement | null;
    if (!dialog) return;

    document.body.style.overflow = 'hidden';
    dialog.showModal();

    renderRecentChips();
    fetchAndRenderLatestCrimes();
    showSuggestions();
    watchSearchInput();

    setTimeout(() => {
      document.querySelector<HTMLInputElement>('#searchInput')?.focus();
    }, 50);
  };

  // ── Re-attach listeners after each SPA nav ────────────────────────────────
  document.addEventListener('DOMContentLoaded', () => {
    latestCrimesFetched = false;
    lastQuery = '';

    const dialog = document.getElementById('searchModal') as HTMLDialogElement | null;
    const closeBtn = document.getElementById('closeSearchModal');

    bindChips(document.getElementById('searchSuggestions'));

    closeBtn?.addEventListener('click', closeModal);

    dialog?.addEventListener('click', (e) => {
      if (e.target === dialog) closeModal();
    });

    dialog?.addEventListener('cancel', (e) => {
      e.preventDefault();
      closeModal();
    });
  });

  // ── Keyboard shortcuts ────────────────────────────────────────────────────
  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      (window as any).openSearchModal();
    }
  });

</script>
