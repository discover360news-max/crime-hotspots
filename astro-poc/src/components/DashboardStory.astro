---
/**
 * DashboardStory — two-column card at the top of the dashboard
 * Left: live "this week" narrative summary
 * Right: latest weekly blog post (title, date, read link)
 */
import type { Crime } from '../lib/crimeData';
import { countCrimeType } from '../lib/dashboardHelpers';
import { getCollection } from 'astro:content';
import { buildRoute } from '../config/routes';

interface Props {
  allCrimes: Crime[];
}

const { allCrimes } = Astro.props;

// This week's crimes — offset by 3-day lag (crimes are logged by incident date,
// not entry date, so the most recent 3 days are always incomplete)
const now = new Date();
const lagDays = 3;
const weekEnd = new Date();
weekEnd.setDate(now.getDate() - lagDays);
weekEnd.setHours(0, 0, 0, 0);
const weekAgo = new Date();
weekAgo.setDate(now.getDate() - (7 + lagDays));
weekAgo.setHours(0, 0, 0, 0);
const twoWeeksAgo = new Date();
twoWeeksAgo.setDate(now.getDate() - (14 + lagDays));
twoWeeksAgo.setHours(0, 0, 0, 0);

const thisWeekCrimes = allCrimes.filter(c => c.dateObj >= weekAgo && c.dateObj < weekEnd);
const lastWeekCrimes = allCrimes.filter(c => c.dateObj >= twoWeeksAgo && c.dateObj < weekAgo);

// Top area this week — derived from the same lag-adjusted thisWeekCrimes window
// so the "leads with X" count matches the incident count shown in the banner
const areaCountThisWeek = new Map<string, number>();
thisWeekCrimes.forEach(c => {
  const area = c.area || 'Unknown';
  if (area !== 'Unknown') areaCountThisWeek.set(area, (areaCountThisWeek.get(area) || 0) + 1);
});
const topAreaEntry = Array.from(areaCountThisWeek.entries()).sort((a, b) => b[1] - a[1])[0];
const topArea = topAreaEntry ? { area: topAreaEntry[0], count: topAreaEntry[1] } : null;

// Murders comparison — uses countCrimeType which correctly:
// - Applies victimCount for primary Murder (double murder = 2)
// - Counts each "Murder" occurrence in related crimes (Murder, Murder = 2)
// - Does NOT use victimCount when Murder is a related crime (robbery victimCount won't inflate murder stats)
const murdersThisWeek = countCrimeType(thisWeekCrimes, 'Murder');
const murdersLastWeek = countCrimeType(lastWeekCrimes, 'Murder');
const murderChange = murdersLastWeek > 0
  ? Math.round(((murdersThisWeek - murdersLastWeek) / murdersLastWeek) * 100)
  : 0;

// Overall week change
const weekChange = lastWeekCrimes.length > 0
  ? Math.round(((thisWeekCrimes.length - lastWeekCrimes.length) / lastWeekCrimes.length) * 100)
  : 0;

// Latest TT weekly blog post — auto-updates on every build/deploy
const allBlogPosts = await getCollection('blog');
const latestPost = allBlogPosts
  .filter(p => p.data.country === 'tt')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())[0];

const hasLiveData = thisWeekCrimes.length > 0;

function formatPostDate(date: Date) {
  return new Date(date).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
}
---

{(hasLiveData || latestPost) && (
  <div class="rounded-lg border border-slate-200 dark:border-[var(--ch-border-subtle)] bg-white/70 dark:bg-[var(--ch-surface)] p-3 mb-4">
    <div class="flex flex-col sm:flex-row sm:items-stretch sm:gap-4">

      <!-- Left: live weekly summary -->
      {hasLiveData && (
        <div class="flex items-start gap-2 sm:flex-1 min-w-0">
          <span class="relative flex h-2 w-2 mt-1.5 shrink-0">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-rose-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-rose-500"></span>
          </span>
          <p class="text-sm text-slate-600 dark:text-[hsl(0_0%_80%)] leading-relaxed">
            This week: <span class="font-bold text-slate-700 dark:text-[var(--ch-text-heading)]">{thisWeekCrimes.length} crimes</span> reported
            across Trinidad{weekChange !== 0 && (
              <span class={weekChange > 0 ? 'text-rose-600' : 'text-emerald-600'}>
                {' '}({weekChange > 0 ? '+' : ''}{weekChange}% vs last week)
              </span>
            )}.
            {topArea && (
              <> <span class="font-medium">{topArea.area}</span> leads with {topArea.count}.</>
            )}
            {murdersThisWeek > 0 && murderChange !== 0 && (
              <> Murders <span class={murderChange > 0 ? 'font-medium text-rose-600' : 'font-medium text-emerald-600'}>
                {`${murderChange > 0 ? 'up' : 'down'} ${Math.abs(murderChange)}%`}
              </span> week-over-week.</>
            )}
          </p>
        </div>
      )}

      <!-- Dividers (only when both columns present) -->
      {hasLiveData && latestPost && (
        <>
          <div class="hidden sm:block w-px bg-slate-200 dark:bg-[hsl(0_0%_18%)] self-stretch shrink-0"></div>
          <div class="sm:hidden h-px bg-slate-200 dark:bg-[hsl(0_0%_18%)] my-2.5"></div>
        </>
      )}

      <!-- Right: latest weekly blog post -->
      {latestPost && (
        <div class="sm:w-[44%] shrink-0 min-w-0 flex flex-col">
          <div class="flex items-center gap-2 mb-0.5">
            <span class="text-[10px] font-medium text-slate-400 dark:text-[hsl(0_0%_40%)] uppercase tracking-wide leading-none">Weekly Report</span>
            <span class="text-[10px] text-slate-400 dark:text-[hsl(0_0%_40%)] leading-none">{latestPost.data.readTime}</span>
          </div>
          <p class="text-sm font-medium text-slate-700 dark:text-[hsl(0_0%_88%)] leading-snug line-clamp-1 mb-1">{latestPost.data.title}</p>
          <div class="flex items-center justify-between gap-2 mt-auto">
            <span class="text-xs text-slate-400 dark:text-[hsl(0_0%_45%)]">{formatPostDate(latestPost.data.date)}</span>
            <a href={buildRoute.blogPost(latestPost.id)} class="text-xs font-medium text-rose-600 hover:text-rose-700 active:text-rose-800 transition whitespace-nowrap">
              Read &rarr;
            </a>
          </div>
        </div>
      )}

    </div>
  </div>
)}
