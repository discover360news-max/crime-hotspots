---
/**
 * CategoryAccordion
 * Collapsible section grouping safety tips by category.
 * Used on the safety tips index page.
 */

interface Props {
  category: string;
  count: number;
  categoryHref: string;
  isExpanded?: boolean;
}

const { category, count, categoryHref, isExpanded = false } = Astro.props;
---

<details class="cat-accordion mb-3" open={isExpanded || undefined}>
  <summary class="cat-header w-full px-4 py-3 bg-white dark:bg-[var(--ch-surface-sub)] rounded-lg border border-slate-200 dark:border-[var(--ch-border-card)] hover:border-rose-300 dark:hover:border-rose-700 transition flex items-center justify-between group list-none cursor-pointer">
    <div class="flex items-center gap-3">
      <svg
        class="cat-chevron w-4 h-4 text-slate-400 dark:text-[var(--ch-text-muted)] transition-transform duration-200 flex-shrink-0"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
      <span class="text-body font-bold text-slate-700 dark:text-[var(--ch-text-heading)]">{category}</span>
    </div>

    <div class="flex items-center gap-2">
      <span class="px-2 py-0.5 rounded-full border border-slate-300 dark:border-[hsl(0_0%_30%)] text-slate-500 dark:text-[var(--ch-text-muted)] text-caption font-medium">
        {count} {count === 1 ? 'tip' : 'tips'}
      </span>
      <a
        href={categoryHref}
        class="hidden sm:inline text-caption text-slate-400 dark:text-[var(--ch-text-faint)] hover:text-rose-600 dark:hover:text-rose-400 hover:underline transition"
        onclick="event.stopPropagation()"
      >
        See all →
      </a>
    </div>
  </summary>

  <div class="cat-content overflow-hidden">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 pb-2">
      <slot />
    </div>
    <a
      href={categoryHref}
      class="sm:hidden mt-2 mb-1 inline-block text-caption font-bold text-slate-600 dark:text-[hsl(0_0%_65%)] hover:text-rose-600 dark:hover:text-rose-400 hover:underline transition-colors"
    >
      See all {category} tips →
    </a>
  </div>
</details>

<style>
  /* height: auto is animatable because Layout.astro sets html { interpolate-size: allow-keywords } */
  .cat-content {
    height: 0;
    transition: height 300ms ease, margin-top 200ms ease;
  }
  .cat-content.is-open {
    height: auto;
    margin-top: 0.75rem;
  }
  details[open] .cat-chevron {
    transform: rotate(90deg);
  }
  /* Remove default <summary> marker in all browsers */
  summary::-webkit-details-marker { display: none; }
</style>

<script>
  // <details> sets content to display:none on close, which kills CSS height transitions.
  // Intercept toggle: manage is-open class for animation, open attribute for ARIA semantics.
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll<HTMLDetailsElement>('.cat-accordion').forEach((details) => {
      const content = details.querySelector('.cat-content');
      if (!content) return;
      if (details.open) content.classList.add('is-open');
      const header = details.querySelector('.cat-header');
      if (!header) return;
      header.addEventListener('click', (e) => {
        e.preventDefault(); // Prevent native <details> toggle — we manage open attribute ourselves
        if (details.open) {
          content.classList.remove('is-open');
          setTimeout(() => details.removeAttribute('open'), 300);
        } else {
          details.setAttribute('open', '');
          content.getBoundingClientRect(); // Force reflow so browser sees height:0 before transition
          content.classList.add('is-open');
        }
      });
    });
  });
</script>
