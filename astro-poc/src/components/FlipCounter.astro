---
/**
 * FlipCounter Component
 * iOS-style split-flap counter display with animation
 *
 * Props:
 * - value: The target number to display
 * - animateOnLoad: Whether to animate from 0 on page load (default: true)
 * - maxDigits: Maximum digits to display (default: auto based on value)
 */

interface Props {
  value: number;
  animateOnLoad?: boolean;
  maxDigits?: number;
  id?: string;
}

const {
  value,
  animateOnLoad = true,
  maxDigits,
  id = 'flip-counter'
} = Astro.props;

// Calculate digits needed (at least 2 for visual balance)
const digitCount = maxDigits || Math.max(2, Math.floor(Math.log10(Math.abs(value || 1))) + 1);

// Create array of digit positions
const digits = Array.from({ length: digitCount }, (_, i) => {
  const digitValue = Math.floor((value / Math.pow(10, digitCount - 1 - i)) % 10);
  const isLeadingZero = i < digitCount - value.toString().length && digitValue === 0;
  return { index: i, value: digitValue, isLeadingZero };
});

// Initial display value (0 if animating, actual if not)
const initialDigits = animateOnLoad
  ? digits.map(d => ({ ...d, displayValue: 0, isHidden: d.isLeadingZero }))
  : digits.map(d => ({ ...d, displayValue: d.value, isHidden: d.isLeadingZero }));
---

<div class="flip-counter" id={id} data-target={value} data-digits={digitCount}>
  {initialDigits.map((digit) => (
    <div
      class={`flip-digit ${digit.isHidden && animateOnLoad ? 'hidden' : ''}`}
      data-target-digit={digit.value}
      data-index={digit.index}
    >
      <div class="flip-digit-inner">
        <div class="flip-digit-top">
          {animateOnLoad ? '0' : digit.value}
        </div>
        <div class="flip-digit-bottom">
          {animateOnLoad ? '0' : digit.value}
        </div>
      </div>
    </div>
  ))}
</div>

{animateOnLoad && (
  <script define:vars={{ containerId: id, targetValue: value }}>
    // Initialize flip counter animation on page load
    function initFlipCounter() {
      const container = document.getElementById(containerId);
      if (!container) return;

      const digits = container.querySelectorAll('.flip-digit');
      const targetString = targetValue.toString();

      // Skip animation for users who prefer reduced motion — show final values immediately
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        digits.forEach(digit => {
          const target = parseInt(digit.dataset.targetDigit || '0', 10);
          const top = digit.querySelector('.flip-digit-top');
          const bottom = digit.querySelector('.flip-digit-bottom');
          if (top) top.textContent = target.toString();
          if (bottom) bottom.textContent = target.toString();
          digit.classList.remove('hidden');
        });
        return;
      }

      const FLIP_INTERVAL = 250; // ms between digit increments
      const STAGGER_MS = 80;     // ms delay between each digit starting
      const START_DELAY = 300;   // ms before animation begins

      const startTime = performance.now() + START_DELAY;

      // Per-digit state — track progress without nested timers
      const state = Array.from(digits).map((digit, index) => {
        const target = parseInt(digit.dataset.targetDigit || '0', 10);
        const isLeadingZero = index < digits.length - targetString.length;
        return {
          digit,
          target,
          current: 0,
          isLeadingZero,
          startAt: startTime + index * STAGGER_MS,
          lastFlipAt: 0,
          done: isLeadingZero && target === 0,
        };
      });

      function frame(now) {
        let anyActive = false;

        for (const s of state) {
          if (s.done) continue;
          if (now < s.startAt) { anyActive = true; continue; }

          if (now - s.lastFlipAt >= FLIP_INTERVAL && s.current < s.target) {
            s.lastFlipAt = now;
            s.current++;

            if (s.isLeadingZero && s.current > 0) {
              s.digit.classList.remove('hidden');
            }

            const top = s.digit.querySelector('.flip-digit-top');
            const bottom = s.digit.querySelector('.flip-digit-bottom');
            if (top) top.textContent = s.current.toString();
            if (bottom) bottom.textContent = s.current.toString();

            // shadowPulse via CSS — clean up class when animation ends
            s.digit.classList.add('flipping');
            s.digit.addEventListener('animationend', () => {
              s.digit.classList.remove('flipping');
            }, { once: true });

            if (s.current >= s.target) s.done = true;
            else anyActive = true;
          } else if (s.current < s.target) {
            anyActive = true;
          }
        }

        if (anyActive) requestAnimationFrame(frame);
      }

      requestAnimationFrame(frame);
    }

    // Run animation after page load (astro:page-load works with ClientRouter)
    document.addEventListener('DOMContentLoaded', () => {
      setTimeout(initFlipCounter, 300);
    });
  </script>
)}

<style>
  @import '../styles/flip-counter.css';
</style>
