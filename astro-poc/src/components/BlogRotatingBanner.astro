---
/**
 * Blog Rotating Banner Component
 * Auto-rotates through latest blog posts for a specific country
 * Links to blog listing page
 */

import { getCollection } from 'astro:content';
import { routes } from '../config/routes';

interface Props {
  country: 'tt' | 'gy'; // Country code to filter blog posts
  limit?: number; // Number of posts to rotate (default: 3)
}

const { country, limit = 3 } = Astro.props;

// Fetch latest blog posts for this country
const allPosts = await getCollection('blog', ({ data }) => data.country === country);
const latestPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, limit);

// If no posts, don't render
if (latestPosts.length === 0) return null;

// Animation timing — each item is shown for 5s; 0.5s slide-in/out transitions
// Item 0 uses a negative delay so it appears already-visible on page load (no slide-in flash)
const slideInDuration = 0.5; // seconds
const itemDelays = latestPosts.map((_, i) =>
  i === 0 ? `-${slideInDuration}s` : `${i * 5 - slideInDuration}s`
);
---

<div
  class="blog-rotating-banner border border-slate-300 dark:border-[hsl(0_0%_25%)] rounded-lg px-3 py-1 md:px-4 md:py-2 mb-6 overflow-hidden"
  data-post-count={latestPosts.length}
>
  <a href={routes.blog} class="flex items-center gap-2 md:gap-3 group">
    <!-- Horn Icon -->
    <div class="flex-shrink-0">
      <svg
        class="w-4 h-4 md:w-5 md:h-5 text-slate-500 dark:text-[hsl(0_0%_55%)]"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        aria-hidden="true"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"
        />
      </svg>
    </div>

    <!-- Rotating Blog Titles -->
    <div class="flex-1 min-w-0 relative h-5 md:h-6 overflow-hidden">
      {latestPosts.map((post, index) => (
        <div
          class="blog-title absolute inset-0 flex items-center"
          style={`animation-delay: ${itemDelays[index]};`}
        >
          <span class="text-xs md:text-sm font-medium text-slate-600 dark:text-[hsl(0_0%_72%)] group-hover:underline truncate">
            {post.data.title}
          </span>
        </div>
      ))}
    </div>

    <!-- Arrow Icon (indicates clickable) -->
    <div class="flex-shrink-0">
      <svg
        class="w-4 h-4 text-slate-500 dark:text-[hsl(0_0%_55%)] group-hover:translate-x-1 transition-transform"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M9 5l7 7-7 7"
        />
      </svg>
    </div>
  </a>
</div>

<style>
  .blog-rotating-banner {
    background: linear-gradient(to right, rgba(255, 255, 255, 0.8), rgba(255, 255, 255, 0.9));
    backdrop-filter: blur(10px);
  }

  :global(.dark) .blog-rotating-banner {
    background: linear-gradient(to right, hsl(0 0% 10% / 0.7), hsl(0 0% 12% / 0.8));
  }

  .blog-title {
    will-change: transform, opacity;
  }

  /* Single post — always visible, no animation */
  [data-post-count="1"] .blog-title {
    opacity: 1;
    transform: translateY(0);
  }

  /* Two posts — 10s cycle (5s per item) */
  [data-post-count="2"] .blog-title {
    animation: blog-rotate-2 10s infinite;
    animation-fill-mode: backwards; /* holds 0% state (hidden) during positive delays */
  }

  /* Three posts — 15s cycle (5s per item) */
  [data-post-count="3"] .blog-title {
    animation: blog-rotate-3 15s infinite;
    animation-fill-mode: backwards;
  }

  /* Pause rotation on hover (desktop) */
  .blog-rotating-banner:hover .blog-title {
    animation-play-state: paused;
  }

  /*
   * Keyframes — each item occupies one "slot" in the cycle.
   * 0%:       hidden below (translateY 100%) — held during animation-delay
   * slide in: 0.5s to enter from below
   * hold:     visible for ~4s
   * slide out: 0.5s to exit upward (translateY -100%)
   * rest:     hidden above until next cycle
   *
   * Percentages are relative to the full cycle duration (N × 5s).
   */

  /* 2 posts — 10s cycle. Slot = 50% = 5s. Slide = 5% = 0.5s. */
  @keyframes blog-rotate-2 {
    0%   { opacity: 0; transform: translateY(100%); }
    5%   { opacity: 1; transform: translateY(0); }     /* slide in complete */
    45%  { opacity: 1; transform: translateY(0); }     /* hold */
    50%  { opacity: 0; transform: translateY(-100%); } /* slide out complete */
    100% { opacity: 0; transform: translateY(100%); }  /* ready for next cycle */
  }

  /* 3 posts — 15s cycle. Slot = 33.3% = 5s. Slide = 3.33% = 0.5s. */
  @keyframes blog-rotate-3 {
    0%     { opacity: 0; transform: translateY(100%); }
    3.33%  { opacity: 1; transform: translateY(0); }     /* slide in complete */
    30%    { opacity: 1; transform: translateY(0); }     /* hold */
    33.33% { opacity: 0; transform: translateY(-100%); } /* slide out complete */
    100%   { opacity: 0; transform: translateY(100%); }  /* ready for next cycle */
  }
</style>
