          </svg>
          <span class="text-lg font-bold text-emerald-600 dark:text-emerald-400 leading-none">{socialProof.areas_monitored_display}</span>
        </div>
        <p class="text-[10px] text-slate-500 dark:text-[var(--ch-text-muted)] leading-none">areas monitored</p>
      </div>

    </div>
  </div>
)}

