        </div>
        <p class="text-[10px] text-slate-500 dark:text-[var(--ch-text-muted)] leading-none">monthly impressions</p>
      </div>

      <!-- Incidents — rose -->
      <div class="rounded-lg py-2.5 px-3 bg-rose-50 dark:bg-rose-950/40 border border-rose-100 dark:border-rose-900/50">
