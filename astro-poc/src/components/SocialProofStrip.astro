          </svg>
          <span class="text-lg font-bold text-blue-600 dark:text-blue-400 leading-none">{socialProof.monthly_readers_display}</span>
        </div>
        <p class="text-[10px] text-slate-500 dark:text-[var(--ch-text-muted)] leading-none">monthly readers</p>
      </div>

      <!-- Impressions — violet -->
