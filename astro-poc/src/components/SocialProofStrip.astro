---
/**
 * SocialProofStrip — Site credibility metrics
 * Data: src/data/social-proof.json (GA4/GSC, updated weekly) + live D1 incident count
 * Variants: strip (4-col row), compact (2×2 grid), sidebar (stacked list), hero (2×2 dark)
 * Pass incidentCount from parent if allCrimes is already in scope — avoids a second D1 query.
 */
import socialProof from '../data/social-proof.json';

interface Props {
  variant?: 'strip' | 'compact' | 'sidebar' | 'hero';
  incidentCount?: number;
}

const { variant = 'strip', incidentCount } = Astro.props;

let incidents = incidentCount ?? 0;
if (incidentCount === undefined) {
  try {
    const db = Astro.locals.runtime?.env?.DB as D1Database | undefined;
    if (db) {
      const result = await db.prepare('SELECT COUNT(*) as count FROM crimes').first<{ count: number }>();
      incidents = result?.count ?? socialProof.incident_count_fallback;
    } else {
      incidents = socialProof.incident_count_fallback;
    }
  } catch {
    incidents = socialProof.incident_count_fallback;
  }
}

function fmtIncidents(n: number): string {
  if (n <= 0) return socialProof.incident_count_fallback.toLocaleString() + '+';
  const rounded = Math.floor(n / 100) * 100;
  return rounded.toLocaleString() + '+';
}

function fmtIncidentsShort(n: number): string {
  const base = n > 0 ? n : socialProof.incident_count_fallback;
  if (base >= 1000) return (Math.floor(base / 100) / 10).toFixed(1).replace(/\.0$/, '') + 'K+';
  return base + '+';
}

const incidentsDisplay = fmtIncidents(incidents);
const incidentsShort = fmtIncidentsShort(incidents);
---

{variant === 'strip' && (
  <div>
    <p class="text-[10px] font-bold uppercase tracking-wider text-slate-400 dark:text-[var(--ch-text-faint)] mb-2.5">
