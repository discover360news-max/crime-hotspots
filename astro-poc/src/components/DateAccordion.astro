---
/**
 * Date Accordion Component
 * Collapsible section for grouping crimes by date
 */

interface Props {
  date: string;
  crimeCount: number;
  victimCount: number;
  isExpanded?: boolean;
}

const { date, crimeCount, victimCount, isExpanded = false } = Astro.props;

// Format date for display
const formattedDate = new Date(date).toLocaleDateString('en-US', {
  weekday: 'long',
  month: 'long',
  day: 'numeric',
  year: 'numeric'
});
---

<details class="date-accordion mb-4" data-date={date} open={isExpanded || undefined}>
  <!-- Accordion Header -->
  <summary class="accordion-header w-full px-4 py-3 bg-white dark:bg-[hsl(0_0%_10%)] rounded-lg border border-slate-200 dark:border-[hsl(0_0%_18%)] hover:bg-white dark:hover:bg-[hsl(0_0%_14%)] transition flex items-center justify-between group list-none cursor-pointer">
    <div class="flex items-center gap-3">
      <!-- Chevron Icon -->
      <svg
        class="chevron w-5 h-5 text-slate-400 dark:text-[hsl(0_0%_55%)] transition-transform duration-200"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>

      <!-- Date & Victim Count -->
      <div class="text-left">
        <h3 class="text-small font-semibold text-slate-700 dark:text-[hsl(0_0%_90%)]">{formattedDate}</h3>
        <p class="text-xs text-slate-500 dark:text-[hsl(0_0%_60%)]">{victimCount} {victimCount === 1 ? 'victim' : 'victims'}</p>
      </div>
    </div>

    <!-- Badge -->
    <span class="px-3 py-1 rounded-full bg-rose-100 dark:bg-rose-950/60 text-rose-600 dark:text-rose-400 text-xs font-medium">
      {victimCount}
    </span>
  </summary>

  <!-- Accordion Content -->
  <div class="accordion-content overflow-hidden">
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 pb-4">
      <slot />
    </div>
  </div>
</details>

<style>
  /* height: auto is animatable because Layout.astro sets html { interpolate-size: allow-keywords } */
  .accordion-content {
    height: 0;
    transition: height 300ms ease, margin-top 200ms ease;
  }
  .accordion-content.is-open {
    height: auto;
    margin-top: 0.75rem;
  }
  details[open] .chevron {
    transform: rotate(90deg);
  }
  /* Remove default <summary> marker in all browsers */
  summary::-webkit-details-marker { display: none; }
</style>

<script>
  // <details> sets content to display:none on close, which kills CSS height transitions.
  // Intercept toggle: manage is-open class for animation, open attribute for ARIA semantics.
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.date-accordion').forEach((details) => {
      const content = details.querySelector('.accordion-content');
      if (!content) return;
      if (details.open) content.classList.add('is-open');
      details.querySelector('.accordion-header').addEventListener('click', (e) => {
        e.preventDefault(); // Prevent native <details> toggle — we manage open attribute ourselves
        if (details.open) {
          content.classList.remove('is-open');
          setTimeout(() => details.removeAttribute('open'), 300);
        } else {
          details.setAttribute('open', '');
          content.getBoundingClientRect(); // Force reflow so browser sees height:0 before transition
          content.classList.add('is-open');
        }
      });
    });
  });
</script>
