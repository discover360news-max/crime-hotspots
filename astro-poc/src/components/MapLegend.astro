---
/**
 * MapLegend
 * Collapsible legend for the Leaflet crime incidents map.
 */
---

<details id="legendDetails" class="mt-3 group bg-white/85 dark:bg-[var(--ch-surface)]/85 backdrop-blur-md border border-slate-200 dark:border-[var(--ch-border-subtle)] rounded-lg">
  <summary class="px-4 py-2.5 cursor-pointer list-none flex items-center justify-between select-none">
    <h3 class="text-xs font-semibold text-slate-700 dark:text-[var(--ch-text-heading)]">
      <span class="legend-label-closed">View Legend</span>
      <span class="legend-label-open">Legend</span>
    </h3>
    <svg id="legendChevron" class="w-4 h-4 text-slate-400 dark:text-[var(--ch-text-faint)] transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7 7" />
    </svg>
  </summary>
  <!-- Animation wrapper: grid trick for smooth slide-down -->
  <div id="legendBody" class="legend-body">
    <div style="overflow:hidden">
      <div class="px-4 pb-3 pt-2 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-x-4 gap-y-2 border-t border-slate-100 dark:border-[var(--ch-border-card)]">
        <div class="flex items-center gap-2">
          <span class="w-2.5 h-2.5 rounded-full border border-white dark:border-[var(--ch-border-subtle)] shadow-sm shrink-0" style="background:#e11d48"></span>
          <span class="text-xs text-slate-600 dark:text-[var(--ch-text-muted)]">Murder</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-2.5 h-2.5 rounded-full border border-white dark:border-[var(--ch-border-subtle)] shadow-sm shrink-0" style="background:#f43f5e"></span>
          <span class="text-xs text-slate-600 dark:text-[var(--ch-text-muted)]">Attempted Murder</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-2.5 h-2.5 rounded-full border border-white dark:border-[var(--ch-border-subtle)] shadow-sm shrink-0" style="background:#ec4899"></span>
          <span class="text-xs text-slate-600 dark:text-[var(--ch-text-muted)]">Kidnapping</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-2.5 h-2.5 rounded-full border border-white dark:border-[var(--ch-border-subtle)] shadow-sm shrink-0" style="background:#c026d3"></span>
          <span class="text-xs text-slate-600 dark:text-[var(--ch-text-muted)]">Sexual Assault</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-2.5 h-2.5 rounded-full border border-white dark:border-[var(--ch-border-subtle)] shadow-sm shrink-0" style="background:#dc2626"></span>
          <span class="text-xs text-slate-600 dark:text-[var(--ch-text-muted)]">Shooting</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-2.5 h-2.5 rounded-full border border-white dark:border-[var(--ch-border-subtle)] shadow-sm shrink-0" style="background:#8b5cf6"></span>
          <span class="text-xs text-slate-600 dark:text-[var(--ch-text-muted)]">Assault</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-2.5 h-2.5 rounded-full border border-white dark:border-[var(--ch-border-subtle)] shadow-sm shrink-0" style="background:#9333ea"></span>
          <span class="text-xs text-slate-600 dark:text-[var(--ch-text-muted)]">Home Invasion</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-2.5 h-2.5 rounded-full border border-white dark:border-[var(--ch-border-subtle)] shadow-sm shrink-0" style="background:#f59e0b"></span>
          <span class="text-xs text-slate-600 dark:text-[var(--ch-text-muted)]">Carjacking</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-2.5 h-2.5 rounded-full border border-white dark:border-[var(--ch-border-subtle)] shadow-sm shrink-0" style="background:#ea580c"></span>
          <span class="text-xs text-slate-600 dark:text-[var(--ch-text-muted)]">Arson</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-2.5 h-2.5 rounded-full border border-white dark:border-[var(--ch-border-subtle)] shadow-sm shrink-0" style="background:#f97316"></span>
          <span class="text-xs text-slate-600 dark:text-[var(--ch-text-muted)]">Robbery</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-2.5 h-2.5 rounded-full border border-white dark:border-[var(--ch-border-subtle)] shadow-sm shrink-0" style="background:#fb7185"></span>
          <span class="text-xs text-slate-600 dark:text-[var(--ch-text-muted)]">Domestic Violence</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-2.5 h-2.5 rounded-full border border-white dark:border-[var(--ch-border-subtle)] shadow-sm shrink-0" style="background:#059669"></span>
          <span class="text-xs text-slate-600 dark:text-[var(--ch-text-muted)]">Extortion</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-2.5 h-2.5 rounded-full border border-white dark:border-[var(--ch-border-subtle)] shadow-sm shrink-0" style="background:#eab308"></span>
          <span class="text-xs text-slate-600 dark:text-[var(--ch-text-muted)]">Burglary</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-2.5 h-2.5 rounded-full border border-white dark:border-[var(--ch-border-subtle)] shadow-sm shrink-0" style="background:#06b6d4"></span>
          <span class="text-xs text-slate-600 dark:text-[var(--ch-text-muted)]">Theft</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-2.5 h-2.5 rounded-full border border-white dark:border-[var(--ch-border-subtle)] shadow-sm shrink-0" style="background:#3b82f6"></span>
          <span class="text-xs text-slate-600 dark:text-[var(--ch-text-muted)]">Seizures</span>
        </div>
      </div>
    </div>
  </div>
</details>

<style>
  /* Grid animation — JS drives grid-template-rows for both open and close */
  .legend-body {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 300ms ease;
  }

  /* Chevron rotation */
  #legendChevron {
    transition: transform 300ms ease;
  }
  details[open] #legendChevron {
    transform: rotate(180deg);
  }

  /* Label swap */
  .legend-label-open { display: none; }
  details[open] .legend-label-open { display: inline; }
  details[open] .legend-label-closed { display: none; }

  /* Remove default <summary> marker */
  summary::-webkit-details-marker { display: none; }
</style>

<script>
  // Uses astro:page-load (not is:inline) so it re-runs on SPA navigation (B002)
  document.addEventListener('DOMContentLoaded', () => {
    const details = document.getElementById('legendDetails') as HTMLDetailsElement | null;
    const body = document.getElementById('legendBody');
    if (!details || !body) return;

    // Take full control of open/close to ensure smooth grid animation in both directions
    details.querySelector('summary')!.addEventListener('click', function (e) {
      e.preventDefault();
      if (details.open) {
        // Closing: animate grid to 0fr, then remove [open]
        body.style.gridTemplateRows = '0fr';
        setTimeout(function () {
          details.removeAttribute('open');
          body.style.gridTemplateRows = ''; // Clear so CSS drives the next open
        }, 300);
      } else {
        // Opening: set [open], force reflow at CSS base (0fr), then animate to 1fr via inline style
        details.setAttribute('open', '');
        body.getBoundingClientRect(); // Force reflow — CSS has no details[open] rule, so state is 0fr
        body.style.gridTemplateRows = '1fr'; // Animate to 1fr; leave inline style (no CSS to conflict)
      }
    });
  });
</script>
