---
/**
 * StatCards Component
 * Grid of statistics cards with year-over-year comparison
 * Supports optional subtitle override (e.g., "out of 10") instead of YoY comparison
 *
 * Usage:
 * <StatCards stats={[
 *   { label: "Murders", current: 50, previous: 45, yoyChange: 11.1, direction: "up" },
 *   { label: "Risk Level", current: 7.2, subtitle: "out of 10" },
 *   ...
 * ]} />
 */

interface StatCard {
  label: string;
  current: number;
  previous?: number;
  yoyChange?: number;
  direction?: 'up' | 'down' | 'flat';
  subtitle?: string;
  highlight?: boolean; // true = render count in rose-600 (e.g. murder stats)
  size?: 'large'; // bumps number size — used for Risk Level
  riskColor?: 'high' | 'neutral' | 'low'; // level-specific color for risk score
  shareText?: string; // pre-formatted WhatsApp share message for this stat
}

interface Props {
  stats: StatCard[];
}

const { stats } = Astro.props;

const currentYear = new Date().getFullYear();
const previousYear = currentYear - 1;

function formatPercentChange(change: number): string {
  const formatted = Math.abs(change).toFixed(1);
  return change >= 0 ? `+${formatted}%` : `-${formatted}%`;
}
---

<div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
  {stats.map((stat) => (
    <div class="bg-white/85 dark:bg-[hsl(0_0%_8%)]/85 rounded-lg border border-slate-200 dark:border-[hsl(0_0%_18%)] p-4 shadow-sm">
      <div class="text-caption text-slate-500 dark:text-[hsl(0_0%_60%)] font-bold">{stat.label}</div>
      <div class={`font-bold mt-1 ${
        stat.size === 'large' ? 'text-3xl sm:text-4xl' : 'text-2xl sm:text-3xl'
      } ${
        stat.riskColor === 'high' ? 'text-amber-600 dark:text-amber-400' :
        stat.riskColor === 'low'  ? 'text-emerald-600 dark:text-emerald-400' :
        stat.riskColor === 'neutral' ? 'text-slate-700 dark:text-[hsl(0_0%_85%)]' :
        stat.highlight ? 'text-rose-600 dark:text-rose-400' :
        'text-slate-800 dark:text-[hsl(0_0%_95%)]'
      }`}>{stat.current}</div>
      {stat.subtitle ? (
        <div class="text-caption mt-1 flex items-center justify-between gap-1">
          <span class="text-slate-400 dark:text-[hsl(0_0%_50%)]">{stat.subtitle}</span>
          {stat.shareText && (
            <a
              href={`https://wa.me/?text=${encodeURIComponent(stat.shareText)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="shrink-0 p-1 -mr-1 rounded text-slate-400 dark:text-[hsl(0_0%_40%)] hover:text-rose-600 dark:hover:text-rose-400 transition"
              aria-label={`Share ${stat.label} on WhatsApp`}
              title="Share on WhatsApp"
            >
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
            </a>
          )}
        </div>
      ) : stat.direction && stat.yoyChange !== undefined ? (
        <div class="text-caption mt-1 flex items-center justify-between gap-1">
          <span class={`${
            stat.direction === 'down' ? 'text-emerald-600 dark:text-emerald-400' :
            stat.direction === 'up' ? 'text-rose-600' :
            'text-slate-400 dark:text-[hsl(0_0%_50%)]'
          }`}>
            {stat.direction === 'down' ? '↓' : stat.direction === 'up' ? '↑' : '→'}
            {formatPercentChange(stat.yoyChange)} vs {previousYear}
          </span>
          {stat.shareText && (
            <a
              href={`https://wa.me/?text=${encodeURIComponent(stat.shareText)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="shrink-0 p-1 -mr-1 rounded text-slate-400 dark:text-[hsl(0_0%_40%)] hover:text-rose-600 dark:hover:text-rose-400 transition"
              aria-label={`Share ${stat.label} on WhatsApp`}
              title="Share on WhatsApp"
            >
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
            </a>
          )}
        </div>
      ) : null}
    </div>
  ))}
</div>
