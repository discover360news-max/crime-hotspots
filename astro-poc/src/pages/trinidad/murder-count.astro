---
/**
 * Trinidad Murder Rate & Count 2026
 * Mobile-first page displaying murder count with animated flip counter + murder rate per 100k
 * Target keywords: "trinidad murder rate", "trinidad murder toll", "how many murders in trinidad 2026"
 */

import Layout from '../../layouts/Layout.astro';
import FlipCounter from '../../components/FlipCounter.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getTrinidadCrimes, getAllCrimesFromD1 } from '../../lib/crimeData';
import { countCrimeType } from '../../lib/dashboardHelpers';
import { getCollection } from 'astro:content';
import { routes, buildRoute } from '../../config/routes';
import InfoPopup from '../../components/InfoPopup.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';

Astro.response.headers.set('CDN-Cache-Control', 'max-age=82800');
Astro.response.headers.set('Cache-Control', 'public, max-age=3600, must-revalidate');

const db = Astro.locals.runtime?.env?.DB as D1Database | undefined;
const allCrimes = db ? await getAllCrimesFromD1(db) : await getTrinidadCrimes();
const currentYear = new Date().getFullYear();
const previousYear = currentYear - 1;
const crimes2026 = allCrimes.filter(crime => crime.year === currentYear);
const crimes2025 = allCrimes.filter(crime => crime.year === previousYear);

// Get murder counts for both years
const murderCount = countCrimeType(crimes2026, 'Murder');
const murderCount2025SamePeriod = countCrimeType(crimes2025.filter(crime => {
  const now = new Date();
  const crimeDate = new Date(crime.date);
  const startOfPreviousYear = new Date(`${previousYear}-01-01`);
  const dayOfCurrentYear = Math.floor((now.getTime() - new Date(`${currentYear}-01-01`).getTime()) / (1000 * 60 * 60 * 24));
  const samePeriodEnd = new Date(startOfPreviousYear.getTime() + (dayOfCurrentYear * 24 * 60 * 60 * 1000));
  return crimeDate >= startOfPreviousYear && crimeDate <= samePeriodEnd;
}), 'Murder');

// Calculate year-over-year change
const yoyChange = murderCount2025SamePeriod > 0
  ? ((murderCount - murderCount2025SamePeriod) / murderCount2025SamePeriod) * 100
  : 0;
const yoyDirection = yoyChange > 0.5 ? 'up' : yoyChange < -0.5 ? 'down' : 'same';

// Population for murder rate calculation (Trinidad & Tobago estimate)
const POPULATION = 1500000;

// Calculate murder rate per 100,000 population
const currentMurderRate = ((murderCount / POPULATION) * 100000).toFixed(1);

// Calculate 2025 full year murder rate for comparison
const murderCount2025Full = countCrimeType(crimes2025, 'Murder');
const murderRate2025 = ((murderCount2025Full / POPULATION) * 100000).toFixed(1);

// Project annual murder count and rate (based on current pace)
const now = new Date();
const startOfYear = new Date(`${currentYear}-01-01`);
const daysPassed = Math.max(1, Math.floor((now.getTime() - startOfYear.getTime()) / (1000 * 60 * 60 * 24)));
const daysInYear = 365;
const projectedAnnualMurders = Math.round((murderCount / daysPassed) * daysInYear);
const projectedMurderRate = ((projectedAnnualMurders / POPULATION) * 100000).toFixed(1);

// Latest 10 murders for the incidents section
const latestMurders = crimes2026
  .filter(c =>
    c.primaryCrimeType === 'Murder' ||
    c.crimeType === 'Murder' ||
    c.relatedCrimeTypes?.split(',').map(t => t.trim()).includes('Murder')
  )
  .sort((a, b) => b.dateObj.getTime() - a.dateObj.getTime())
  .slice(0, 10);

// Get latest Trinidad blog post
const blogPosts = await getCollection('blog', ({ data }) => data.country === 'tt');
const latestPost = blogPosts.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
)[0];

// Last updated = build time (when data was fetched from Google Sheets)
const lastUpdated = new Date().toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric'
});

// OG image is generated at build time by GitHub Actions (daily rebuild).
// Do NOT call generateMurderCountOgImage here — sharp + node:fs crash in Cloudflare Workers.
const ogImagePath = '/og-images/murder-count.png';

const pageUrl = 'https://crimehotspots.com/trinidad/murder-count/';
const shareText = `Trinidad Murder Count ${currentYear}: ${murderCount} murders so far. Track live statistics at Crime Hotspots.`;

const title = `Trinidad Murder Count ${currentYear}: ${murderCount} Murders So Far — Updated Daily | Crime Hotspots`;
const description = `Trinidad murder count ${currentYear}: ${murderCount} murders (death toll updated daily). Murder rate: ${currentMurderRate} per 100k. Murder toll projected at ${projectedMurderRate} per 100k for full year. Track the Trinidad & Tobago murder toll and murder rate live.`;

const faqData = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": `How many murders in Trinidad and Tobago in ${currentYear}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Trinidad and Tobago has recorded ${murderCount} murders so far in ${currentYear} (as of ${lastUpdated}). At the current pace, the annualized murder rate is ${projectedMurderRate} per 100,000 population, with ${projectedAnnualMurders} murders projected by year end. Data is updated daily.`
      }
    },
    {
      "@type": "Question",
      "name": `What is the Trinidad murder rate in ${currentYear}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Trinidad and Tobago's annualized murder rate in ${currentYear} is ${projectedMurderRate} per 100,000 population, based on ${murderCount} murders in the first ${daysPassed} days of the year. The ${previousYear} final murder rate was ${murderRate2025} per 100,000 — one of the highest in the Caribbean.`
      }
    },
    {
      "@type": "Question",
      "name": `What is the Trinidad murder toll so far in ${currentYear}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `The Trinidad murder toll stands at ${murderCount} as of ${lastUpdated}. This is ${yoyDirection === 'up' ? `up ${Math.abs(yoyChange).toFixed(0)}% compared to the same period in ${previousYear}` : yoyDirection === 'down' ? `down ${Math.abs(yoyChange).toFixed(0)}% compared to the same period in ${previousYear}` : `similar to the same period in ${previousYear}`} (${murderCount2025SamePeriod} murders). Data updated daily from verified news sources.`
      }
    }
  ]
};
---

<Layout title={title} description={description} includePagefind={false} ogImage={`https://crimehotspots.com${ogImagePath}`}>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-8" data-pagefind-ignore>
    <!-- Breadcrumbs -->
    <div class="mb-6">
      <Breadcrumbs items={[
        { label: 'Home', href: routes.home },
        { label: 'Trinidad & Tobago', href: routes.trinidad.dashboard },
        { label: 'Murder Rate & Count' }
      ]} />
    </div>

    <!-- Page header — above grid so sidebar aligns with counter, not title -->
    <div class="text-center mb-8">
      <h1 class="text-center">
        <span class="block text-2xl sm:text-3xl font-bold text-slate-700 dark:text-[var(--ch-text-heading)]">Trinidad & Tobago</span>
        <span class="block text-lg sm:text-xl text-slate-500 dark:text-[var(--ch-text-muted)] font-medium">Murder Count</span>
        <span class="block text-4xl sm:text-5xl font-bold text-rose-600">{currentYear}</span>
      </h1>
    </div>

    <!-- Two-column grid — starts at counter level -->
    <div class="lg:grid lg:grid-cols-[1fr_256px] lg:gap-8 lg:items-start">

      <!-- Left column: counter + stats -->
      <main class="min-w-0 space-y-10">

        <!-- Flip Counter -->
        <div class="flex justify-center pt-4 pb-10">
          <FlipCounter value={murderCount} animateOnLoad={true} />
        </div>

        <!-- Last Updated -->
        <p class="text-sm text-slate-400 dark:text-[var(--ch-text-faint)]">
          Updated: {lastUpdated}
        </p>

        <!-- 2025 Comparison -->
        <div class="bg-slate-50 dark:bg-[var(--ch-surface)] rounded-lg border border-slate-200 dark:border-[var(--ch-border-subtle)] p-4">
          <div class="flex items-center gap-1">
            <p class="text-sm text-slate-600 dark:text-[hsl(0_0%_70%)]">
              Same period in {previousYear}: <span class="font-bold text-slate-800 dark:text-[var(--ch-text-heading)]">{murderCount2025SamePeriod}</span> murders
            </p>
            <InfoPopup id="murder-comparison-info">
              <p class="font-bold mb-2 text-slate-700 dark:text-[var(--ch-text-heading)]">How We Compare Years</p>
              <p class="mb-3">To make a fair comparison, we only look at the same time window in both years. For example, if today is February 10, we compare January 1–February 10 of {currentYear} against January 1–February 10 of {previousYear}.</p>
              <p>The percentage below shows whether murders are trending higher or lower than the same point last year. A green arrow means fewer murders so far this year.</p>
            </InfoPopup>
          </div>
          {yoyDirection !== 'same' && (
            <p class={`text-xs mt-2 ${yoyDirection === 'down' ? 'text-emerald-600' : 'text-rose-600'}`}>
              {yoyDirection === 'down' ? '↓' : '↑'} {Math.abs(yoyChange).toFixed(0)}% vs {previousYear}
            </p>
          )}
        </div>

        <!-- Murder Rate Section (SEO: "trinidad murder rate") -->
        <div>
          <div class="flex items-center gap-1 mb-4">
            <h2 class="text-xl font-bold text-slate-700 dark:text-[var(--ch-text-heading)]">
              Trinidad & Tobago Murder Rate {currentYear}
            </h2>
            <InfoPopup id="murder-rate-info">
              <p class="font-bold mb-2 text-slate-700 dark:text-[var(--ch-text-heading)]">Understanding Murder Rates</p>
              <p class="mb-3">A murder rate shows how many murders happen for every 100,000 people in a country. This makes it easier to compare safety between places of different sizes.</p>

              <p class="font-bold mb-2 text-slate-700 dark:text-[var(--ch-text-heading)]">What Each Card Means</p>
              <ul class="list-disc list-inside space-y-1">
                <li><span class="font-bold text-slate-700 dark:text-[var(--ch-text-strong)]">Current Rate (YTD)</span> — The murder rate so far this year, based on the first {daysPassed} days of data.</li>
                <li><span class="font-bold text-slate-700 dark:text-[var(--ch-text-strong)]">Annualized Rate</span> — If murders continue at the current pace for the full year, this is the estimated annual rate ({projectedAnnualMurders} murders projected).</li>
                <li><span class="font-bold text-slate-700 dark:text-[var(--ch-text-strong)]">{previousYear} Final Rate</span> — Last year's actual rate, based on {murderCount2025Full} total murders recorded.</li>
              </ul>

              <p class="font-bold mb-2 mt-3 text-slate-700 dark:text-[var(--ch-text-heading)]">About the Population</p>
              <p>All rates use an estimated population of 1.5 million for Trinidad & Tobago. This is a commonly used approximation; the actual population may vary slightly.</p>
            </InfoPopup>
          </div>

          <div class="grid grid-cols-3 gap-3">
            <!-- Current Year-to-Date Rate -->
            <div class="bg-rose-50 dark:bg-rose-950/30 rounded-lg border border-rose-200 dark:border-rose-900/50 p-4 text-center">
              <div class="text-xs text-slate-500 dark:text-[var(--ch-text-muted)] font-medium mb-1">Current Rate (YTD)</div>
              <div class="text-2xl font-bold text-rose-600">{currentMurderRate}</div>
              <div class="text-xs text-slate-400 dark:text-[var(--ch-text-faint)] mt-1">per 100k</div>
              <div class="text-xs text-slate-500 dark:text-[var(--ch-text-muted)] mt-2 pt-2 border-t border-rose-100 dark:border-rose-900/40">{murderCount} murders</div>
            </div>

            <!-- Projected Annual Rate -->
            <div class="bg-slate-100 dark:bg-[var(--ch-surface)] rounded-lg border border-slate-200 dark:border-[var(--ch-border-subtle)] p-4 text-center">
              <div class="text-xs text-slate-500 dark:text-[var(--ch-text-muted)] font-medium mb-1">Annualized Rate</div>
              <div class="text-2xl font-bold text-slate-700 dark:text-[var(--ch-text-heading)]">{projectedMurderRate}</div>
              <div class="text-xs text-slate-400 dark:text-[var(--ch-text-faint)] mt-1">per 100k ({currentYear})</div>
              <div class="text-xs text-slate-500 dark:text-[var(--ch-text-muted)] mt-2 pt-2 border-t border-slate-200 dark:border-[var(--ch-border-card)]">{murderCount} murders in {daysPassed} days</div>
            </div>

            <!-- 2025 Final Rate -->
            <div class="bg-slate-50 dark:bg-[var(--ch-surface)] rounded-lg border border-slate-200 dark:border-[var(--ch-border-subtle)] p-4 text-center">
              <div class="text-xs text-slate-500 dark:text-[var(--ch-text-muted)] font-medium mb-1">{previousYear} Final Rate</div>
              <div class="text-2xl font-bold text-slate-700 dark:text-[var(--ch-text-heading)]">{murderRate2025}</div>
              <div class="text-xs text-slate-400 dark:text-[var(--ch-text-faint)] mt-1">per 100k</div>
              <div class="text-xs text-slate-500 dark:text-[var(--ch-text-muted)] mt-2 pt-2 border-t border-slate-100 dark:border-[var(--ch-border-card)]">{murderCount2025Full} murders</div>
            </div>
          </div>

          <p class="text-xs text-slate-500 dark:text-[var(--ch-text-muted)] mt-3">
            Annualized rate from {daysPassed} days of data. Assumes current pace continues through year end. Based on population estimate of {(POPULATION / 1000000).toFixed(1)}M.
          </p>
        </div>

        <!-- Action Buttons -->
        <div class="flex flex-col sm:flex-row gap-3">
          <a
            href={routes.trinidad.dashboard}
            class="px-6 py-3 min-h-[44px] flex items-center justify-center bg-rose-600 text-white rounded-lg hover:bg-rose-700 active:bg-rose-800 transition font-medium text-sm shadow-md"
          >
            View Dashboard
          </a>
          <a
            href={routes.trinidad.statistics}
            class="px-6 py-3 min-h-[44px] flex items-center justify-center border border-slate-300 dark:border-[var(--ch-border)] text-slate-600 dark:text-[hsl(0_0%_70%)] rounded-lg hover:bg-slate-50 dark:hover:bg-[hsl(0_0%_12%)] active:bg-slate-100 dark:active:bg-[hsl(0_0%_15%)] transition font-medium text-sm"
          >
            All Crime Statistics
          </a>
        </div>

        <!-- Latest Analysis -->
        {latestPost && (
          <div>
            <p class="text-sm text-slate-500 dark:text-[var(--ch-text-muted)] mb-3">Latest Analysis</p>
            <a href={`/blog/${latestPost.slug}/`} class="block bg-white dark:bg-[var(--ch-surface)] rounded-lg border border-slate-200 dark:border-[var(--ch-border-subtle)] p-4 hover:border-rose-300 dark:hover:border-rose-800 hover:shadow-sm transition">
              <h3 class="font-bold text-slate-800 dark:text-[var(--ch-text-heading)] text-sm mb-2">{latestPost.data.title}</h3>
              <p class="text-xs text-slate-500 dark:text-[var(--ch-text-muted)]">{latestPost.data.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })} &bull; {latestPost.data.readTime}</p>
            </a>
          </div>
        )}

      </main>

      <!-- Right column: sidebar -->
      <aside class="mt-10 lg:mt-0 lg:sticky lg:top-20 space-y-5 min-w-0 [&_.newsletter-signup-form]:flex-col [&_.newsletter-signup-form_input]:w-full">

        <!-- Share buttons -->
        <div class="flex items-center gap-2">
          <span class="text-xs text-slate-500 dark:text-[var(--ch-text-faint)]">Share:</span>
          <button
            class="sb-share-btn p-2 rounded-lg border border-slate-300 dark:border-[var(--ch-border)] text-slate-600 dark:text-[var(--ch-text-muted)] hover:bg-slate-50 dark:hover:bg-[hsl(0_0%_12%)] active:bg-slate-100 dark:active:bg-[hsl(0_0%_15%)] transition"
            data-platform="twitter"
            data-share-url={pageUrl}
            data-share-text={shareText}
            title="Share on X (Twitter)"
            aria-label="Share on X (Twitter)"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </button>
          <button
            class="sb-share-btn p-2 rounded-lg border border-slate-300 dark:border-[var(--ch-border)] text-slate-600 dark:text-[var(--ch-text-muted)] hover:bg-slate-50 dark:hover:bg-[hsl(0_0%_12%)] active:bg-slate-100 dark:active:bg-[hsl(0_0%_15%)] transition"
            data-platform="facebook"
            data-share-url={pageUrl}
            data-share-text={shareText}
            title="Share on Facebook"
            aria-label="Share on Facebook"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </button>
          <button
            class="sb-share-btn p-2 rounded-lg border border-slate-300 dark:border-[var(--ch-border)] text-slate-600 dark:text-[var(--ch-text-muted)] hover:bg-slate-50 dark:hover:bg-[hsl(0_0%_12%)] active:bg-slate-100 dark:active:bg-[hsl(0_0%_15%)] transition"
            data-platform="whatsapp"
            data-share-url={pageUrl}
            data-share-text={shareText}
            title="Share on WhatsApp"
            aria-label="Share on WhatsApp"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
            </svg>
          </button>
          <button
            id="share-copy"
            class="p-2 rounded-lg border border-slate-300 dark:border-[var(--ch-border)] text-slate-600 dark:text-[var(--ch-text-muted)] hover:bg-slate-50 dark:hover:bg-[hsl(0_0%_12%)] active:bg-slate-100 dark:active:bg-[hsl(0_0%_15%)] transition"
            title="Copy link"
            aria-label="Copy link"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
          </button>
        </div>
        <p id="copy-feedback" class="text-xs text-emerald-600 opacity-0 transition-opacity">Link copied!</p>

        <!-- Latest Incidents -->
        {latestMurders.length > 0 && (
          <div class="rounded-lg border border-slate-200 dark:border-[var(--ch-border-card)] bg-slate-50 dark:bg-[hsl(0_0%_7%)] overflow-hidden">
            <div class="px-3 pt-3 pb-2 border-b border-slate-200 dark:border-[var(--ch-border-subtle)]">
              <p class="text-xs font-semibold text-slate-500 dark:text-[var(--ch-text-faint)] uppercase tracking-wide">Latest Incidents</p>
            </div>
            <div class="p-2 space-y-1.5">
              {latestMurders.map(crime => (
                <a
                  href={buildRoute.crime(crime.slug)}
                  class="flex items-start justify-between gap-2 bg-white dark:bg-[var(--ch-surface-sub)] rounded-lg border border-slate-200 dark:border-[var(--ch-border-card)] px-2.5 py-2 hover:border-rose-300 dark:hover:border-rose-700 hover:shadow-sm transition group"
                >
                  <div class="min-w-0 flex-1">
                    <p class="text-xs font-semibold text-slate-700 dark:text-[var(--ch-text-strong)] group-hover:text-rose-600 dark:group-hover:text-rose-400 transition leading-snug line-clamp-2">{crime.headline}</p>
                    <p class="text-[10px] text-slate-400 dark:text-[hsl(0_0%_45%)] mt-0.5 truncate">{crime.area}</p>
                  </div>
                  <span class="text-[10px] text-slate-400 dark:text-[hsl(0_0%_45%)] shrink-0 mt-0.5">
                    {crime.dateObj.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
                  </span>
                </a>
              ))}
            </div>
            <div class="px-3 pb-3 pt-1">
              <a
                href={routes.trinidad.murders}
                class="block text-center text-xs font-medium text-rose-600 dark:text-rose-400 hover:text-rose-700 dark:hover:text-rose-300 py-1.5"
              >
                View all {currentYear} murders &rarr;
              </a>
            </div>
          </div>
        )}

        <!-- Newsletter -->
        <NewsletterSignup variant="card" source="murder-count-page" />

      </aside>
    </div>

    <!-- Structured Data for SEO -->
    <script type="application/ld+json" set:html={JSON.stringify(faqData)} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": `Trinidad & Tobago Murder Rate & Count ${currentYear}`,
      "description": description,
      "url": pageUrl,
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "https://crimehotspots.com/"
          },
          {
            "@type": "ListItem",
            "position": 2,
            "name": "Trinidad",
            "item": "https://crimehotspots.com/trinidad/dashboard/"
          },
          {
            "@type": "ListItem",
            "position": 3,
            "name": "Murder Rate & Count"
          }
        ]
      },
      "mainEntity": {
        "@type": "Dataset",
        "name": `Trinidad & Tobago Murder Statistics ${currentYear}`,
        "description": "Live murder count and murder rate per 100,000 population for Trinidad & Tobago",
        "variableMeasured": [
          {
            "@type": "PropertyValue",
            "name": "Murder Count",
            "value": murderCount,
