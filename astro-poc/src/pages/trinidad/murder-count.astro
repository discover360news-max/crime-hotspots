---
/**
 * Trinidad Murder Rate & Count
 * JNews layout: dark hero (flip counter) → GradientStatCard vitals → year filter →
 *               monthly breakdown → sidebar
 * Supports ?year= URL param for historical year views.
 * Target keywords: "trinidad murder rate", "trinidad murder toll", "how many murders in trinidad 2026"
 */

import Layout from '../../layouts/Layout.astro';
import FlipCounter from '../../components/FlipCounter.astro';
import GradientStatCard from '../../components/GradientStatCard.astro';
import MonthlyBreakdownChart from '../../components/MonthlyBreakdownChart.astro';
import SocialProofStrip from '../../components/SocialProofStrip.astro';
import { getTrinidadCrimes, getAllCrimesFromD1 } from '../../lib/crimeData';
import { countCrimeType } from '../../lib/dashboardHelpers';
import { getCollection } from 'astro:content';
import { routes, buildRoute } from '../../config/routes';
import InfoPopup from '../../components/InfoPopup.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';
import socialProof from '../../data/social-proof.json';

Astro.response.headers.set('CDN-Cache-Control', 'max-age=82800');
Astro.response.headers.set('Cache-Control', 'public, max-age=3600, must-revalidate');

import { env } from 'cloudflare:workers';
import HeroBg from '../../components/HeroBg.astro';
const db = env.DB as D1Database | undefined;
const allCrimes = db ? await getAllCrimesFromD1(db) : await getTrinidadCrimes();

const now = new Date();
const currentYear = now.getFullYear();

// Year filter — URL param with fallback to current year
const paramYear = parseInt(Astro.url.searchParams.get('year') ?? '');
const selectedYear = (paramYear && paramYear >= 2024 && paramYear <= currentYear) ? paramYear : currentYear;
const isCurrentYear = selectedYear === currentYear;

// Available years (descending) computed from data — no extra fetch
const availableYears = [...new Set(allCrimes.map(c => c.year))].sort((a, b) => b - a);

// Filter by selected year
const selectedCrimes = allCrimes.filter(c => c.year === selectedYear);
const previousYearCrimes = allCrimes.filter(c => c.year === selectedYear - 1);
const hasPreviousYear = previousYearCrimes.length > 0;

// Murder counts
const murderCount = countCrimeType(selectedCrimes, 'Murder');
const previousYearMurders = countCrimeType(previousYearCrimes, 'Murder');

// YoY: same-period for current year, full-year for past years
const samePeriodPreviousMurders = isCurrentYear && hasPreviousYear
  ? countCrimeType(previousYearCrimes.filter(crime => {
      const crimeDate = new Date(crime.date);
      const startOfPrevYear = new Date(`${selectedYear - 1}-01-01`);
      const dayOfSelectedYear = Math.floor(
        (now.getTime() - new Date(`${selectedYear}-01-01`).getTime()) / (1000 * 60 * 60 * 24)
      );
      const samePeriodEnd = new Date(startOfPrevYear.getTime() + dayOfSelectedYear * 24 * 60 * 60 * 1000);
      return crimeDate >= startOfPrevYear && crimeDate <= samePeriodEnd;
    }), 'Murder')
  : previousYearMurders;

const yoyChange = samePeriodPreviousMurders > 0
  ? ((murderCount - samePeriodPreviousMurders) / samePeriodPreviousMurders) * 100
  : 0;
const yoyDirection = yoyChange > 0.5 ? 'up' : yoyChange < -0.5 ? 'down' : 'same';

// Rates
const POPULATION = 1500000;
const currentMurderRate = ((murderCount / POPULATION) * 100000).toFixed(1);
const previousYearMurderRate = hasPreviousYear
  ? ((previousYearMurders / POPULATION) * 100000).toFixed(1)
  : '—';

// Annualized projection (current year only)
const startOfYear = new Date(`${selectedYear}-01-01`);
const daysPassed = isCurrentYear
  ? Math.max(1, Math.floor((now.getTime() - startOfYear.getTime()) / (1000 * 60 * 60 * 24)))
  : 365;
const projectedAnnualMurders = Math.round((murderCount / daysPassed) * 365);
const projectedMurderRate = ((projectedAnnualMurders / POPULATION) * 100000).toFixed(1);
const daysPerMurder = murderCount > 0 ? Math.round(daysPassed / murderCount) : 0;

// Monthly breakdown — currentMonthIdx=12 on closed years so all bars render as "past"
const chartMonthIdx = isCurrentYear ? now.getMonth() : 12;
const murdersByMonth = Array.from({ length: 12 }, (_, i) =>
  selectedCrimes.filter(c =>
    (c.primaryCrimeType === 'Murder' || c.crimeType === 'Murder' ||
     c.relatedCrimeTypes?.split(',').map(t => t.trim()).includes('Murder')) &&
    c.month === i + 1
  ).length
);

// Latest 6 murders for sidebar (from selected year)
const latestMurders = selectedCrimes
  .filter(c =>
    c.primaryCrimeType === 'Murder' ||
    c.crimeType === 'Murder' ||
    c.relatedCrimeTypes?.split(',').map(t => t.trim()).includes('Murder')
  )
  .sort((a, b) => b.dateObj.getTime() - a.dateObj.getTime())
  .slice(0, 6);

// Latest blog post
const blogPosts = await getCollection('blog', ({ data }) => data.country === 'tt');
const latestPost = blogPosts.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
)[0];

const lastUpdated = isCurrentYear
  ? now.toLocaleDateString('en-US', { month: 'long', day: 'numeric' })
  : 'Full year data';

const ogImagePath = '/og-images/murder-count.png';
const pageUrl = 'https://crimehotspots.com/trinidad/murder-count/';
const shareText = `Trinidad Murder Count ${selectedYear}: ${murderCount} murders${isCurrentYear ? ' so far' : ''}. Track live statistics at Crime Hotspots.`;
const title = isCurrentYear
  ? `Trinidad Murder Count ${selectedYear}: ${murderCount} Murders So Far — Updated Daily | Crime Hotspots`
  : `Trinidad Murder Count ${selectedYear}: ${murderCount} Murders (Final) | Crime Hotspots`;
const description = isCurrentYear
  ? `Trinidad murder count ${selectedYear}: ${murderCount} murders (updated daily). Murder rate: ${currentMurderRate} per 100k. Projected at ${projectedMurderRate} per 100k for full year. Track the Trinidad & Tobago murder toll live.`
  : `Trinidad murder count ${selectedYear}: ${murderCount} murders (final). Murder rate: ${currentMurderRate} per 100,000 population. Historical data for Trinidad & Tobago.`;

// YoY card value for past years
const yoyCardValue = !hasPreviousYear ? 'N/A'
  : yoyDirection === 'same' ? '~0%'
  : `${yoyDirection === 'up' ? '+' : '-'}${Math.abs(yoyChange).toFixed(0)}%`;

const faqData = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": `How many murders in Trinidad and Tobago in ${selectedYear}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": isCurrentYear
          ? `Trinidad and Tobago has recorded ${murderCount} murders so far in ${selectedYear} (as of ${lastUpdated}). At the current pace, the annualized murder rate is ${projectedMurderRate} per 100,000 population, with ${projectedAnnualMurders} murders projected by year end. Data is updated daily.`
          : `Trinidad and Tobago recorded ${murderCount} murders in ${selectedYear} (final). The murder rate was ${currentMurderRate} per 100,000 population.`
      }
    },
    {
      "@type": "Question",
      "name": `What is the Trinidad murder rate in ${selectedYear}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": isCurrentYear
          ? `Trinidad and Tobago's annualized murder rate in ${selectedYear} is ${projectedMurderRate} per 100,000 population, based on ${murderCount} murders in the first ${daysPassed} days. The ${selectedYear - 1} final murder rate was ${previousYearMurderRate} per 100,000.`
          : `Trinidad and Tobago's murder rate in ${selectedYear} was ${currentMurderRate} per 100,000 population (${murderCount} total murders).`
      }
    },
    {
      "@type": "Question",
      "name": `What is the Trinidad murder toll${isCurrentYear ? ' so far' : ''} in ${selectedYear}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `The Trinidad murder toll${isCurrentYear ? ' stands' : ' stood'} at ${murderCount}${isCurrentYear ? ` as of ${lastUpdated}` : ` for the full year ${selectedYear}`}. This is ${yoyDirection === 'up' ? `up ${Math.abs(yoyChange).toFixed(0)}%` : yoyDirection === 'down' ? `down ${Math.abs(yoyChange).toFixed(0)}%` : 'similar'} compared to ${isCurrentYear ? `the same period in ${selectedYear - 1}` : `${selectedYear - 1}`} (${samePeriodPreviousMurders} murders). Data updated daily from verified news sources.`
      }
    }
  ]
};
---

<Layout title={title} description={description} includePagefind={false} ogImage={`https://crimehotspots.com${ogImagePath}`}>

  <!-- ── Dark Hero ────────────────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden w-full bg-gradient-to-br from-slate-900 to-slate-800">
    <HeroBg />
    <div class="max-w-5xl mx-auto px-4 sm:px-6 pt-8 pb-16 sm:pb-20">

      <!-- Breadcrumbs -->
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex items-center gap-1.5 text-xs text-slate-500">
          <li><a href={routes.home} class="hover:text-slate-300 transition-colors">Home</a></li>
          <li><svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></li>
          <li><a href={routes.trinidad.dashboard} class="hover:text-slate-300 transition-colors">Trinidad & Tobago</a></li>
          <li><svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></li>
          <li class="text-slate-400">Murder Count</li>
        </ol>
      </nav>

      <!-- H1 -->
      <h1 class="text-lg sm:text-xl font-bold text-white/70 text-center mb-8 uppercase tracking-widest">
        Trinidad & Tobago · Murder Count · {selectedYear}
      </h1>

      <!-- Flip Counter — bigger via .hero-counter-wrap override -->
      <div class="hero-counter-wrap flex justify-center mb-12">
        <FlipCounter value={murderCount} animateOnLoad={true} />
      </div>

      <!-- Live pulse -->
      <div class="flex flex-wrap items-center justify-center gap-x-5 gap-y-2 mb-8 text-sm">
        <span class="text-slate-300">
          <span class="font-bold text-white">{murderCount}</span> murders {isCurrentYear ? 'recorded in' : 'in'} {selectedYear}
        </span>
        {yoyDirection !== 'same' && hasPreviousYear && (
          <span class={`font-bold ${yoyDirection === 'down' ? 'text-emerald-400' : 'text-rose-400'}`}>
            {yoyDirection === 'down' ? '↓' : '↑'} {Math.abs(yoyChange).toFixed(0)}% vs {selectedYear - 1}
          </span>
        )}
        <span class="text-xs text-slate-500">{lastUpdated}</span>
      </div>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row justify-center gap-3">
        <a href={routes.trinidad.dashboard}
          class="px-6 py-3 min-h-[44px] flex items-center justify-center bg-rose-600 text-white rounded-lg hover:bg-rose-700 active:bg-rose-800 transition font-medium text-sm shadow-md">
          View Dashboard
        </a>
        <a href={routes.trinidad.murders}
          class="px-6 py-3 min-h-[44px] flex items-center justify-center border border-slate-600 text-slate-300 rounded-lg hover:bg-slate-700 active:bg-slate-600 transition font-medium text-sm">
          All {selectedYear} Murders
        </a>
      </div>

    </div>
  </section>

  <!-- ── Vitals Row (overlaps hero) ──────────────────────────────────────────── -->
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 -mt-5 relative z-10">
      {isCurrentYear ? (
        <>
          <GradientStatCard variant="crimson" value={currentMurderRate} label="YTD Rate" sublabel="per 100k population" />
          <GradientStatCard variant="slate"   value={projectedMurderRate} label="Annualized Rate" sublabel={`per 100k · ${projectedAnnualMurders} projected`} />
          <GradientStatCard variant="slate"   value={previousYearMurderRate} label={`${selectedYear - 1} Final Rate`} sublabel={`${previousYearMurders} total murders`} />
          <GradientStatCard variant="amber"   value={daysPerMurder > 0 ? `~${daysPerMurder}d` : '—'} label="Days Between Murders" sublabel="at current pace" />
        </>
      ) : (
        <>
          <GradientStatCard variant="crimson" value={currentMurderRate} label="Final Rate" sublabel="per 100k population" />
          <GradientStatCard variant="slate"   value={String(murderCount)} label="Total Murders" sublabel={`${selectedYear} full year`} />
          <GradientStatCard variant="slate"   value={yoyCardValue} label={`vs ${selectedYear - 1}`} sublabel="full year comparison" />
          <GradientStatCard variant="amber"   value={murderCount > 0 ? `~${(murderCount / 365).toFixed(1)}` : '0'} label="Daily Average" sublabel="murders per day" />
        </>
      )}
    </div>
  </div>

  <!-- ── Social Proof ────────────────────────────────────────────────────────── -->
  <div class="max-w-5xl mx-auto px-4 sm:px-6 pb-10">
    <SocialProofStrip variant="strip" incidentCount={allCrimes.length} />
  </div>

  <!-- ── Year Selector ───────────────────────────────────────────────────────── -->
  <div class="max-w-5xl mx-auto px-4 sm:px-6 mt-6">
    <div class="flex flex-wrap items-center gap-2">
      <span class="text-xs text-slate-500 dark:text-[var(--ch-text-faint)]">Year:</span>
      {availableYears.map(year => (
        <a
          href={year === currentYear ? '/trinidad/murder-count/' : `/trinidad/murder-count/?year=${year}`}
          class={`px-3 py-1.5 rounded-full text-xs font-medium transition ${
            year === selectedYear
              ? 'bg-rose-600 text-white'
              : 'bg-slate-100 dark:bg-[hsl(0_0%_15%)] text-slate-600 dark:text-[hsl(0_0%_60%)] hover:bg-slate-200 dark:hover:bg-[hsl(0_0%_20%)]'
          }`}
        >
          {year}
        </a>
      ))}
    </div>
  </div>

  <!-- ── Main Content ─────────────────────────────────────────────────────────── -->
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-8" data-pagefind-ignore>
    <div class="lg:grid lg:grid-cols-[1fr_256px] lg:gap-8 lg:items-start">

      <!-- Left column -->
      <main class="min-w-0 space-y-8">

        <!-- YoY comparison -->
        {hasPreviousYear && (
          <div class="bg-slate-50 dark:bg-[var(--ch-surface)] rounded-lg border border-slate-200 dark:border-[var(--ch-border-subtle)] p-4">
            <div class="flex items-center gap-1">
              <p class="text-sm text-slate-600 dark:text-[hsl(0_0%_70%)]">
                {isCurrentYear ? `Same period in ${selectedYear - 1}:` : `${selectedYear - 1} full year:`}
                {' '}<span class="font-bold text-slate-800 dark:text-[var(--ch-text-heading)]">{samePeriodPreviousMurders}</span> murders
              </p>
              {isCurrentYear && (
                <InfoPopup id="murder-comparison-info">
                  <p class="font-bold mb-2 text-slate-700 dark:text-[var(--ch-text-heading)]">How We Compare Years</p>
                  <p class="mb-3">To make a fair comparison, we only look at the same time window in both years. For example, if today is February 10, we compare January 1–February 10 of {selectedYear} against January 1–February 10 of {selectedYear - 1}.</p>
                  <p>A green arrow means fewer murders so far this year.</p>
                </InfoPopup>
              )}
            </div>
            {yoyDirection !== 'same' && (
              <p class={`text-xs mt-2 ${yoyDirection === 'down' ? 'text-emerald-600' : 'text-rose-600'}`}>
                {yoyDirection === 'down' ? '↓' : '↑'} {Math.abs(yoyChange).toFixed(0)}% vs {selectedYear - 1}
              </p>
            )}
          </div>
        )}

        <!-- Monthly breakdown -->
        <MonthlyBreakdownChart
          values={murdersByMonth}
          currentMonthIdx={chartMonthIdx}
          label={`Murders by Month — ${selectedYear}`}
          footnote={isCurrentYear
            ? `Based on ${daysPassed} days of data · annualized rate assumes current pace through year end · population estimate ${(POPULATION / 1_000_000).toFixed(1)}M`
            : `Full year · ${murderCount} total murders · population estimate ${(POPULATION / 1_000_000).toFixed(1)}M`}
        />

        <!-- Ko-fi CTA -->
        <div class="rounded-lg border border-slate-200 dark:border-[var(--ch-border-subtle)] bg-slate-50 dark:bg-[hsl(0_0%_9%)] px-4 py-3 flex flex-col sm:flex-row sm:items-center gap-3">
          <p class="text-sm text-slate-600 dark:text-[var(--ch-text-muted)] flex-1 min-w-0">
            Keeping this data ad-free for <strong class="text-slate-800 dark:text-[var(--ch-text-heading)]">{socialProof.monthly_readers_display}</strong> readers depends on community support.
          </p>
          <a
            href="https://ko-fi.com/crimehotspots"
            target="_blank"
            rel="noopener noreferrer"
            class="shrink-0 inline-flex items-center justify-center px-4 py-2 text-xs font-bold bg-rose-600 hover:bg-rose-700 active:bg-rose-800 text-white rounded-lg transition"
          >
            Support on Ko-fi
          </a>
        </div>

        <!-- Action buttons -->
        <div class="flex flex-col sm:flex-row gap-3">
          <a href={routes.trinidad.dashboard}
            class="px-6 py-3 min-h-[44px] flex items-center justify-center bg-rose-600 text-white rounded-lg hover:bg-rose-700 active:bg-rose-800 transition font-medium text-sm shadow-md">
            View Dashboard
          </a>
          <a href={routes.trinidad.statistics}
            class="px-6 py-3 min-h-[44px] flex items-center justify-center border border-slate-300 dark:border-[var(--ch-border)] text-slate-600 dark:text-[hsl(0_0%_70%)] rounded-lg hover:bg-slate-50 dark:hover:bg-[hsl(0_0%_12%)] transition font-medium text-sm">
            All Crime Statistics
          </a>
        </div>

        <!-- Latest Analysis -->
        {latestPost && (
          <div>
            <p class="text-sm text-slate-500 dark:text-[var(--ch-text-muted)] mb-3">Latest Analysis</p>
            <a href={`/blog/${latestPost.id}/`}
              class="block bg-white dark:bg-[var(--ch-surface)] rounded-lg border border-slate-200 dark:border-[var(--ch-border-subtle)] p-4 hover:border-rose-300 dark:hover:border-rose-800 hover:shadow-sm transition">
              <h3 class="font-bold text-slate-800 dark:text-[var(--ch-text-heading)] text-caption mb-2">{latestPost.data.title}</h3>
              <p class="text-xs text-slate-500 dark:text-[var(--ch-text-muted)]">
                {latestPost.data.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })} &bull; {latestPost.data.readTime}
              </p>
            </a>
          </div>
        )}

      </main>

      <!-- ── Sidebar ────────────────────────────────────────────────────────── -->
      <aside class="mt-10 lg:mt-0 lg:sticky lg:top-20 space-y-5 min-w-0">

        <!-- Share -->
        <div class="flex items-center gap-2">
          <span class="text-xs text-slate-500 dark:text-[var(--ch-text-faint)]">Share:</span>
          <button class="sb-share-btn p-2 rounded-lg border border-slate-300 dark:border-[var(--ch-border)] text-slate-600 dark:text-[var(--ch-text-muted)] hover:bg-slate-50 dark:hover:bg-[hsl(0_0%_12%)] transition"
            data-platform="twitter" data-share-url={pageUrl} data-share-text={shareText}
            title="Share on X (Twitter)" aria-label="Share on X (Twitter)">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </button>
          <button class="sb-share-btn p-2 rounded-lg border border-slate-300 dark:border-[var(--ch-border)] text-slate-600 dark:text-[var(--ch-text-muted)] hover:bg-slate-50 dark:hover:bg-[hsl(0_0%_12%)] transition"
            data-platform="facebook" data-share-url={pageUrl} data-share-text={shareText}
            title="Share on Facebook" aria-label="Share on Facebook">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </button>
          <button class="sb-share-btn p-2 rounded-lg border border-slate-300 dark:border-[var(--ch-border)] text-slate-600 dark:text-[var(--ch-text-muted)] hover:bg-slate-50 dark:hover:bg-[hsl(0_0%_12%)] transition"
            data-platform="whatsapp" data-share-url={pageUrl} data-share-text={shareText}
            title="Share on WhatsApp" aria-label="Share on WhatsApp">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
          </button>
          <button id="share-copy"
            class="p-2 rounded-lg border border-slate-300 dark:border-[var(--ch-border)] text-slate-600 dark:text-[var(--ch-text-muted)] hover:bg-slate-50 dark:hover:bg-[hsl(0_0%_12%)] transition"
            title="Copy link" aria-label="Copy link">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
          </button>
        </div>
        <p id="copy-feedback" class="text-xs text-emerald-600 opacity-0 transition-opacity">Link copied!</p>

        <!-- Latest Incidents -->
        {latestMurders.length > 0 && (
          <div class="rounded-lg border border-slate-200 dark:border-[var(--ch-border-card)] bg-slate-50 dark:bg-[hsl(0_0%_7%)] overflow-hidden">
            <div class="px-3 pt-3 pb-2 border-b border-slate-200 dark:border-[var(--ch-border-subtle)]">
