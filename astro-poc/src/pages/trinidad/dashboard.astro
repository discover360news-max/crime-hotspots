---
/**
 * Trinidad & Tobago Crime Dashboard — JNews-style hierarchy
 * Layout: dark hero → vitals row → stat breakdown → dark band → map+areas → insights → tail
 */

import Layout from '../../layouts/Layout.astro';
import { getAllCrimesFromD1, getTrinidadCrimes, generateNameSlug } from '../../lib/crimeData';
import { countCrimeType, calculateInsights } from '../../lib/dashboardHelpers';
import { getTotalCrimeCount } from '../../lib/statisticsHelpers';
import { getCollection } from 'astro:content';
import GradientStatCard from '../../components/GradientStatCard.astro';
import StatCard from '../../components/StatCard.astro';
import QuickInsightsCard from '../../components/QuickInsightsCard.astro';
import TopRegionsCard from '../../components/TopRegionsCard.astro';
import DashboardInfoCards from '../../components/DashboardInfoCards.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';
import FiltersTray from '../../components/FiltersTray.astro';
import InfoPopup from '../../components/InfoPopup.astro';
import LoadingShimmer from '../../components/LoadingShimmer.astro';
import SiteNotificationBanner from '../../components/SiteNotificationBanner.astro';
import MapLegend from '../../components/MapLegend.astro';
import SocialProofStrip from '../../components/SocialProofStrip.astro';
import { dataUpdateNotice } from '../../config/siteNotifications';
import { getCountryName } from '../../data/countries';
import { routes, buildRoute } from '../../config/routes';
import '../../styles/dashboard.css';

Astro.response.headers.set('CDN-Cache-Control', 'max-age=82800');
Astro.response.headers.set('Cache-Control', 'public, max-age=3600, must-revalidate');

import { env } from 'cloudflare:workers';
const db = env.DB as D1Database | undefined;
const allCrimes = db ? await getAllCrimesFromD1(db) : await getTrinidadCrimes();

const availableYears = [...new Set(allCrimes.map(c => c.year))].sort((a, b) => b - a);
const currentYear = availableYears[0];
const crimes = allCrimes.filter(crime => crime.year === currentYear);
const insights = calculateInsights(crimes);

// Region / Area filter data
const dashboardRegions = [...new Set(allCrimes.map(c => c.region).filter(Boolean))].sort();
const dashboardAreas = [...new Set(allCrimes.map(c => c.area).filter(Boolean))].sort();
const dashboardRegionToAreas: Record<string, string[]> = {};
allCrimes.forEach(c => {
  if (c.region && c.area) {
    if (!dashboardRegionToAreas[c.region]) dashboardRegionToAreas[c.region] = [];
    if (!dashboardRegionToAreas[c.region].includes(c.area)) dashboardRegionToAreas[c.region].push(c.area);
  }
});
Object.values(dashboardRegionToAreas).forEach(arr => (arr as string[]).sort());

// Freshness
const latestCrimeDate = crimes[0]?.dateObj ?? new Date();
const freshnessText = latestCrimeDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });

// Hottest area slug for vitals card link
const dangerousAreaSlug = generateNameSlug(insights.mostDangerousRegion);

// This-week stats for hero pulse (3-day lag — crimes are logged by incident date)
const now = new Date();
const lagDays = 3;
const weekEnd = new Date(); weekEnd.setDate(now.getDate() - lagDays); weekEnd.setHours(0, 0, 0, 0);
const weekAgo = new Date(); weekAgo.setDate(now.getDate() - (7 + lagDays)); weekAgo.setHours(0, 0, 0, 0);
const twoWeeksAgo = new Date(); twoWeeksAgo.setDate(now.getDate() - (14 + lagDays)); twoWeeksAgo.setHours(0, 0, 0, 0);
const thisWeekCrimes = allCrimes.filter(c => c.dateObj >= weekAgo && c.dateObj < weekEnd);
const lastWeekCrimes = allCrimes.filter(c => c.dateObj >= twoWeeksAgo && c.dateObj < weekAgo);
const murdersThisWeek = countCrimeType(thisWeekCrimes, 'Murder');
const murdersLastWeek = countCrimeType(lastWeekCrimes, 'Murder');
const murderChange = murdersLastWeek > 0
  ? Math.round(((murdersThisWeek - murdersLastWeek) / murdersLastWeek) * 100)
  : 0;
const weekChange = lastWeekCrimes.length > 0
  ? Math.round(((thisWeekCrimes.length - lastWeekCrimes.length) / lastWeekCrimes.length) * 100)
  : 0;
const areaCountMap = new Map<string, number>();
thisWeekCrimes.forEach(c => {
  const a = c.area || 'Unknown';
  if (a !== 'Unknown') areaCountMap.set(a, (areaCountMap.get(a) || 0) + 1);
});
const topArea = Array.from(areaCountMap.entries()).sort((a, b) => b[1] - a[1])[0];

// Latest TT weekly blog post for hero card
const allBlogPosts = await getCollection('blog');
const latestPost = allBlogPosts
  .filter(p => p.data.country === 'tt')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())[0];

function formatPostDate(date: Date) {
  return new Date(date).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
}

const title = "Trinidad Crime Dashboard 2026 - Murder Count, Statistics & Live Map";
const description = "Track Trinidad & Tobago crime statistics for 2026. Live murder count, robbery rates, and incident map. Updated daily with the latest crime data.";
---


<Layout title={title} description={description} includeLeaflet={true} includeTurnstile={true}>

  <!-- ═══════════════════════════════════════════════════════════════
       HERO — dark gradient, full viewport width
       ═══════════════════════════════════════════════════════════════ -->
  <section class="w-full bg-gradient-to-br from-slate-900 to-slate-800" data-pagefind-ignore>
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-8 sm:py-10">

      <!-- Breadcrumb (light) -->
      <nav aria-label="Breadcrumb" class="mb-4">
        <ol class="flex items-center gap-1.5 text-xs text-slate-500">
          <li><a href="/" class="hover:text-slate-300 transition">Home</a></li>
          <li><svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></li>
          <li class="text-slate-400">{getCountryName('tt')}</li>
        </ol>
      </nav>

      <div class="grid sm:grid-cols-[1fr_200px] gap-6 items-center">

        <!-- Left: title + pulse + CTAs -->
        <div>
          <h1 class="text-4xl sm:text-5xl font-black text-white leading-tight mb-2">
            Trinidad &amp; Tobago
          </h1>
          <p class="text-slate-400 text-sm mb-5">
            Crime Statistics Dashboard <span id="dashboardYear" class="font-medium text-slate-300">for {currentYear}</span>
          </p>

          <!-- Live this-week pulse -->
          {thisWeekCrimes.length > 0 && (
            <div class="flex items-start gap-2.5 mb-5 bg-white/5 rounded-lg px-4 py-3 border border-white/10">
              <span class="relative flex h-2 w-2 mt-1 shrink-0">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-rose-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-rose-500"></span>
              </span>
              <p class="text-slate-300 text-sm leading-relaxed">
                This week: <strong class="text-white font-bold">{thisWeekCrimes.length} crimes</strong>
                {weekChange !== 0 && (
                  <span class={weekChange > 0 ? 'text-rose-400' : 'text-emerald-400'}>
                    {' '}({weekChange > 0 ? '+' : ''}{weekChange}% vs last week)
                  </span>
                )}.
                {topArea && <> <span class="text-white font-medium">{topArea[0]}</span> leads with {topArea[1]}.</>}
                {murdersThisWeek > 0 && murderChange !== 0 && (
                  <> Murders{' '}
                    <span class={murderChange > 0 ? 'font-medium text-rose-400' : 'font-medium text-emerald-400'}>
                      {murderChange > 0 ? 'up' : 'down'} {Math.abs(murderChange)}%
                    </span> WoW.
                  </>
                )}
              </p>
            </div>
          )}

          <!-- CTAs -->
          <div class="flex gap-3 items-center flex-wrap mb-5">
            <a href={routes.trinidad.headlines}
              class="px-4 py-2 inline-flex items-center gap-2 rounded-lg bg-rose-600 text-white hover:bg-rose-500 active:bg-rose-700 transition font-medium text-xs shadow-sm whitespace-nowrap">
              Headlines
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
            </a>
            <a href={routes.trinidad.murderCount}
              class="px-4 py-2 inline-flex items-center gap-2 rounded-lg border border-slate-500 text-slate-300 hover:border-slate-400 hover:text-white active:bg-white/5 transition font-medium text-xs whitespace-nowrap">
              Murder Count
            </a>
          </div>

          <!-- Data freshness -->
          <p id="dataFreshness" class="text-slate-500 text-xs flex items-center gap-1">
            <svg class="w-3 h-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Data as of {freshnessText}
          </p>
        </div>

        <!-- Right: latest report card + social proof -->
        <div class="flex flex-col gap-3">
          {latestPost && (
            <a href={`/blog/${latestPost.id}/`}
              class="block bg-white/8 border border-white/10 rounded-xl p-4 hover:bg-white/12 hover:border-white/20 transition group">
              <span class="text-[10px] font-semibold text-slate-400 uppercase tracking-widest">Latest Report</span>
              <h3 class="text-white text-sm font-bold mt-2 mb-3 leading-snug line-clamp-4 group-hover:text-rose-300 transition">
                {latestPost.data.title}
              </h3>
              <div class="flex items-center justify-between gap-2">
                <span class="text-slate-500 text-xs">{formatPostDate(latestPost.data.date)}</span>
                <span class="text-rose-400 text-xs font-semibold group-hover:text-rose-300 transition">Read &rarr;</span>
              </div>
            </a>
          )}
          <SocialProofStrip variant="sidebar" incidentCount={allCrimes.length} />
        </div>

      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════
       STICKY FILTER BAR
       ═══════════════════════════════════════════════════════════════ -->
  <div id="filterBar" class="sticky top-16 z-30 bg-white/95 dark:bg-[var(--ch-surface)]/95 backdrop-blur-sm border-b border-slate-200 dark:border-[var(--ch-border-subtle)]">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-2 flex items-center gap-3 flex-wrap">
      <span class="text-xs text-slate-400 dark:text-[hsl(0_0%_48%)] font-medium shrink-0">Year</span>
      <select
        id="yearFilter"
        class="filter-select py-1 pl-2.5 pr-6 text-xs border border-slate-200 dark:border-[var(--ch-border)] text-slate-600 dark:text-[hsl(0_0%_70%)] rounded-md bg-white dark:bg-[var(--ch-bg)] hover:bg-slate-50 dark:hover:bg-[hsl(0_0%_12%)] transition font-medium cursor-pointer"
      ></select>
      <span class="h-4 w-px bg-slate-200 dark:bg-[hsl(0_0%_20%)] shrink-0"></span>
      <button
        id="filtersBtn"
        class="inline-flex items-center gap-1.5 text-xs font-medium text-slate-600 dark:text-[hsl(0_0%_65%)] hover:text-rose-600 dark:hover:text-rose-400 bg-slate-100 dark:bg-[hsl(0_0%_12%)] hover:bg-rose-50 dark:hover:bg-rose-950/30 rounded-md px-2.5 py-1 transition cursor-pointer whitespace-nowrap"
      >
        <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2a1 1 0 01-.293.707L13 13.414V19a1 1 0 01-.553.894l-4 2A1 1 0 017 21v-7.586L3.293 6.707A1 1 0 013 6V4z" />
        </svg>
        <span id="filtersBtnText">Filters</span>
      </button>
      <button
        id="clearFiltersInline"
        class="hidden text-xs text-rose-600 dark:text-rose-400 hover:text-rose-700 dark:hover:text-rose-300 font-medium whitespace-nowrap transition"
      >Clear</button>
    </div>
  </div>


  <!-- ═══════════════════════════════════════════════════════════════
       ZONE 1 — Notification + Vitals + Crime Breakdown
       ═══════════════════════════════════════════════════════════════ -->
  <div class="max-w-5xl mx-auto px-4 sm:px-6 pt-6 pb-2" data-pagefind-ignore>

    <SiteNotificationBanner notification={dataUpdateNotice} />

    <!-- Vitals row: 4 gradient cards -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4 mb-8">
      <GradientStatCard
        variant="slate"
        value={getTotalCrimeCount(crimes)}
        label="Total Crimes"
        sublabel="year to date"
        id="totalIncidents"
      />
      <GradientStatCard
        variant="crimson"
        value={countCrimeType(crimes, 'Murder')}
        label="Murders"
        sublabel="year to date"
        id="vitals-murders"
      />
      <GradientStatCard
        variant="amber"
        value={Number.isNaN(+insights.avgPerDay) ? '—' : insights.avgPerDay}
        label="Crimes / Day"
        sublabel={Number.isNaN(+insights.victimsPerDay) ? '— victims/day' : `${insights.victimsPerDay} victims/day`}
        id="vitals-daily"
      />
      <GradientStatCard
        variant="violet"
        value={insights.mostDangerousRegionCount}
        label="Hottest Area"
        sublabel={insights.mostDangerousRegion}
        id="vitals-hotspot"
        href={buildRoute.area(dangerousAreaSlug)}
      />
    </div>

    <!-- Crime Breakdown -->
    <div class="flex items-center gap-1 px-1 mb-2">
      <h2 class="text-sm font-bold text-slate-500 dark:text-[var(--ch-text-muted)]">Crime Breakdown</h2>
      <InfoPopup id="crime-types-info">
        <p class="font-bold mb-2 text-slate-700 dark:text-[var(--ch-text-heading)]">Crime Type Definitions</p>
        <ul class="space-y-1.5">
          <li><span class="font-bold text-slate-700 dark:text-[var(--ch-text-strong)]">Murder</span> — Fatal violent crime</li>
          <li><span class="font-bold text-slate-700 dark:text-[var(--ch-text-strong)]">Attempted Murder</span> — Non-fatal attack carried out with intent to kill</li>
          <li><span class="font-bold text-slate-700 dark:text-[var(--ch-text-strong)]">Shooting</span> — Firearm discharged at a bystander or with no specific person targeted</li>
          <li><span class="font-bold text-slate-700 dark:text-[var(--ch-text-strong)]">Assault</span> — Physical attack causing bodily harm</li>
          <li><span class="font-bold text-slate-700 dark:text-[var(--ch-text-strong)]">Sexual Assault</span> — Any sexual act carried out without consent</li>
          <li><span class="font-bold text-slate-700 dark:text-[var(--ch-text-strong)]">Domestic Violence</span> — Violent or coercive conduct within an intimate or family relationship</li>
          <li><span class="font-bold text-slate-700 dark:text-[var(--ch-text-strong)]">Kidnapping</span> — Unlawful abduction or restraint of a person</li>
          <li><span class="font-bold text-slate-700 dark:text-[var(--ch-text-strong)]">Robbery</span> — Taking property using force or the threat of force</li>
          <li><span class="font-bold text-slate-700 dark:text-[var(--ch-text-strong)]">Carjacking</span> — Vehicle stolen by force; every carjacking also counts toward Robbery</li>
          <li><span class="font-bold text-slate-700 dark:text-[var(--ch-text-strong)]">Home Invasion</span> — Forced entry into an occupied residence</li>
          <li><span class="font-bold text-slate-700 dark:text-[var(--ch-text-strong)]">Extortion</span> — Obtaining money or property through threats or coercion</li>
          <li><span class="font-bold text-slate-700 dark:text-[var(--ch-text-strong)]">Burglary</span> — Unlawful entry with intent to steal (unoccupied property)</li>
          <li><span class="font-bold text-slate-700 dark:text-[var(--ch-text-strong)]">Theft</span> — Property taken without force</li>
          <li><span class="font-bold text-slate-700 dark:text-[var(--ch-text-strong)]">Arson</span> — Deliberate setting of fires to property</li>
          <li><span class="font-bold text-slate-700 dark:text-[var(--ch-text-strong)]">Seizures</span> — Police confiscation of drugs, firearms, or contraband</li>
        </ul>
      </InfoPopup>
    </div>

    <div class="stats-wrapper relative min-h-[140px] overflow-hidden mb-6">
      <!-- Shimmer -->
      <div id="statsShimmer" class="absolute inset-0 flex gap-4 overflow-x-auto pb-4 transition-opacity duration-300">
        {[...Array(10)].map(() => (
          <div class="flex-shrink-0" style="width: 160px;">
            <LoadingShimmer height="120px" />
          </div>
        ))}
      </div>
      <!-- Stat cards -->
      <div class="stats-scroll-container absolute inset-0 opacity-0 transition-opacity duration-300">
        <StatCard value={countCrimeType(crimes, 'Murder')} label="Murders" crimeType="Murder" />
        <StatCard value={countCrimeType(crimes, 'Attempted Murder')} label="Attempted Murders" crimeType="Attempted Murder" />
        <StatCard value={countCrimeType(crimes, 'Shooting')} label="Shootings" crimeType="Shooting" />
        <StatCard value={countCrimeType(crimes, 'Robbery')} label="Robberies" crimeType="Robbery" />
        <StatCard value={countCrimeType(crimes, 'Carjacking')} label="Carjackings" crimeType="Carjacking" />
        <StatCard value={countCrimeType(crimes, 'Home Invasion')} label="Home Invasions" crimeType="Home Invasion" />
        <StatCard value={countCrimeType(crimes, 'Burglary')} label="Burglaries" crimeType="Burglary" />
        <StatCard value={countCrimeType(crimes, 'Theft')} label="Thefts" crimeType="Theft" />
        <StatCard value={countCrimeType(crimes, 'Assault')} label="Assaults" crimeType="Assault" />
        <StatCard value={countCrimeType(crimes, 'Kidnapping')} label="Kidnappings" crimeType="Kidnapping" />
      </div>
      <!-- Scroll hint -->
      <div id="statsScrollHint" class="absolute right-0 top-0 bottom-4 w-16 bg-gradient-to-l from-white via-white/90 to-transparent dark:from-[var(--ch-bg)] dark:via-[hsl(0_0%_8%_/_0.9)] pointer-events-none flex items-center justify-end pr-2 opacity-0 transition-opacity duration-300">
        <svg class="w-4 h-4 text-rose-600 animate-pulse" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </div>
    </div>

  </div>


  <!-- ═══════════════════════════════════════════════════════════════
       DARK SEPARATOR BAND — full viewport width
       ═══════════════════════════════════════════════════════════════ -->
  <div class="w-full bg-slate-900 dark:bg-[hsl(0_0%_5%)] py-4" data-pagefind-ignore>
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest">Live Data</p>
      <h2 class="text-white font-black text-lg mt-0.5">Crime Incidents &amp; Hotspots</h2>
    </div>
  </div>


  <!-- ═══════════════════════════════════════════════════════════════
       ZONE 2 — Map + Top Areas (side by side on desktop)
       ═══════════════════════════════════════════════════════════════ -->
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-6" data-pagefind-ignore>

    <div class="grid lg:grid-cols-[3fr_2fr] gap-6 mb-8 items-start">

      <!-- Map column -->
      <div>
        <div class="flex items-center gap-2 mb-3">
          <h3 class="text-sm font-bold text-slate-500 dark:text-[var(--ch-text-muted)]">Crime Incidents Map</h3>
          <InfoPopup id="map-info">
            <p class="font-bold mb-2 text-slate-700 dark:text-[var(--ch-text-heading)]">Understanding the Map</p>
            <p class="mb-3">This map shows estimated/reported locations of crimes and is updated daily.</p>
            <p class="font-bold mb-2 text-slate-700 dark:text-[var(--ch-text-heading)]">How to Use:</p>
            <ul class="list-disc list-inside space-y-1">
              <li>Click clusters to zoom in</li>
              <li>Click markers for incident details</li>
              <li>Use two fingers to pan map</li>
            </ul>
          </InfoPopup>
        </div>

        <div id="mapContainer" class="relative h-[450px]">
          <div id="mapShimmer" class="absolute inset-0 w-full transition-opacity duration-300">
            <LoadingShimmer height="100%" />
          </div>
          <div id="leafletMap" class="absolute inset-0 w-full rounded-lg opacity-0 transition-opacity duration-300"></div>
          <div id="mapZoomHintTrinidad" class="absolute inset-0 bg-black/50 flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300 z-10">
            <div class="bg-white/85 dark:bg-[var(--ch-surface)]/85 backdrop-blur-md rounded-lg px-6 py-4 shadow-xl max-w-xs text-center">
              <p class="text-caption font-bold text-slate-600 dark:text-[var(--ch-text-heading)]">Use two fingers to move map</p>
              <p class="text-caption text-slate-600 dark:text-[var(--ch-text-muted)] mt-1">One finger scrolls the page</p>
            </div>
          </div>
        </div>
        <MapLegend />
      </div>

      <!-- Top Areas column -->
      <div>
        <div class="flex items-center gap-2 mb-3">
          <h3 class="text-sm font-bold text-slate-500 dark:text-[var(--ch-text-muted)]">Top Areas</h3>
          <InfoPopup id="top-areas-risk-info">
            <p class="font-bold mb-2 text-slate-700 dark:text-[var(--ch-text-heading)]">Understanding Risk Assessment</p>
            <p class="mb-3">Each area's risk level is calculated based on crime severity and victim impact.</p>
            <p class="font-bold mb-2 text-slate-700 dark:text-[var(--ch-text-heading)]">How It Works:</p>
            <ul class="list-disc list-inside space-y-1 mb-3">
              <li>Each crime type has a severity weight (Murder=10, Theft=2, etc.)</li>
              <li>Victim counts multiply risk for serious crimes</li>
              <li>Area risk = sum of all crime risk scores</li>
              <li>Bar shows percentage relative to highest-risk area</li>
            </ul>
            <p class="font-bold mb-2 text-slate-700 dark:text-[var(--ch-text-heading)]">Color Guide:</p>
            <ul class="list-disc list-inside space-y-1">
              <li><span class="text-green-600 font-medium">Green</span>: Low risk (0-33%)</li>
              <li><span class="text-yellow-600 font-medium">Yellow</span>: Medium risk (34-66%)</li>
              <li><span class="text-rose-600 font-medium">Red</span>: High risk (67-100%)</li>
            </ul>
          </InfoPopup>
          <div class="ml-auto flex items-center gap-3">
            <a href={routes.trinidad.compare} class="text-xs text-slate-400 dark:text-[hsl(0_0%_45%)] hover:text-rose-600 dark:hover:text-rose-400 font-medium transition">
              Compare
              <svg class="w-3 h-3 inline-block ml-0.5 -mt-px" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
            <span class="text-slate-200 dark:text-[hsl(0_0%_20%)]">|</span>
            <a href={routes.trinidad.areas} class="text-xs text-slate-400 dark:text-[hsl(0_0%_45%)] hover:text-rose-600 dark:hover:text-rose-400 font-medium transition">
              All
              <svg class="w-3 h-3 inline-block ml-0.5 -mt-px" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>

        <div class="relative">
