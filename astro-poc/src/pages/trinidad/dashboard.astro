  <!-- ═══════════════════════════════════════════════════════════════
       SCRIPTS — unchanged from previous version
       ═══════════════════════════════════════════════════════════════ -->

  <script>
    import { initializeDashboardData } from '../../scripts/dashboardDataLoader';
    document.addEventListener('DOMContentLoaded', initializeDashboardData);
  </script>

  <script>
    import { initializeDashboardMap } from '../../scripts/dashboardMapInit';
    document.addEventListener('DOMContentLoaded', initializeDashboardMap);
  </script>

  <script>
    import { updateLeafletMap } from '../../scripts/leafletMap';
    import {
      updateQuickInsights,
      updateTopRegions,
      applyPrecomputedStats,
      applyPrecomputedInsights,
      applyPrecomputedTopRegions,
    } from '../../scripts/dashboardUpdates';
    import { initializeStatCardFiltering } from '../../scripts/statCardFiltering';

    function updateSubtitleYear(selectedValue: string) {
      const dashboardYear = document.getElementById('dashboardYear');
      if (dashboardYear) {
        dashboardYear.textContent = selectedValue === 'all' ? '(All Years)' : `for ${selectedValue}`;
      }

      const freshness = document.getElementById('dataFreshness');
      if (freshness && window.__crimesData) {
        const filtered: any[] = selectedValue === 'all'
          ? window.__crimesData
          : window.__crimesData.filter((c: any) => String(c.year) === selectedValue);
        if (filtered.length > 0) {
          const newest = filtered.reduce((a: any, b: any) => a.dateObj > b.dateObj ? a : b);
          const d = newest.dateObj as Date;
          freshness.innerHTML = `<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg> Data as of ${d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}`;
        }
      }
    }

    function populateYearDropdown(crimes: any[]) {
      const yearFilterEl = document.getElementById('yearFilter') as unknown as HTMLSelectElement | null;
      if (!yearFilterEl) return;

      const defaultYear = (window as any).__dashboardDefaultYear;
      const availableYears: number[] = ((window as any).__dashboardAvailableYears as number[] | undefined) ??
        [...new Set(crimes.map((c: any) => c.year as number))].sort((a, b) => b - a);

      yearFilterEl.innerHTML = '';
      availableYears.forEach(year => {
        const opt = document.createElement('option');
        opt.value = String(year);
        opt.textContent = String(year);
        opt.selected = String(year) === defaultYear;
        yearFilterEl.appendChild(opt);
      });
      const allOpt = document.createElement('option');
      allOpt.value = 'all';
      allOpt.textContent = 'All Years';
      yearFilterEl.appendChild(allOpt);
    }

    async function onYearChange(selectedValue: string) {
      const updateStart = Date.now();

      const statsShimmer = document.getElementById('statsShimmer');
      const statsContainer = document.querySelector('.stats-scroll-container') as HTMLElement | null;
      const insightsShimmer = document.getElementById('insightsShimmer');
      const insightsCards = document.getElementById('insightsCards');
      const topRegionsShimmer = document.getElementById('topRegionsShimmer');
      const topRegionsCard = document.getElementById('topRegionsCard');
      const mapShimmer = document.getElementById('mapShimmer');
      const leafletMapEl = document.getElementById('leafletMap');

      if (statsShimmer) { statsShimmer.style.opacity = '1'; statsShimmer.style.pointerEvents = ''; }
      if (statsContainer) statsContainer.style.opacity = '0';
      if (insightsShimmer) { insightsShimmer.style.opacity = '1'; insightsShimmer.style.pointerEvents = ''; }
      if (insightsCards) insightsCards.style.opacity = '0';
      if (topRegionsShimmer) { topRegionsShimmer.style.opacity = '1'; topRegionsShimmer.style.pointerEvents = ''; }
      if (topRegionsCard) topRegionsCard.style.opacity = '0';
      if (mapShimmer) { mapShimmer.style.opacity = '1'; mapShimmer.style.pointerEvents = ''; }
      if (leafletMapEl) leafletMapEl.style.opacity = '0';

      try {
        const [dashData, crimesData] = await Promise.all([
          fetch(`/api/dashboard/?year=${selectedValue}`).then(r => r.json()),
          fetch(`/api/crimes/?year=${selectedValue}`).then(r => r.json()),
        ]) as [any, any];

        const crimes = (crimesData.crimes as any[]).map((c: any) => ({
          ...c,
          dateObj: new Date(c.year, c.month - 1, c.day),
        }));
        window.__crimesData = crimes;

        applyPrecomputedStats(dashData.stats, dashData.trends);
        applyPrecomputedInsights(dashData.insights);
        applyPrecomputedTopRegions(dashData.topRegions);
        updateLeafletMap(crimes, '/trinidad/crime/');
        updateSubtitleYear(selectedValue);

        await Promise.all([
          window.hideShimmerWithMinTime(statsShimmer, statsContainer, updateStart),
          window.hideShimmerWithMinTime(insightsShimmer, insightsCards, updateStart),
          window.hideShimmerWithMinTime(topRegionsShimmer, topRegionsCard, updateStart),
          window.hideShimmerWithMinTime(mapShimmer, leafletMapEl, updateStart),
        ]);
      } catch (err) {
        console.warn('Year filter update failed:', err);
        // Restore visible state so the dashboard doesn't freeze on shimmers
        if (statsShimmer) { statsShimmer.style.opacity = '0'; statsShimmer.style.pointerEvents = 'none'; }
        if (statsContainer) statsContainer.style.opacity = '1';
        if (insightsShimmer) { insightsShimmer.style.opacity = '0'; insightsShimmer.style.pointerEvents = 'none'; }
        if (insightsCards) insightsCards.style.opacity = '1';
        if (topRegionsShimmer) { topRegionsShimmer.style.opacity = '0'; topRegionsShimmer.style.pointerEvents = 'none'; }
        if (topRegionsCard) topRegionsCard.style.opacity = '1';
        if (mapShimmer) { mapShimmer.style.opacity = '0'; mapShimmer.style.pointerEvents = 'none'; }
        if (leafletMapEl) leafletMapEl.style.opacity = '1';
      }
    }

    function setupYearFilter() {
      const crimes = window.__crimesData;
      if (!crimes) return;

      populateYearDropdown(crimes);

      const yearFilterEl = document.getElementById('yearFilter') as unknown as HTMLSelectElement | null;
      if (yearFilterEl) {
        yearFilterEl.addEventListener('change', (e) => {
          onYearChange((e.target as HTMLSelectElement).value);
        });
      }
    }

    document.addEventListener('DOMContentLoaded', () => {
      window.addEventListener('crimesDataReady', setupYearFilter, { once: true });

      initializeStatCardFiltering({
        updateQuickInsights,
        updateTopRegions,
        updateLeafletMap
      });
    });
  </script>

  <FiltersTray showYearFilter={false} showCrimeTypeFilter={true}>
    <div>
      <label for="regionFilter" class="block text-sm font-medium text-slate-700 dark:text-[var(--ch-text-strong)] mb-2">Region</label>
      <select
        id="regionFilter"
        class="filter-select w-full pl-4 pr-10 py-2.5 border border-slate-300 dark:border-[var(--ch-border)] text-slate-500 dark:text-[var(--ch-text-muted)] rounded-lg hover:bg-slate-50 dark:hover:bg-[hsl(0_0%_12%)] transition font-medium text-xs bg-white/50 dark:bg-[var(--ch-surface-sub)]"
      >
        <option value="">All Regions</option>
        {dashboardRegions.map(region => (
          <option value={region}>{region}</option>
        ))}
      </select>
    </div>
    <div>
      <label for="areaFilter" class="block text-sm font-medium text-slate-700 dark:text-[var(--ch-text-strong)] mb-2">Area</label>
      <select
        id="areaFilter"
        class="filter-select w-full pl-4 pr-10 py-2.5 border border-slate-300 dark:border-[var(--ch-border)] text-slate-500 dark:text-[var(--ch-text-muted)] rounded-lg hover:bg-slate-50 dark:hover:bg-[hsl(0_0%_12%)] transition font-medium text-xs bg-white/50 dark:bg-[var(--ch-surface-sub)]"
      >
        <option value="">All Areas</option>
        {dashboardAreas.map(area => (
          <option value={area}>{area}</option>
        ))}
      </select>
    </div>
  </FiltersTray>

  <script is:inline define:vars={{ dashboardRegionToAreas, dashboardAllAreas: dashboardAreas, dashboardDefaultYear: String(currentYear), dashboardAvailableYears: availableYears, dashboardSSR: true }}>
    window.__dashboardRegionToAreas = dashboardRegionToAreas;
    window.__dashboardAllAreas = dashboardAllAreas;
    window.__dashboardDefaultYear = dashboardDefaultYear;
    window.__dashboardAvailableYears = dashboardAvailableYears;
    window.__dashboardSSR = dashboardSSR;
  </script>

  <script>
    import { initializeDashboardLocationFilter } from '../../scripts/dashboardLocationFilter';
    document.addEventListener('DOMContentLoaded', initializeDashboardLocationFilter);
  </script>

  <script>
    import { initializeTraySync } from '../../scripts/statCardFiltering';
    document.addEventListener('DOMContentLoaded', initializeTraySync);
  </script>

  <script>
    import { initializeStatsScroll } from '../../scripts/statsScroll';
    document.addEventListener('DOMContentLoaded', () => { initializeStatsScroll(); });
  </script>

</Layout>
