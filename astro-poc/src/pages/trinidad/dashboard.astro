            <div class="w-1/2 pr-4 border-r border-slate-200 dark:border-[var(--ch-border-card)] flex flex-col items-center justify-center gap-2">
              <LoadingShimmer height="12px" width="40%" rounded="full" />
              <LoadingShimmer height="22px" width="70%" rounded="md" />
              <LoadingShimmer height="12px" width="45%" rounded="full" />
            </div>
            <div class="flex-1 grid grid-cols-2 gap-x-3 gap-y-3 content-center">
              {[...Array(4)].map(() => (
                <div class="flex flex-col gap-1.5">
                  <LoadingShimmer height="10px" width="55%" rounded="full" />
                  <LoadingShimmer height="14px" width="80%" rounded="md" />
                </div>
              ))}
            </div>
          </div>
        </div>
        <div id="insightsCards" class="opacity-0 transition-opacity duration-300">
          <QuickInsightsCard insights={insights} />
