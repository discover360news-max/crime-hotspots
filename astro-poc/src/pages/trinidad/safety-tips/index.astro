---
export const prerender = true;

import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import TipCard from '../../../components/TipCard.astro';
import SocialProofStrip from '../../../components/SocialProofStrip.astro';
import { routes } from '../../../config/routes';
import DarkHero from '../../../components/DarkHero.astro';

const allTips = await getCollection('tips', ({ data }) => data.status === 'published');

const severityOrder: Record<string, number> = { high: 0, medium: 1, low: 2 };

// Group by category for pill counts (sorted by tip count desc)
const byCategory: Record<string, typeof allTips> = {};
allTips.forEach(tip => {
  const cat = tip.data.category;
  if (!byCategory[cat]) byCategory[cat] = [];
  byCategory[cat].push(tip);
});
const sortedCategories = Object.entries(byCategory).sort((a, b) => b[1].length - a[1].length);

// Flat list: high → medium → low, then newest first within each severity
const sortedTips = [...allTips].sort((a, b) => {
  const sev = severityOrder[a.data.severity] - severityOrder[b.data.severity];
  if (sev !== 0) return sev;
  return b.data.date_added.getTime() - a.data.date_added.getTime();
});

const totalCount = allTips.length;
const categoryCount = sortedCategories.length;
---

<Layout
  title="Crime Safety Tips Trinidad & Tobago — CrimeHotSpots.com"
  description="Actionable crime safety tips for Trinidad & Tobago residents. Curated from real incident patterns to help you protect yourself from robbery, carjacking, home invasion and more."
>

  <DarkHero
    title="Crime Safety Tips"
    subtitle={`${totalCount} tips across ${categoryCount} categories — practical, actionable advice curated from real incidents in Trinidad & Tobago.`}
    breadcrumbs={[
      { label: 'Home', href: routes.home },
      { label: 'Trinidad & Tobago', href: routes.trinidad.dashboard },
      { label: 'Safety Tips' },
    ]}
    ctas={[
      { text: 'Submit a Tip', href: routes.trinidad.safetyTipsSubmit, variant: 'primary' },
      { text: 'View Dashboard', href: routes.trinidad.dashboard },
    ]}
  >
    <Fragment slot="pulse">
      Tips are curated from <strong class="text-white">real crime incidents</strong> and reviewed before publishing. See a gap? <a href={routes.trinidad.safetyTipsSubmit} class="text-rose-400 hover:text-rose-300 transition underline">Submit a tip.</a>
    </Fragment>
    <SocialProofStrip slot="right" variant="hero" />
  </DarkHero>

  <main class="max-w-5xl mx-auto px-4 sm:px-6 py-6" data-pagefind-body>

    {allTips.length === 0 ? (
      <div class="bg-white/70 dark:bg-[hsl(0_0%_8%_/_0.7)] backdrop-blur-md rounded-lg shadow-sm p-8 border border-slate-100 dark:border-[var(--ch-border-card)] text-center">
        <p class="text-body text-slate-500 dark:text-[var(--ch-text-muted)]">No safety tips published yet — check back soon.</p>
        <a href={routes.trinidad.safetyTipsSubmit} class="mt-3 inline-block text-caption font-bold text-rose-600 dark:text-rose-400 hover:underline">
          Submit the first tip
        </a>
      </div>
    ) : (
      <>
        <!-- Category Pill Filters — horizontal scroll on mobile, wraps on desktop -->
        <div class="-mx-4 sm:mx-0 px-4 sm:px-0 overflow-x-auto pb-2 mb-5">
          <div class="flex gap-2 min-w-max sm:flex-wrap sm:min-w-0" id="categoryFilter">
            <button data-filter="all" class="tip-pill px-3 py-1.5 rounded-full text-xs font-bold bg-rose-600 text-white transition">
              All <span class="ml-1 opacity-75">{totalCount}</span>
            </button>
            {sortedCategories.map(([cat, tips]) => (
              <button data-filter={cat} class="tip-pill px-3 py-1.5 rounded-full text-xs font-bold bg-slate-100 dark:bg-[hsl(0_0%_14%)] text-slate-600 dark:text-[hsl(0_0%_65%)] hover:bg-rose-50 dark:hover:bg-rose-950/30 hover:text-rose-600 dark:hover:text-rose-400 transition">
                {cat} <span class="ml-1 opacity-70">{tips.length}</span>
              </button>
            ))}
          </div>
        </div>

        <!-- Tips Grid -->
        <div id="tipsGrid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
          {sortedTips.map(tip => (
            <div data-tip-category={tip.data.category}>
              <TipCard tip={tip} />
            </div>
          ))}
        </div>

        <!-- Hidden until filter yields no results -->
        <div id="noTipsResults" class="hidden text-center py-12">
          <p class="text-slate-500 dark:text-[var(--ch-text-muted)] text-sm">No tips in this category yet.</p>
        </div>
      </>
    )}

  </main>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const pills = document.querySelectorAll<HTMLButtonElement>('.tip-pill');
    const tipCards = document.querySelectorAll<HTMLElement>('[data-tip-category]');
    const noResults = document.getElementById('noTipsResults');

    const activeClass = 'tip-pill px-3 py-1.5 rounded-full text-xs font-bold bg-rose-600 text-white transition';
    const inactiveClass = 'tip-pill px-3 py-1.5 rounded-full text-xs font-bold bg-slate-100 dark:bg-[hsl(0_0%_14%)] text-slate-600 dark:text-[hsl(0_0%_65%)] hover:bg-rose-50 dark:hover:bg-rose-950/30 hover:text-rose-600 dark:hover:text-rose-400 transition';

    pills.forEach(pill => {
      pill.addEventListener('click', () => {
        const filter = pill.getAttribute('data-filter');

        pills.forEach(p => { p.className = inactiveClass; });
        pill.className = activeClass;

        let visibleCount = 0;
        tipCards.forEach(card => {
          const show = filter === 'all' || card.getAttribute('data-tip-category') === filter;
          card.style.display = show ? '' : 'none';
          if (show) visibleCount++;
        });

        if (noResults) noResults.classList.toggle('hidden', visibleCount > 0);
      });
    });
  });
</script>
