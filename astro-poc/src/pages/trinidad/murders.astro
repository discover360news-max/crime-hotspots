---
/**
 * Trinidad & Tobago Murders List
 * Chronological list of all recorded murders for the current year.
 * Target keywords: "list of murders in trinidad 2026", "trinidad murders 2026"
 */

import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';
import { getTrinidadCrimes, getAllCrimesFromD1 } from '../../lib/crimeData';
import { routes, buildRoute } from '../../config/routes';

Astro.response.headers.set('CDN-Cache-Control', 'max-age=82800');
Astro.response.headers.set('Cache-Control', 'public, max-age=3600, must-revalidate');

const db = Astro.locals.runtime?.env?.DB as D1Database | undefined;
const allCrimes = db ? await getAllCrimesFromD1(db) : await getTrinidadCrimes();

const currentYear = new Date().getFullYear();

const murders = allCrimes
  .filter(c =>
    c.year === currentYear && (
      c.primaryCrimeType === 'Murder' ||
      c.crimeType === 'Murder' ||
      c.relatedCrimeTypes?.split(',').map(t => t.trim()).includes('Murder')
    )
  )
  .sort((a, b) => b.dateObj.getTime() - a.dateObj.getTime());

const murderCount = murders.length;

// Group by date (YYYY-MM-DD)
const byDate = new Map<string, typeof murders>();
for (const crime of murders) {
  const key = crime.date;
  if (!byDate.has(key)) byDate.set(key, []);
  byDate.get(key)!.push(crime);
}
const sortedDates = Array.from(byDate.keys()).sort((a, b) => b.localeCompare(a));

const lastUpdated = new Date().toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });

const title = `Trinidad Murders ${currentYear} — Full List (${murderCount} Recorded) | Crime Hotspots`;
const description = `Full list of ${murderCount} murders recorded in Trinidad & Tobago in ${currentYear}, updated daily. Browse all incidents by date with links to individual reports.`;
const pageUrl = `https://crimehotspots.com/trinidad/murders/`;
---

<Layout title={title} description={description} includePagefind={false}>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-8">

    <div class="mb-6">
      <Breadcrumbs items={[
        { label: 'Home', href: routes.home },
        { label: 'Trinidad & Tobago', href: routes.trinidad.dashboard },
        { label: 'Murder Count', href: routes.trinidad.murderCount },
        { label: 'All Murders' },
      ]} />
    </div>

    <!-- Header -->
    <div class="mb-8">
      <h1 class="text-2xl sm:text-3xl font-bold text-slate-800 dark:text-[var(--ch-text-heading)]">
        Trinidad & Tobago Murders {currentYear}
      </h1>
      <p class="text-slate-500 dark:text-[var(--ch-text-muted)] mt-1 text-sm">
        {murderCount} murders recorded &mdash; Updated {lastUpdated}
      </p>
    </div>

    <!-- Back link -->
    <div class="mb-6">
      <a
        href={routes.trinidad.murderCount}
        class="text-sm text-rose-600 hover:text-rose-700 dark:text-rose-400 dark:hover:text-rose-300 font-medium"
      >
        &larr; Back to Murder Count
      </a>
    </div>

    <!-- Murder list grouped by date -->
    {sortedDates.length === 0 ? (
      <p class="text-slate-500 dark:text-[var(--ch-text-muted)] text-sm">No murders recorded yet for {currentYear}.</p>
    ) : (
      <div class="space-y-6">
        {sortedDates.map(dateKey => {
          const dayMurders = byDate.get(dateKey)!;
          const dateLabel = dayMurders[0].dateObj.toLocaleDateString('en-US', {
            weekday: 'long', month: 'long', day: 'numeric', year: 'numeric'
          });
          return (
            <div>
              <div class="flex items-center gap-3 mb-2">
                <h2 class="text-xs font-semibold text-slate-500 dark:text-[var(--ch-text-faint)] uppercase tracking-wide">
                  {dateLabel}
                </h2>
                {dayMurders.length > 1 && (
                  <span class="text-xs bg-rose-100 dark:bg-rose-950/40 text-rose-600 dark:text-rose-400 font-medium px-1.5 py-0.5 rounded">
                    {dayMurders.length}
                  </span>
                )}
              </div>
              <div class="space-y-1.5">
                {dayMurders.map(crime => (
                  <a
                    href={buildRoute.crime(crime.slug)}
                    class="flex items-start justify-between gap-3 bg-white dark:bg-[var(--ch-surface)] rounded-lg border border-slate-200 dark:border-[var(--ch-border-card)] px-3 py-2.5 hover:border-rose-300 dark:hover:border-rose-800 hover:shadow-sm transition group"
                  >
                    <div class="min-w-0 flex-1">
                      <p class="text-sm font-medium text-slate-700 dark:text-[var(--ch-text-strong)] group-hover:text-rose-600 dark:group-hover:text-rose-400 transition leading-snug line-clamp-2">
                        {crime.headline}
                      </p>
                      <p class="text-xs text-slate-400 dark:text-[hsl(0_0%_45%)] mt-0.5 truncate">
                        {crime.area}{crime.region && crime.area !== crime.region ? ` · ${crime.region}` : ''}
                      </p>
                    </div>
                    {crime.victimCount && crime.victimCount > 1 && (
                      <span class="shrink-0 text-xs bg-rose-100 dark:bg-rose-950/40 text-rose-600 dark:text-rose-400 font-semibold px-1.5 py-0.5 rounded mt-0.5">
                        {crime.victimCount} killed
                      </span>
                    )}
                  </a>
                ))}
              </div>
            </div>
          );
        })}
      </div>
    )}

    <!-- Footer note -->
    <p class="text-xs text-slate-400 dark:text-[var(--ch-text-faint)] mt-10">
      Murders sourced from Trinidad Guardian, Trinidad Express, and Newsday. Updated daily at build time.
      For full crime statistics see the <a href={routes.trinidad.statistics} class="underline hover:text-rose-500">statistics page</a>.
    </p>

    <!-- Newsletter -->
    <div class="mt-8">
      <NewsletterSignup variant="card" source="trinidad-murders-list-page" />
    </div>

  </div>

  <!-- Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": `Trinidad & Tobago Murders ${currentYear}`,
    "description": description,
    "url": pageUrl,
    "breadcrumb": {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://crimehotspots.com/" },
        { "@type": "ListItem", "position": 2, "name": "Trinidad & Tobago", "item": "https://crimehotspots.com/trinidad/dashboard/" },
        { "@type": "ListItem", "position": 3, "name": "Murder Count", "item": "https://crimehotspots.com/trinidad/murder-count/" },
        { "@type": "ListItem", "position": 4, "name": `All Murders ${currentYear}` }
      ]
    }
  })} />
</Layout>
