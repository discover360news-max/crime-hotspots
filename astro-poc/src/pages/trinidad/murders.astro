---
/**
 * Trinidad & Tobago Murders List
 * Chronological list of all recorded murders for the current year.
 * Target keywords: "list of murders in trinidad 2026", "trinidad murders 2026"
 */

import Layout from '../../layouts/Layout.astro';
import GradientStatCard from '../../components/GradientStatCard.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';
import SocialProofStrip from '../../components/SocialProofStrip.astro';
import { getCrimesWithFallback } from '../../lib/crimeData';
import { countCrimeType } from '../../lib/dashboardHelpers';
import { routes, buildRoute } from '../../config/routes';

Astro.response.headers.set('CDN-Cache-Control', 'max-age=82800');
Astro.response.headers.set('Cache-Control', 'public, max-age=3600, must-revalidate');

import { env } from 'cloudflare:workers';
import DarkHero from '../../components/DarkHero.astro';
const db = env.DB as D1Database | undefined;
const allCrimes = await getCrimesWithFallback(db);

const currentYear = new Date().getFullYear();

const murders = allCrimes
  .filter(c =>
    c.year === currentYear && (
      c.primaryCrimeType === 'Murder' ||
      c.crimeType === 'Murder' ||
      c.relatedCrimeTypes?.split(',').map(t => t.trim()).includes('Murder')
    )
  )
  .sort((a, b) => b.dateObj.getTime() - a.dateObj.getTime());

// Victim-aware total — matches murder-count page (applies victimCount multiplier)
const murderCount = countCrimeType(murders, 'Murder');
// Incident count — number of rows in the list (one per event)
const incidentCount = murders.length;

// Group by date (YYYY-MM-DD)
const byDate = new Map<string, typeof murders>();
for (const crime of murders) {
  const key = crime.date;
  if (!byDate.has(key)) byDate.set(key, []);
  byDate.get(key)!.push(crime);
}
const sortedDates = Array.from(byDate.keys()).sort((a, b) => b.localeCompare(a));

const INITIAL_GROUPS = 14;

const lastUpdated = new Date().toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });

// --- Vitals calculations ---
const today = new Date();
const startOfYear = new Date(currentYear, 0, 1);
const daysPassed = Math.max(1, Math.floor((today.getTime() - startOfYear.getTime()) / 86400000));
const annualizedRate = Math.round((murderCount / daysPassed) * 365);

// YoY — same period last year
type CrimeEntry = (typeof allCrimes)[number];
const isMurder = (c: CrimeEntry) =>
  c.primaryCrimeType === 'Murder' || c.crimeType === 'Murder' ||
  !!c.relatedCrimeTypes?.split(',').map(t => t.trim()).includes('Murder');

const samePeriodCutoff = new Date(currentYear - 1, today.getMonth(), today.getDate());
const prevYearSamePeriod = allCrimes.filter(c => c.year === currentYear - 1 && c.dateObj <= samePeriodCutoff && isMurder(c));
const prevYearSamePeriodCount = countCrimeType(prevYearSamePeriod, 'Murder');

const yoyRaw = prevYearSamePeriodCount > 0
  ? Math.round((murderCount - prevYearSamePeriodCount) / prevYearSamePeriodCount * 100)
  : 0;
const yoyDisplay = prevYearSamePeriodCount === 0 ? '—'
  : `${yoyRaw > 0 ? '+' : ''}${yoyRaw}%`;
const yoyPulseText = prevYearSamePeriodCount > 0
  ? `${currentYear} is tracking ${Math.abs(yoyRaw)}% ${yoyRaw > 0 ? 'above' : yoyRaw < 0 ? 'below' : 'on pace with'} the same point last year — ${prevYearSamePeriodCount} murders at this date in ${currentYear - 1}.`
  : `${murderCount} murders recorded across ${sortedDates.length} days so far in ${currentYear}.`;

const title = `Trinidad Murders ${currentYear} — Full List (${murderCount} Recorded) | Crime Hotspots`;
const description = `Full list of ${murderCount} murders recorded in Trinidad & Tobago in ${currentYear} across ${incidentCount} incidents, updated daily. Browse all incidents by date with links to individual reports.`;
const pageUrl = `https://crimehotspots.com/trinidad/murders/`;
---

<Layout title={title} description={description} includePagefind={false}>

  <DarkHero
    title={String(murderCount)}
    titleSize="lg"
    subtitle={`Murders in Trinidad & Tobago · ${currentYear}`}
    breadcrumbs={[
      { label: 'Home', href: routes.home },
      { label: 'Trinidad & Tobago', href: routes.trinidad.dashboard },
      { label: 'Murder Count', href: routes.trinidad.murderCount },
      { label: 'All Murders' },
    ]}
    ctas={[
      { text: '← Murder Count', href: routes.trinidad.murderCount, variant: 'primary' },
      { text: 'Statistics', href: routes.trinidad.statistics },
    ]}
    freshness={`Data as of ${lastUpdated}`}
  >
    <Fragment slot="pulse">{yoyPulseText}</Fragment>
    <SocialProofStrip slot="right" variant="hero" incidentCount={allCrimes.length} />
  </DarkHero>

  <!-- Content Zone -->
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-6">

    <!-- Vitals Row -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4 mb-6">
      <GradientStatCard variant="crimson" value={murderCount}    label="Murders YTD"       sublabel="year to date"             id="vitals-murders" />
      <GradientStatCard variant="amber"   value={annualizedRate} label="Projected (Annual)" sublabel="at current pace"          id="vitals-annual" />
      <GradientStatCard variant="violet"  value={yoyDisplay}     label="vs Last Year"       sublabel={`${currentYear - 1} same period`} id="vitals-yoy" />
      <GradientStatCard variant="slate"   value={sortedDates.length} label="Days with Murders" sublabel={`of ${daysPassed} days`} id="vitals-days" />
    </div>

    {murderCount !== incidentCount && (
      <p class="text-xs text-slate-400 dark:text-[var(--ch-text-faint)] mb-6 px-1">
        Across {incidentCount} separate incidents &mdash; some involved multiple victims
      </p>
    )}

    <!-- Section label -->
    <div class="flex items-center gap-2 px-1 mb-3">
      <h2 class="text-sm font-bold text-slate-500 dark:text-[var(--ch-text-muted)]">All Murders &mdash; {currentYear}</h2>
    </div>

    <!-- Murder list grouped by date -->
    {sortedDates.length === 0 ? (
      <p class="text-slate-500 dark:text-[var(--ch-text-muted)] text-sm">No murders recorded yet for {currentYear}.</p>
    ) : (
      <div id="murders-list" class="space-y-6">
        {sortedDates.map((dateKey, groupIndex) => {
          const dayMurders = byDate.get(dateKey)!;
          const dayCount = countCrimeType(dayMurders, 'Murder');
          const dateLabel = dayMurders[0].dateObj.toLocaleDateString('en-US', {
            weekday: 'long', month: 'long', day: 'numeric', year: 'numeric'
          });
          return (
            <div data-group-index={groupIndex} class={groupIndex >= INITIAL_GROUPS ? 'hidden' : ''}>
              <div class="flex items-center gap-3 mb-2">
                <h3 class="text-xs font-bold text-slate-500 dark:text-[var(--ch-text-faint)] uppercase tracking-wide">
                  {dateLabel}
                </h3>
                <span class="text-xs bg-rose-100 dark:bg-rose-950/40 text-rose-600 dark:text-rose-400 font-medium px-1.5 py-0.5 rounded">
                  {dayCount} {dayCount === 1 ? 'murder' : 'murders'}
                </span>
              </div>
              <div class="space-y-1.5">
                {dayMurders.map(crime => (
                  <a
                    href={buildRoute.crime(crime.slug)}
                    class="flex items-start justify-between gap-3 bg-white dark:bg-[var(--ch-surface)] rounded-lg border border-slate-200 dark:border-[var(--ch-border-card)] px-3 py-2.5 hover:border-rose-300 dark:hover:border-rose-800 hover:shadow-sm transition group"
                  >
                    <div class="min-w-0 flex-1">
                      <p class="text-sm font-medium text-slate-700 dark:text-[var(--ch-text-strong)] group-hover:text-rose-600 dark:group-hover:text-rose-400 transition leading-snug line-clamp-2">
                        {crime.headline}
                      </p>
                      <p class="text-xs text-slate-400 dark:text-[hsl(0_0%_45%)] mt-0.5 truncate">
                        {crime.area}{crime.region && crime.area !== crime.region ? ` · ${crime.region}` : ''}
                      </p>
                    </div>
                    {crime.victimCount && crime.victimCount > 1 && (
                      <span class="shrink-0 text-xs bg-rose-100 dark:bg-rose-950/40 text-rose-600 dark:text-rose-400 font-semibold px-1.5 py-0.5 rounded mt-0.5">
                        {crime.victimCount} killed
                      </span>
                    )}
                  </a>
                ))}
              </div>
            </div>
          );
        })}
      </div>
    )}

    <!-- Load more -->
    {sortedDates.length > INITIAL_GROUPS && (
      <div id="load-more-wrap" class="mt-8 text-center">
        <button
          id="load-more-btn"
          class="px-6 py-3 min-h-[44px] border border-slate-300 dark:border-[var(--ch-border)] text-slate-600 dark:text-[hsl(0_0%_70%)] rounded-lg hover:bg-slate-50 dark:hover:bg-[hsl(0_0%_12%)] active:bg-slate-100 dark:active:bg-[hsl(0_0%_15%)] transition font-medium text-sm"
          data-total={sortedDates.length}
          data-shown={INITIAL_GROUPS}
          data-batch={INITIAL_GROUPS}
        >
          Load more
        </button>
        <p id="load-more-status" class="text-xs text-slate-400 dark:text-[var(--ch-text-faint)] mt-2">
          Showing {INITIAL_GROUPS} of {sortedDates.length} days
        </p>
      </div>
    )}

    <!-- Footer note -->
    <p class="text-xs text-slate-400 dark:text-[var(--ch-text-faint)] mt-10">
      Murders sourced from Trinidad Guardian, Trinidad Express, and Newsday. Updated daily at build time.
      For full crime statistics see the <a href={routes.trinidad.statistics} class="underline hover:text-rose-500">statistics page</a>.
    </p>

    <!-- Newsletter -->
    <div class="mt-8">
      <NewsletterSignup variant="card" source="trinidad-murders-list-page" />
    </div>

  </div>

  <!-- SEO: WebPage + Dataset structured data — injected into <head> via slot="head". -->
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": `Trinidad & Tobago Murders List ${currentYear}`,
    "description": description,
    "url": pageUrl,
    "breadcrumb": {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://crimehotspots.com/" },
        { "@type": "ListItem", "position": 2, "name": "Trinidad & Tobago", "item": "https://crimehotspots.com/trinidad/dashboard/" },
        { "@type": "ListItem", "position": 3, "name": "Murder Count", "item": "https://crimehotspots.com/trinidad/murder-count/" },
        { "@type": "ListItem", "position": 4, "name": `All Murders ${currentYear}` }
      ]
    },
    "mainEntity": {
      "@type": "Dataset",
      "name": `Trinidad & Tobago Murder Incidents ${currentYear}`,
      "description": `Complete list of ${murderCount} murders recorded in Trinidad & Tobago in ${currentYear} across ${incidentCount} incidents, updated daily.`,
      "variableMeasured": [
        { "@type": "PropertyValue", "name": "Total Murders", "value": murderCount, "unitText": "murders" },
        { "@type": "PropertyValue", "name": "Total Incidents", "value": incidentCount, "unitText": "incidents" },
        { "@type": "PropertyValue", "name": "Days with Murders", "value": sortedDates.length, "unitText": "days" }
      ],
      "temporalCoverage": currentYear.toString(),
      "spatialCoverage": {
        "@type": "Place",
        "name": "Trinidad and Tobago",
        "geo": { "@type": "GeoCoordinates", "latitude": 10.6918, "longitude": -61.2225 }
      },
      "creator": { "@type": "Organization", "name": "Crime Hotspots", "url": "https://crimehotspots.com" },
      "license": "https://creativecommons.org/licenses/by/4.0/"
    }
  })} />
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.getElementById('load-more-btn') as HTMLButtonElement | null;
    const wrap = document.getElementById('load-more-wrap');
    const status = document.getElementById('load-more-status');
    if (!btn || !wrap) return;

    const total = parseInt(btn.dataset.total ?? '0', 10);
    const batch = parseInt(btn.dataset.batch ?? '14', 10);
    let shown = parseInt(btn.dataset.shown ?? '14', 10);

    btn.addEventListener('click', () => {
      const next = shown + batch;
      document.querySelectorAll<HTMLElement>('#murders-list [data-group-index]').forEach(el => {
        const idx = parseInt(el.dataset.groupIndex ?? '0', 10);
        if (idx >= shown && idx < next) el.classList.remove('hidden');
      });
      shown = next;

      if (shown >= total) {
        wrap.remove();
      } else if (status) {
        status.textContent = `Showing ${shown} of ${total} days`;
      }
    });
  });
</script>
