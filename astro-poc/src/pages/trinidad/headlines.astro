---
/**
 * Trinidad & Tobago Headlines Page
 * JNews layout: dark hero → type chips → two-column (list + sidebar) → filter tray
 */

import Layout from '../../layouts/Layout.astro';
import SiteNotificationBanner from '../../components/SiteNotificationBanner.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';
import { getCrimesWithFallback, generateNameSlug, type Crime } from '../../lib/crimeData';
import { getHotAreas } from '../../lib/trendingHelpers';
import { countCrimeType } from '../../lib/dashboardHelpers';
import { usesVictimCount, crimeHasVictims } from '../../config/crimeTypeConfig';
import { getTotalCrimeCount } from '../../lib/statisticsHelpers';
import { dataUpdateNotice } from '../../config/siteNotifications';
import { routes, buildRoute } from '../../config/routes';
import SocialProofStrip from '../../components/SocialProofStrip.astro';
import SocialFollow from '../../components/SocialFollow.astro';

Astro.response.headers.set('CDN-Cache-Control', 'max-age=82800');
Astro.response.headers.set('Cache-Control', 'public, max-age=3600, must-revalidate');

import { env } from 'cloudflare:workers';
import DarkHero from '../../components/DarkHero.astro';
const db = env.DB as D1Database | undefined;
const allCrimes = await getCrimesWithFallback(db);

const availableYears = [...new Set(allCrimes.map(c => c.year))].sort((a, b) => b - a);
const currentYear = availableYears[0] ?? new Date().getFullYear();

// Filter data
const areas = [...new Set(allCrimes.map(c => c.area).filter(Boolean))].sort();
const regions = [...new Set(allCrimes.map(c => c.region).filter(Boolean))].sort();
const crimeTypes = [...new Set(allCrimes.map(c => c.crimeType).filter(Boolean))].sort();
const regionToAreas: Record<string, string[]> = {};
allCrimes.forEach(c => {
  if (c.region && c.area) {
    if (!regionToAreas[c.region]) regionToAreas[c.region] = [];
    if (!regionToAreas[c.region].includes(c.area)) regionToAreas[c.region].push(c.area);
  }
});
Object.values(regionToAreas).forEach(arr => (arr as string[]).sort());

// Crime type chips: ordered by frequency, most common first
const typeFreq = allCrimes.reduce((acc: Record<string, number>, c) => {
  const t = c.primaryCrimeType || c.crimeType;
  if (t) acc[t] = (acc[t] || 0) + 1;
  return acc;
}, {});
const crimeTypesByFreq = Object.entries(typeFreq)
  .sort((a, b) => b[1] - a[1])
  .map(([type]) => type);

// Server-render first 30 crimes grouped by date
const initialCrimes = allCrimes.slice(0, 30);
const initialCrimeCount = getTotalCrimeCount(initialCrimes);
const totalCrimeCount = getTotalCrimeCount(allCrimes);
const crimesByDate = new Map<string, Crime[]>();
initialCrimes.forEach(crime => {
  const key = crime.date;
  if (!crimesByDate.has(key)) crimesByDate.set(key, []);
  crimesByDate.get(key)!.push(crime);
});
const sortedDates = Array.from(crimesByDate.keys()).sort((a, b) => new Date(b).getTime() - new Date(a).getTime());

function calculateVictimCount(crimes: Crime[]): number {
  return crimes.reduce((total, crime) => {
    const primaryType = crime.primaryCrimeType || crime.crimeType;
    if (!crimeHasVictims(primaryType)) return total;
    if (usesVictimCount(primaryType)) return total + (crime.victimCount && crime.victimCount > 0 ? crime.victimCount : 1);
    return total + 1;
  }, 0);
}

// Color helper — must stay in sync with headlinesPage.ts getTypeStyle()
function getTypeStyle(crimeType: string): { hex: string; pillClass: string } {
  const t = (crimeType || '').toLowerCase();
  if (['murder', 'attempted murder'].some(s => t.includes(s)))
    return { hex: '#e11d48', pillClass: 'text-rose-700 bg-rose-50 dark:bg-rose-950/40 dark:text-rose-400' };
  if (['shooting', 'kidnapping', 'sexual assault', 'home invasion', 'arson', 'carjacking', 'robbery', 'domestic violence', 'extortion'].some(s => t.includes(s)))
    return { hex: '#f59e0b', pillClass: 'text-amber-700 bg-amber-50 dark:bg-amber-950/40 dark:text-amber-400' };
  return { hex: '#94a3b8', pillClass: 'text-slate-600 bg-slate-100 dark:bg-[hsl(0_0%_15%)] dark:text-[hsl(0_0%_60%)]' };
}

// Freshness + pulse
const latestCrimeDate = allCrimes[0]?.dateObj ?? new Date();
const freshnessText = latestCrimeDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
const cutoff30d = new Date();
cutoff30d.setDate(cutoff30d.getDate() - 30);
const count30d = allCrimes.filter(c => (c.datePublished ?? c.dateObj) >= cutoff30d).length;

// Sidebar data
const ytdMurders = countCrimeType(allCrimes.filter(c => c.year === currentYear), 'Murder');
const hotAreas = getHotAreas(allCrimes, 3);

const title = `Trinidad & Tobago Crime Headlines — Latest Reports`;
const description = `Trinidad & Tobago crime headlines updated daily. Filter incidents (Murder, Robbery, etc.) by area and date, sourced from Guardian, Express, and Newsday.`;
---

<Layout title={title} description={description} includeTurnstile={true}>

  <DarkHero
    title="Latest Crime Headlines"
    subtitle="Trinidad & Tobago crime reports, updated daily."
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Trinidad & Tobago', href: routes.trinidad.dashboard },
      { label: 'Headlines' },
    ]}
    ctas={[
      { text: 'Dashboard', href: routes.trinidad.dashboard, variant: 'primary' },
      { text: 'Murder Count', href: routes.trinidad.murderCount },
    ]}
    freshness={`Data as of ${freshnessText}`}
  >
    <Fragment slot="pulse">
      <strong class="text-white">{count30d} {count30d === 1 ? 'crime' : 'crimes'}</strong> reported in the last 30 days.
    </Fragment>
    <Fragment slot="cta-extra">
      <button id="filtersBtn" class="px-4 py-2 rounded-lg border border-slate-500 text-slate-300 hover:border-slate-400 hover:text-white transition font-medium text-xs whitespace-nowrap">
        <span id="filtersBtnText">Filters ›</span>
      </button>
      <button id="clearFiltersInline" class="hidden text-xs text-rose-400 hover:text-rose-300 font-medium whitespace-nowrap transition">Clear</button>
    </Fragment>
    <SocialProofStrip slot="right" variant="hero" incidentCount={allCrimes.length} />
  </DarkHero>

  <!-- Type Filter Chips -->
  <div class="relative max-w-5xl mx-auto px-4 sm:px-6 pt-5 pb-1">
    <div id="chipScrollArea" class="flex items-center gap-2 overflow-x-auto pb-1">
      <button class="chip-filter chip-active shrink-0" data-type="">All</button>
      {crimeTypesByFreq.map(type => (
        <button class="chip-filter shrink-0" data-type={type}>{type}</button>
      ))}
    </div>
    <div id="chipFade" class="pointer-events-none absolute right-4 sm:right-6 top-0 bottom-1 w-12 bg-gradient-to-l from-slate-100 dark:from-[hsl(0_0%_8%)] to-transparent transition-opacity duration-200"></div>
  </div>

  <main class="max-w-5xl mx-auto px-4 sm:px-6 py-5" data-pagefind-ignore>
    <div class="lg:grid lg:grid-cols-[1fr_272px] lg:gap-8 lg:items-start">

      <!-- ── Main column ────────────────────────────────────────────────── -->
      <div>
        <SiteNotificationBanner notification={dataUpdateNotice} />

        <!-- Results row -->
        <div class="mb-4 text-xs flex flex-wrap items-center justify-between gap-y-1.5 text-slate-400 dark:text-[var(--ch-text-faint)]">
          <span>Showing <span id="resultsShowing">{initialCrimeCount}</span> of <a href={routes.trinidad.archive} class="border-b border-dotted border-slate-400 dark:border-[hsl(0_0%_40%)] hover:text-rose-600 hover:border-rose-600 transition"><span id="resultsTotal">{totalCrimeCount}</span></a> crimes</span>
          <a href={routes.trinidad.archive} class="border-b border-dotted border-slate-400 dark:border-[hsl(0_0%_40%)] hover:text-rose-600 hover:border-rose-600 transition">Archive</a>
        </div>

        <!-- Crime accordions (dark separator bands) -->
        <div id="crimeAccordions">
          {sortedDates.map((date, index) => {
            const crimes = crimesByDate.get(date)!;
            const isExpanded = index < 3;
            const incidentCount = crimes.length;
            const victimCount = calculateVictimCount(crimes);
            const c0 = crimes[0];
            const d = new Date(c0.year, c0.month - 1, c0.day);
            const weekday = d.toLocaleDateString('en-US', { weekday: 'long' });
            const shortDate = d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
            return (
              <div class="date-accordion mb-4" data-date={date}>
                <button
                  class="da-header w-full text-left bg-slate-800 dark:bg-[hsl(0_0%_8%)] rounded-xl px-4 py-3 flex items-center justify-between group hover:bg-slate-700 dark:hover:bg-[hsl(0_0%_11%)] transition-colors"
                  aria-expanded={isExpanded ? 'true' : 'false'}
                >
                  <div>
                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-0.5">{weekday}</p>
                    <h3 class="text-white font-black text-base leading-tight">{shortDate}</h3>
                    <p class="text-slate-400 text-xs mt-0.5">{incidentCount} {incidentCount === 1 ? 'crime' : 'crimes'} · {victimCount} {victimCount === 1 ? 'victim' : 'victims'}</p>
                  </div>
                  <svg class={`da-chevron w-4 h-4 text-slate-500 transition-transform${isExpanded ? ' rotate-90' : ''}`} fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                  </svg>
                </button>
                <div class={`da-content overflow-hidden${isExpanded ? ' is-open' : ''}`}>
                  <div class="space-y-1 pt-2">
                    {crimes.map(crime => {
                      const style = getTypeStyle(crime.primaryCrimeType ?? crime.crimeType);
                      const pill = crime.primaryCrimeType ?? crime.crimeType;
                      return (
                        <a
                          href={`/trinidad/crime/${crime.slug}/`}
                          class="crime-card group flex items-start gap-3 py-3 px-3 rounded-xl hover:bg-slate-50 dark:hover:bg-[hsl(0_0%_11%)] transition-colors block"
                        >
                          <div class="w-1 rounded-full shrink-0 mt-0.5" style={`background:${style.hex};min-height:36px;align-self:stretch`}></div>
                          <div class="flex-1 min-w-0">
                            <div class="flex items-center gap-2 mb-1 flex-wrap">
                              <span class={`${style.pillClass} inline-block px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wide`}>
                                {pill}
                              </span>
                              <span class="text-[10px] text-slate-400 dark:text-[hsl(0_0%_45%)] truncate">{crime.area}</span>
                            </div>
                            <p class="text-sm font-medium text-slate-700 dark:text-[hsl(0_0%_80%)] group-hover:text-slate-900 dark:group-hover:text-white leading-snug line-clamp-2 transition-colors">
                              {crime.headline}
                            </p>
                          </div>
                          <svg class="w-3.5 h-3.5 text-slate-300 dark:text-[hsl(0_0%_30%)] group-hover:text-rose-500 transition-colors shrink-0 mt-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                          </svg>
                        </a>
                      );
                    })}
                  </div>
                </div>
              </div>
            );
          })}
        </div>

        <!-- Load More -->
        <div class="mt-6 text-center">
          <button
            id="loadMore"
            class="px-4 py-1.5 border-2 border-slate-300 dark:border-[hsl(0_0%_30%)] text-slate-700 dark:text-[var(--ch-text-strong)] hover:border-rose-600 dark:hover:border-rose-500 hover:text-rose-600 dark:hover:text-rose-400 active:bg-rose-50 dark:active:bg-rose-950/40 rounded-lg transition font-medium text-xs"
          >
            Load More
          </button>
        </div>

        <!-- Social Follow -->
        <div class="mt-6">
          <SocialFollow variant="strip" />
        </div>
      </div>

      <!-- ── Sidebar ─────────────────────────────────────────────────────── -->
      <aside class="hidden lg:flex flex-col gap-5 sticky top-20 mt-0">

        <!-- Murder count card -->
        <a
          href={routes.trinidad.murderCount}
          class="group block rounded-xl overflow-hidden shadow-sm"
        >
          <div class="bg-gradient-to-br from-slate-900 to-slate-800 p-5 group-hover:from-slate-800 group-hover:to-slate-700 transition-colors">
            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1">Trinidad &amp; Tobago · {currentYear}</p>
            <div class="text-5xl font-black text-white leading-none mb-1">{ytdMurders}</div>
            <p class="text-slate-400 text-xs mb-4">murders year to date</p>
            <span class="inline-flex items-center gap-1 text-rose-400 text-xs font-medium group-hover:text-rose-300 transition-colors">
              View full count
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </span>
          </div>
        </a>

        <!-- Hot areas this week -->
        {hotAreas.length > 0 && (
          <div class="rounded-xl border border-slate-100 dark:border-[var(--ch-border-subtle)] bg-white/70 dark:bg-[var(--ch-surface)] p-4">
            <div class="flex items-center justify-between mb-3">
              <h2 class="text-xs font-bold text-slate-500 dark:text-[var(--ch-text-muted)] uppercase tracking-widest">Hot Areas This Week</h2>
              <span class="relative flex h-1.5 w-1.5">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-rose-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-rose-500"></span>
              </span>
            </div>
            <div class="space-y-1">
              {hotAreas.map((area, i) => (
                <a
                  href={buildRoute.area(generateNameSlug(area.area))}
                  class="flex items-center justify-between py-1.5 px-2 rounded-lg hover:bg-slate-50 dark:hover:bg-[hsl(0_0%_12%)] group transition-colors"
                >
                  <div class="flex items-center gap-2 min-w-0">
                    <span class="text-xs font-bold text-slate-300 dark:text-[hsl(0_0%_35%)] w-4 shrink-0">{i + 1}</span>
                    <span class="text-sm text-slate-700 dark:text-[var(--ch-text)] group-hover:text-rose-600 dark:group-hover:text-rose-400 transition-colors truncate">{area.area}</span>
                  </div>
                  <span class="text-xs font-bold text-rose-600 dark:text-rose-400 shrink-0 ml-2">{area.count}</span>
                </a>
              ))}
            </div>
            <a href={routes.trinidad.areas} class="text-xs text-rose-600 dark:text-rose-400 hover:text-rose-700 dark:hover:text-rose-300 font-medium mt-3 block transition-colors">
              Browse all areas →
            </a>
          </div>
        )}

        <!-- Social Follow -->
        <SocialFollow variant="sidebar" />

        <!-- Newsletter -->
        <NewsletterSignup variant="card" source="headlines-sidebar" />

      </aside>

    </div>
  </main>

  <!-- Filter Tray -->
  <div id="filtersTray" class="fixed inset-0 z-50 pointer-events-none overflow-hidden">
    <div id="filtersBackdrop" class="absolute inset-0 bg-black/50 backdrop-blur-sm opacity-0 transition-opacity duration-300 pointer-events-none"></div>
    <div id="filtersTrayContent" class="absolute right-0 top-0 h-full max-w-[min(20rem,calc(100vw-2rem))] w-full bg-white/85 dark:bg-[var(--ch-surface)]/90 backdrop-blur-lg rounded-l-2xl shadow-2xl transform translate-x-full transition-transform duration-300 pointer-events-auto overflow-y-auto">
      <div class="p-5">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-heading font-bold text-slate-700 dark:text-[var(--ch-text)]">Filters</h2>
          <button id="closeFiltersBtn" class="text-slate-400 dark:text-[var(--ch-text-faint)] hover:text-slate-600 dark:hover:text-[hsl(0_0%_75%)] transition">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>
        <div class="space-y-4">
          <div>
            <label for="dateFrom" class="block text-sm font-medium text-slate-700 dark:text-[var(--ch-text-strong)] mb-2">From Date</label>
            <input type="date" id="dateFrom" class="filter-date-input w-full px-4 py-2.5 border border-slate-300 dark:border-[var(--ch-border)] text-slate-500 dark:text-[var(--ch-text-muted)] rounded-lg hover:bg-slate-50 dark:hover:bg-[hsl(0_0%_12%)] transition font-medium text-xs bg-white/50 dark:bg-[var(--ch-surface-sub)]" />
          </div>
          <div>
            <label for="dateTo" class="block text-sm font-medium text-slate-700 dark:text-[var(--ch-text-strong)] mb-2">To Date</label>
            <input type="date" id="dateTo" class="filter-date-input w-full px-4 py-2.5 border border-slate-300 dark:border-[var(--ch-border)] text-slate-500 dark:text-[var(--ch-text-muted)] rounded-lg hover:bg-slate-50 dark:hover:bg-[hsl(0_0%_12%)] transition font-medium text-xs bg-white/50 dark:bg-[var(--ch-surface-sub)]" />
          </div>
          <div>
            <label for="crimeTypeFilter" class="block text-sm font-medium text-slate-700 dark:text-[var(--ch-text-strong)] mb-2">Crime Type</label>
            <select id="crimeTypeFilter" class="filter-select w-full pl-4 pr-10 py-2.5 border border-slate-300 dark:border-[var(--ch-border)] text-slate-500 dark:text-[var(--ch-text-muted)] rounded-lg hover:bg-slate-50 dark:hover:bg-[hsl(0_0%_12%)] transition font-medium text-xs bg-white/50 dark:bg-[var(--ch-surface-sub)]">
              <option value="">All Types</option>
              {crimeTypes.map(type => <option value={type}>{type}</option>)}
            </select>
          </div>
          <div>
            <label for="regionFilter" class="block text-sm font-medium text-slate-700 dark:text-[var(--ch-text-strong)] mb-2">Region</label>
            <select id="regionFilter" class="filter-select w-full pl-4 pr-10 py-2.5 border border-slate-300 dark:border-[var(--ch-border)] text-slate-500 dark:text-[var(--ch-text-muted)] rounded-lg hover:bg-slate-50 dark:hover:bg-[hsl(0_0%_12%)] transition font-medium text-xs bg-white/50 dark:bg-[var(--ch-surface-sub)]">
              <option value="">All Regions</option>
              {regions.map(region => <option value={region}>{region}</option>)}
            </select>
          </div>
          <div>
            <label for="areaFilter" class="block text-sm font-medium text-slate-700 dark:text-[var(--ch-text-strong)] mb-2">Area</label>
            <select id="areaFilter" class="filter-select w-full pl-4 pr-10 py-2.5 border border-slate-300 dark:border-[var(--ch-border)] text-slate-500 dark:text-[var(--ch-text-muted)] rounded-lg hover:bg-slate-50 dark:hover:bg-[hsl(0_0%_12%)] transition font-medium text-xs bg-white/50 dark:bg-[var(--ch-surface-sub)]">
              <option value="">All Areas</option>
              {areas.map(area => <option value={area}>{area}</option>)}
            </select>
          </div>
          <div class="flex gap-2 pt-2">
            <button id="clearFilters" class="flex-1 px-4 py-2 text-rose-600 hover:text-rose-700 transition font-medium text-xs">Clear Filters</button>
            <button id="applyFilters" class="flex-1 px-4 py-2 border-2 border-slate-300 dark:border-[var(--ch-border)] text-slate-500 dark:text-[var(--ch-text-muted)] rounded-lg transition-all duration-200 font-medium text-xs">Apply</button>
          </div>
        </div>
      </div>
    </div>
  </div>

</Layout>

<style>
  /* Accordion height transition */
  :global(.da-content) {
    height: 0;
    transition: height 300ms ease, margin-top 200ms ease;
  }
  :global(.da-content.is-open) {
    height: auto;
    margin-top: 0;
  }

  /* Type filter chips */
  .chip-filter {
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    border: 1.5px solid #e2e8f0;
    background: transparent;
    color: #64748b;
    font-size: 0.7rem;
    font-weight: 700;
    cursor: pointer;
    transition: border-color 150ms, color 150ms, background 150ms;
    white-space: nowrap;
  }
  .chip-filter:hover {
    border-color: #fda4af;
    color: #e11d48;
  }
  .chip-filter.chip-active {
    background: #e11d48;
    border-color: #e11d48;
    color: #fff;
  }
  :global(.dark) .chip-filter {
    border-color: hsl(0 0% 20%);
    color: hsl(0 0% 55%);
  }
  :global(.dark) .chip-filter:hover {
    border-color: hsl(346 77% 49% / 0.5);
    color: #fb7185;
  }
  :global(.dark) .chip-filter.chip-active {
    background: #e11d48;
    border-color: #e11d48;
    color: #fff;
  }

  /* Hide chip scroll bar */
  #chipScrollArea::-webkit-scrollbar { display: none; }
  #chipScrollArea { -ms-overflow-style: none; scrollbar-width: none; }

  /* Date input styling */
  .filter-date-input::-webkit-calendar-picker-indicator {
    padding: 2px; margin-right: 2px; cursor: pointer; opacity: 0.5;
  }
  .filter-date-input::-webkit-calendar-picker-indicator:hover { opacity: 0.8; }
</style>

<!-- Data bridge -->
<script define:vars={{ allCrimes, regionToAreas, allAreas: areas }}>
  window.__hlData = { allCrimes, regionToAreas, allAreas };
</script>

<!-- Main filter/render/chip logic -->
<script src="../../scripts/headlinesPage.ts"></script>

<!-- Chip fade scroll indicator -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const chipScroll = document.getElementById('chipScrollArea');
    const chipFade = document.getElementById('chipFade');
    if (chipScroll && chipFade) {
      chipScroll.addEventListener('scroll', () => {
        const atEnd = chipScroll.scrollLeft + chipScroll.clientWidth >= chipScroll.scrollWidth - 4;
        chipFade.style.opacity = atEnd ? '0' : '1';
      }, { passive: true });
    }
  });
</script>

<!-- Accordion toggle: event delegation -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const container = document.getElementById('crimeAccordions');
    if (!container) return;
    container.addEventListener('click', (e) => {
      const header = (e.target as Element).closest('.da-header');
      if (!header) return;
      const accordion = header.closest('.date-accordion');
      const content = accordion?.querySelector('.da-content');
      const chevron = header.querySelector('.da-chevron');
      const expanded = header.getAttribute('aria-expanded') === 'true';
      if (content && chevron) {
        header.setAttribute('aria-expanded', expanded ? 'false' : 'true');
        content.classList.toggle('is-open', !expanded);
        chevron.classList.toggle('rotate-90', !expanded);
      }
    });
  });
</script>
