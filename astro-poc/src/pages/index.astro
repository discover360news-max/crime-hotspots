---
/**
 * Homepage — Caribbean Crime Statistics Portal
 * SSR + CDN cache (same pattern as crime data pages)
 * Dark JNews hero → T&T featured section → coming soon islands → QuickAnswers
 */

import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import QuickAnswers from '../components/QuickAnswers.astro';
import HeroBg from '../components/HeroBg.astro';
import SocialProofStrip from '../components/SocialProofStrip.astro';
import { routes, buildRoute } from '../config/routes';
import { getAllCrimesFromD1, getTrinidadCrimes } from '../lib/crimeData';
import { getHotAreas } from '../lib/trendingHelpers';
import { countCrimeType } from '../lib/dashboardHelpers';
import { usesVictimCount, crimeHasVictims } from '../config/crimeTypeConfig';

import trinidadImg from '../assets/images/trinidad.jpg';
import trinidadDarkImg from '../assets/images/trinidad-card-trsp-bg.png';
import jamaicaImg from '../assets/images/jamaica-card-trsp-bg.png';
import guyanaImg from '../assets/images/guyana.jpg';
import guyanaDarkImg from '../assets/images/guyana-card-trsp-bg.png';
import barbadosImg from '../assets/images/barbados.jpg';
import barbadosDarkImg from '../assets/images/barbados-card-trsp-bg.png';

// CDN cache: 1h browser, ~23h edge (matches daily rebuild cycle)
Astro.response.headers.set('Cache-Control', 'public, max-age=3600, s-maxage=82800');

import { env } from 'cloudflare:workers';
const db = env.DB as D1Database | undefined;
const allCrimes = db ? await getAllCrimesFromD1(db) : await getTrinidadCrimes();

// This week vs last week
const now = new Date();
const weekAgo = new Date(now.getTime() - 7 * 24 * 60 * 60 * 1000);
const twoWeeksAgo = new Date(now.getTime() - 14 * 24 * 60 * 60 * 1000);

const thisWeekCrimes = allCrimes.filter(c => (c.datePublished ?? c.dateObj) >= weekAgo);
const lastWeekCrimes = allCrimes.filter(c => { const d = c.datePublished ?? c.dateObj; return d >= twoWeeksAgo && d < weekAgo; });
const murdersThisWeek = countCrimeType(thisWeekCrimes, 'Murder');
const weekChange = lastWeekCrimes.length > 0
  ? Math.round(((thisWeekCrimes.length - lastWeekCrimes.length) / lastWeekCrimes.length) * 100)
  : 0;
const hotAreas = getHotAreas(allCrimes, 3);
const topArea = hotAreas[0];

// Per-area murder + victim counts for hotspots widget (this week)
const murdersByArea = new Map<string, number>();
const victimsByArea = new Map<string, number>();
thisWeekCrimes.forEach(c => {
  const area = c.area || 'Unknown';
  const primaryType = c.primaryCrimeType || c.crimeType;
  const victims = !crimeHasVictims(primaryType) ? 0
    : usesVictimCount(primaryType) && c.victimCount && c.victimCount > 0 ? c.victimCount
    : 1;
  victimsByArea.set(area, (victimsByArea.get(area) || 0) + victims);
  if (c.primaryCrimeType === 'Murder') {
    murdersByArea.set(area, (murdersByArea.get(area) || 0) + victims);
  }
});

// Latest 3 crimes for headline cards
const latestCrimes = allCrimes.slice(0, 3);

// Hero pulse
const heroPulse = thisWeekCrimes.length > 0
  ? `${thisWeekCrimes.length} crime${thisWeekCrimes.length !== 1 ? 's' : ''} reported in Trinidad this week · ${murdersThisWeek} murder${murdersThisWeek !== 1 ? 's' : ''}`
  : 'No incidents reported in Trinidad this week.';

const title = "Caribbean Crime Statistics — Live Data for Trinidad & Jamaica";
const description = "Real-time crime statistics, murder counts, and safety data for Trinidad & Tobago, Jamaica, and the wider Caribbean. Track incidents by area with daily-updated, verified data.";
---

<Layout title={title} description={description} includeLeaflet={false} includePagefind={false}>

  <!-- ═══════════════════════════════════════════════════════════
       DARK HERO
       ═══════════════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden w-full bg-gradient-to-br from-slate-900 to-slate-800">
    <HeroBg />
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-10 sm:py-14">
      <div class="grid lg:grid-cols-[1fr_auto] gap-8 items-center">

        <!-- Left: headline + pulse + CTAs -->
        <div>
          <h1 class="text-4xl sm:text-5xl font-black text-white leading-tight mb-3">
            Live Crime Statistics<br class="hidden sm:block" /> for the Caribbean
          </h1>
          <p class="text-slate-400 text-sm sm:text-base mb-6 max-w-xl">
            Real-time murder counts, incident tracking, and safety data for Trinidad &amp; Tobago, Jamaica, and beyond.
          </p>

          <!-- Live pulse -->
          <div class="flex items-start gap-2.5 mb-6 bg-white/5 rounded-lg px-4 py-3 border border-white/10 max-w-xl">
            <span class="relative flex h-2 w-2 mt-1 shrink-0">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-rose-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-rose-500"></span>
            </span>
            <p class="text-slate-300 text-sm leading-relaxed">{heroPulse}</p>
          </div>

          <!-- CTAs -->
          <div class="flex gap-3 flex-wrap">
            <a href={routes.trinidad.dashboard} class="px-4 py-2 rounded-lg bg-rose-600 text-white hover:bg-rose-500 transition font-medium text-xs">
              Explore Dashboard
            </a>
            <a href={routes.trinidad.murderCount} class="px-4 py-2 rounded-lg border border-slate-500 text-slate-300 hover:border-slate-400 hover:text-white transition font-medium text-xs">
              Murder Count
            </a>
          </div>
        </div>

        <!-- Right: social proof 2×2 -->
        <div class="w-full lg:w-52">
          <SocialProofStrip variant="hero" incidentCount={allCrimes.length} />
        </div>

      </div>
    </div>
  </section>

  <main>

    <!-- ═══════════════════════════════════════════════════════════
         T&T SECTION
         ═══════════════════════════════════════════════════════════ -->
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-8">

      <!-- Section label -->
      <div class="flex items-center gap-2 mb-5">
        <span class="relative flex h-2 w-2 shrink-0">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-rose-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-rose-500"></span>
        </span>
        <h2 class="text-sm font-bold text-slate-500 dark:text-[var(--ch-text-muted)] uppercase tracking-widest">
          Trinidad &amp; Tobago
        </h2>
        <span class="inline-flex items-center px-2 py-0.5 rounded-full bg-rose-100 dark:bg-rose-950/50 text-rose-700 dark:text-rose-400 text-[10px] font-bold tracking-wide uppercase">
          Live
        </span>
      </div>

      <!-- Two-column: island card (left) + latest headlines (right) -->
      <div class="grid grid-cols-[1fr_1.6fr] gap-3 sm:gap-5 mb-8">

        <!-- LEFT: Island identity card -->
        <a
          href={routes.trinidad.dashboard}
          class="group relative block rounded-2xl shadow-sm overflow-hidden dark:ring-1 dark:ring-white/15 bg-white/70 dark:bg-[var(--ch-surface)] hover:shadow-lg transition-shadow duration-300"
        >
          <!-- Island image -->
          <div class="w-full aspect-square overflow-hidden bg-white/70 dark:bg-transparent">
            <Image
              src={trinidadImg}
              alt="Trinidad & Tobago island map"
              class="w-full h-full object-cover block dark:hidden transition-transform duration-300 ease-out group-hover:scale-[1.04] group-hover:-translate-y-1"
              loading="eager"
              width={360}
              height={360}
              format="webp"
              quality={80}
            />
            <Image
              src={trinidadDarkImg}
              alt="Trinidad & Tobago island map"
              class="w-full h-full object-cover hidden dark:block transition-transform duration-300 ease-out group-hover:scale-[1.04] group-hover:-translate-y-1"
              loading="eager"
              width={360}
              height={360}
              format="webp"
              quality={80}
            />
          </div>

          <!-- Inline stats -->
          <div class="px-4 pb-4 pt-3 border-t border-slate-200 dark:border-[var(--ch-border)] bg-slate-50 dark:bg-[var(--ch-surface-sub)]">
            <p class="text-[10px] font-bold uppercase tracking-wider text-slate-500 dark:text-[var(--ch-text-muted)] mb-2">This Week</p>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-2 sm:gap-3 mb-3">
              <div>
                <div class="text-lg sm:text-xl font-bold text-slate-700 dark:text-[var(--ch-text-heading)]">{thisWeekCrimes.length}</div>
                <div class="text-xs text-slate-500 dark:text-[var(--ch-text-muted)]">
                  crimes
                  {weekChange !== 0 && (
                    <span class={weekChange > 0 ? 'text-rose-600' : 'text-emerald-600'}>
                      {' '}{weekChange > 0 ? '+' : ''}{weekChange}%
                    </span>
                  )}
                </div>
              </div>
              {topArea && (
                <div class="hidden sm:block">
                  <div class="text-sm font-bold text-slate-700 dark:text-[var(--ch-text-heading)] truncate">{topArea.area}</div>
                  <div class="text-xs text-slate-500 dark:text-[var(--ch-text-muted)]">top area</div>
                </div>
              )}
              <div>
                <div class="text-lg sm:text-xl font-bold text-rose-600">{murdersThisWeek}</div>
                <div class="text-xs text-slate-500 dark:text-[var(--ch-text-muted)]">murders</div>
              </div>
            </div>
            <div class="inline-flex items-center gap-1 text-sm font-bold text-rose-600 group-hover:text-rose-700 dark:group-hover:text-rose-400 transition-colors">
              Explore
              <svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          </div>
        </a>

        <!-- RIGHT: Latest headlines + This Week's Hotspots -->
        <div class="flex flex-col">

          <!-- Headlines -->
          <div>
            <div class="flex items-center justify-between px-1 mb-3">
              <h3 class="text-sm font-bold text-slate-500 dark:text-[var(--ch-text-muted)]">Latest Headlines</h3>
              <a href={routes.trinidad.headlines} class="text-xs text-rose-600 dark:text-rose-400 hover:text-rose-700 dark:hover:text-rose-300 font-medium transition">
                View all →
              </a>
            </div>
            <div class="flex flex-col gap-3">
              {latestCrimes.map((crime, i) => {
                const pill = crime.primaryCrimeType ?? crime.crimeType;
                const date = new Intl.DateTimeFormat('en-TT', { month: 'short', day: 'numeric' }).format(crime.dateObj);
                return (
                  <a
                    href={buildRoute.crime(crime.slug)}
                    class={`group block bg-white/70 dark:bg-[var(--ch-surface)] rounded-xl border border-slate-100 dark:border-[var(--ch-border-subtle)] p-4 hover:shadow-md hover:border-slate-200 dark:hover:border-[var(--ch-border-card)] transition-all${i >= 2 ? ' hidden sm:block' : ''}`}
                  >
                    <div class="flex items-center gap-2 mb-1.5">
                      <span class="inline-block px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wide text-rose-700 bg-rose-50 dark:bg-rose-950/40 dark:text-rose-400">
                        {pill}
                      </span>
                      <span class="text-[10px] text-slate-400 dark:text-[var(--ch-text-faint)]">{crime.area}</span>
                      <span class="text-[10px] text-slate-300 dark:text-[hsl(0_0%_30%)] ml-auto shrink-0">{date}</span>
                    </div>
                    <p class="text-sm font-medium text-slate-700 dark:text-[var(--ch-text)] line-clamp-1 sm:line-clamp-2 leading-snug group-hover:text-slate-900 dark:group-hover:text-white transition-colors">
                      {crime.headline}
                    </p>
                  </a>
                );
              })}
            </div>
          </div>

          <!-- This Week's Hotspots — anchored to bottom -->
          {hotAreas.length > 0 && (
            <div class="mt-auto pt-3">
              <div class="flex items-center justify-between px-1 mb-3">
                <h3 class="text-sm font-bold text-slate-500 dark:text-[var(--ch-text-muted)]">This Week's Hotspots</h3>
                <a href={routes.trinidad.areas} class="text-xs text-rose-600 dark:text-rose-400 hover:text-rose-700 dark:hover:text-rose-300 font-medium transition">
                  All areas →
                </a>
              </div>
              <div class="bg-white/70 dark:bg-[var(--ch-surface)] rounded-xl border border-slate-100 dark:border-[var(--ch-border-subtle)] overflow-hidden">
                <div>
                  {hotAreas.map((area, i) => {
                    const murders = murdersByArea.get(area.area) || 0;
                    const victims = victimsByArea.get(area.area) || 0;
                    const crimesLabel = `${area.count} crime${area.count !== 1 ? 's' : ''}`;
                    const murdersLabel = murders > 0 ? ` · ${murders} murder${murders !== 1 ? 's' : ''}` : '';
                    const victimsLabel = victims > 0 ? ` · ${victims} victim${victims !== 1 ? 's' : ''}` : '';
                    return (
                      <a
                        href={buildRoute.area(area.areaSlug)}
                        class={`group flex items-center gap-3 px-4 py-2.5 hover:bg-slate-50 dark:hover:bg-[var(--ch-surface-sub)] transition-colors border-b border-slate-50 dark:border-[var(--ch-border-subtle)] last:border-0${i >= 1 ? ' hidden sm:flex' : ''}`}
                      >
                        <span class="text-[10px] font-bold tabular-nums text-slate-300 dark:text-[hsl(0_0%_30%)] w-3 shrink-0">{area.rank}</span>
                        <div class="flex flex-col flex-1 min-w-0">
                          <span class="text-sm font-medium text-slate-700 dark:text-[var(--ch-text)] truncate group-hover:text-slate-900 dark:group-hover:text-white transition-colors">
                            {area.area}
                          </span>
                          <span class="text-[10px] text-slate-400 dark:text-[var(--ch-text-faint)]">
                            {crimesLabel}{murdersLabel}{victimsLabel}
                          </span>
                        </div>
                        <svg class="w-3.5 h-3.5 text-slate-300 dark:text-[hsl(0_0%_30%)] shrink-0 group-hover:text-rose-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                        </svg>
                      </a>
                    );
                  })}
                </div>
              </div>
            </div>
          )}

        </div>

      </div>

      <!-- EXPLORE TILES -->
      <div>
        <h3 class="text-sm font-bold text-slate-500 dark:text-[var(--ch-text-muted)] px-1 mb-3">Where do you want to start?</h3>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 text-left">

          <a href={routes.trinidad.areas} class="group bg-white/70 dark:bg-[var(--ch-surface)] backdrop-blur-md rounded-2xl shadow-sm border border-slate-100 dark:border-[hsl(0_0%_12%)] p-5 flex flex-col gap-2 hover:shadow-md transition-shadow">
            <p class="text-body font-bold text-slate-800 dark:text-[var(--ch-text)] leading-snug">See your area's risk level</p>
            <p class="text-xs text-slate-500 dark:text-[hsl(0_0%_60%)] leading-relaxed flex-1">Check how your area ranks across Trinidad by crime count and risk score.</p>
            <span class="inline-flex items-center gap-1 text-xs text-rose-600 dark:text-rose-400 font-medium group-hover:text-rose-700 dark:group-hover:text-rose-300 transition-colors">
              Browse areas
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </span>
          </a>

          <a href={routes.trinidad.murderCount} class="group bg-white/70 dark:bg-[var(--ch-surface)] backdrop-blur-md rounded-2xl shadow-sm border border-slate-100 dark:border-[hsl(0_0%_12%)] p-5 flex flex-col gap-2 hover:shadow-md transition-shadow">
            <p class="text-body font-bold text-slate-800 dark:text-[var(--ch-text)] leading-snug">Track the murder count</p>
            <p class="text-xs text-slate-500 dark:text-[hsl(0_0%_60%)] leading-relaxed flex-1">Follow the 2026 running total with a week-by-week breakdown and trend line.</p>
            <span class="inline-flex items-center gap-1 text-xs text-rose-600 dark:text-rose-400 font-medium group-hover:text-rose-700 dark:group-hover:text-rose-300 transition-colors">
              View count
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </span>
          </a>

          <a href={routes.blog} class="group bg-white/70 dark:bg-[var(--ch-surface)] backdrop-blur-md rounded-2xl shadow-sm border border-slate-100 dark:border-[hsl(0_0%_12%)] p-5 flex flex-col gap-2 hover:shadow-md transition-shadow">
            <p class="text-body font-bold text-slate-800 dark:text-[var(--ch-text)] leading-snug">Read this week's report</p>
            <p class="text-xs text-slate-500 dark:text-[hsl(0_0%_60%)] leading-relaxed flex-1">Weekly crime analysis covering incidents, trends, and what's changed across the island.</p>
            <span class="inline-flex items-center gap-1 text-xs text-rose-600 dark:text-rose-400 font-medium group-hover:text-rose-700 dark:group-hover:text-rose-300 transition-colors">
              Read report
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </span>
          </a>

        </div>
      </div>

    </div>

    <!-- ═══════════════════════════════════════════════════════════
         SOCIAL PROOF
         ═══════════════════════════════════════════════════════════ -->
    <div class="max-w-5xl mx-auto px-4 sm:px-6 pb-10">
      <SocialProofStrip variant="strip" incidentCount={allCrimes.length} />
    </div>

    <!-- ═══════════════════════════════════════════════════════════
         DARK SEPARATOR
         ═══════════════════════════════════════════════════════════ -->
    <div class="w-full bg-slate-900 dark:bg-[hsl(0_0%_5%)] py-4">
      <div class="max-w-5xl mx-auto px-4 sm:px-6">
        <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest">Caribbean Coverage</p>
        <h2 class="text-white font-black text-lg mt-0.5">More Countries</h2>
      </div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════
         COMING SOON ISLANDS
         ═══════════════════════════════════════════════════════════ -->
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-8">
      <div class="grid grid-cols-3 gap-3 sm:gap-5" role="list" aria-label="Coming soon countries">

        <!-- Jamaica: countdown -->
        <div
          class="rounded-2xl shadow-sm overflow-hidden dark:ring-1 dark:ring-white/15 bg-white/70 dark:bg-[var(--ch-surface)] opacity-90 cursor-not-allowed"
          role="listitem"
        >
          <div aria-disabled="true" role="button" tabindex="-1">
            <div class="flex items-center justify-between px-3 pt-2.5 pb-2">
              <h3 class="text-caption font-bold text-slate-600 dark:text-[hsl(0_0%_70%)]">🇯🇲 Jamaica</h3>
              <span class="inline-flex items-center px-2 py-0.5 rounded-full bg-amber-100 dark:bg-amber-950/40 text-amber-700 dark:text-amber-400 text-[10px] font-bold tracking-wide uppercase">
                Jul 2026
              </span>
            </div>
            <div class="w-full aspect-square overflow-hidden bg-white dark:bg-transparent">
              <Image
                src={jamaicaImg}
                alt="Jamaica map"
                class="w-full h-full object-cover"
                loading="lazy"
                width={220}
                height={220}
                format="webp"
                quality={70}
              />
            </div>
            <div id="jm-countdown" class="py-3 px-3 text-center">
              <div class="flex items-end justify-center gap-1.5 sm:gap-2">
                <div class="flex flex-col items-center min-w-[22px] sm:min-w-[28px]">
                  <span id="jm-days" class="text-base sm:text-xl font-bold tabular-nums text-slate-700 dark:text-[var(--ch-text-strong)] leading-none">--</span>
                  <span class="text-[8px] sm:text-[9px] text-slate-400 dark:text-[hsl(0_0%_45%)] uppercase tracking-wide mt-0.5">days</span>
                </div>
                <span class="text-slate-300 dark:text-[hsl(0_0%_28%)] text-sm font-light pb-3">:</span>
                <div class="flex flex-col items-center min-w-[20px] sm:min-w-[24px]">
                  <span id="jm-hours" class="text-base sm:text-xl font-bold tabular-nums text-slate-700 dark:text-[var(--ch-text-strong)] leading-none">--</span>
                  <span class="text-[8px] sm:text-[9px] text-slate-400 dark:text-[hsl(0_0%_45%)] uppercase tracking-wide mt-0.5">hrs</span>
                </div>
                <span class="text-slate-300 dark:text-[hsl(0_0%_28%)] text-sm font-light pb-3">:</span>
                <div class="flex flex-col items-center min-w-[20px] sm:min-w-[24px]">
                  <span id="jm-mins" class="text-base sm:text-xl font-bold tabular-nums text-slate-700 dark:text-[var(--ch-text-strong)] leading-none">--</span>
                  <span class="text-[8px] sm:text-[9px] text-slate-400 dark:text-[hsl(0_0%_45%)] uppercase tracking-wide mt-0.5">min</span>
                </div>
              </div>
              <p class="text-[9px] sm:text-[10px] text-slate-400 dark:text-[hsl(0_0%_45%)] mt-1 tracking-wide">until launch</p>
            </div>
            <div id="jm-countdown-fallback" class="hidden pb-4 px-3 text-center">
              <span class="inline-block px-4 py-1 rounded-full bg-slate-200 dark:bg-[hsl(0_0%_12%)] text-xs text-slate-500 dark:text-[var(--ch-text-faint)] font-medium">
                Launching soon
              </span>
            </div>
          </div>
        </div>

        <!-- Guyana -->
        <div
          class="rounded-2xl shadow-sm overflow-hidden dark:ring-1 dark:ring-white/15 bg-white/70 dark:bg-[var(--ch-surface)] opacity-60 cursor-not-allowed"
          role="listitem"
        >
          <div aria-disabled="true" role="button" tabindex="-1">
            <div class="px-3 pt-2.5 pb-2">
              <h3 class="text-caption font-bold text-slate-600 dark:text-[hsl(0_0%_70%)]">🇬🇾 Guyana</h3>
            </div>
            <div class="w-full aspect-square overflow-hidden relative">
              <Image src={guyanaImg} alt="Guyana map" class="w-full h-full object-cover grayscale block dark:hidden" loading="lazy" width={220} height={220} format="webp" quality={60} />
              <Image src={guyanaDarkImg} alt="Guyana map" class="w-full h-full object-cover grayscale hidden dark:block" loading="lazy" width={220} height={220} format="webp" quality={60} />
              <div class="absolute inset-0 bg-slate-300/20 dark:bg-slate-900/30"></div>
            </div>
            <div class="py-3 px-3 text-center">
              <span class="inline-block px-3 py-1 rounded-full bg-slate-200 dark:bg-[hsl(0_0%_12%)] text-xs text-slate-500 dark:text-[var(--ch-text-faint)] font-medium">Coming Soon</span>
              <p class="text-[10px] text-transparent mt-1">–</p>
            </div>
          </div>
        </div>

        <!-- Barbados -->
        <div
          class="rounded-2xl shadow-sm overflow-hidden dark:ring-1 dark:ring-white/15 bg-white/70 dark:bg-[var(--ch-surface)] opacity-60 cursor-not-allowed"
          role="listitem"
        >
