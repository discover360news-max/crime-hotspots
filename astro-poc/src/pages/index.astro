---
/**
 * Homepage - Country Selection
 * Caribbean-wide crime statistics portal
 */

// Keep homepage static (pre-rendered at build time)
export const prerender = true;

import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import HomepagePulse from '../components/HomepagePulse.astro';
import QuickAnswers from '../components/QuickAnswers.astro';
import { routes } from '../config/routes';
// Import optimized images (Astro converts to WebP automatically)
import trinidadImg from '../assets/images/trinidad.jpg';
import guyanaImg from '../assets/images/guyana.jpg';
import barbadosImg from '../assets/images/barbados.jpg';
import jamaicaImg from '../assets/images/jamaica-card-trsp-bg.png';
// Dark mode variants (transparent background, blends with dark card)
import trinidadDarkImg from '../assets/images/trinidad-card-trsp-bg.png';
import guyanaDarkImg from '../assets/images/guyana-card-trsp-bg.png';
import barbadosDarkImg from '../assets/images/barbados-card-trsp-bg.png';

const title = "Crime Hotspots Caribbean — Live Crime Statistics for the Caribbean";
const description = "Live crime statistics and interactive maps for Trinidad & Tobago. Track murders, robberies, and incidents by location with verified data from Guardian, Express, and Newsday.";

// Country data
// image/darkImage: ImageMetadata for countries with graphics, null for placeholder cards
type Country = {
  id: string; name: string; short: string; flag: string; dashboard: string;
  available: boolean; image: typeof trinidadImg | null; darkImage: typeof trinidadDarkImg | null;
};
const countries: Country[] = [
  {
    id: 'tt',
    name: 'Trinidad & Tobago',
    short: 'Nationwide coverage',
    flag: '🇹🇹',
    dashboard: routes.trinidad.dashboard,
    available: true,
    image: trinidadImg,
    darkImage: trinidadDarkImg,
  },
  {
    id: 'jm',
    name: 'Jamaica',
    short: 'Coming soon',
    flag: '🇯🇲',
    dashboard: routes.jamaica.dashboard,
    available: false,
    image: jamaicaImg,
    darkImage: jamaicaImg,
  },
  {
    id: 'gy',
    name: 'Guyana',
    short: 'Coming soon',
    flag: '🇬🇾',
    dashboard: '/guyana/dashboard',
    available: false,
    image: guyanaImg,
    darkImage: guyanaDarkImg,
  },
  {
    id: 'bdos',
    name: 'Barbados',
    short: 'Coming soon',
    flag: '🇧🇧',
    dashboard: '/barbados/dashboard',
    available: false,
    image: barbadosImg,
    darkImage: barbadosDarkImg,
  },
];
---

<Layout title={title} description={description} includeLeaflet={false} includePagefind={false}>
  <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-5">
    <!-- Hero Section -->
    <section class="flex flex-col items-center justify-center text-center mb-12">
      <div class="text-center max-w-2xl mx-auto mb-8">
        <h1 class="text-display font-bold text-slate-900 dark:text-[hsl(0_0%_95%)] mb-3">
          Know Where. Stay Safe.
        </h1>
        <p class="text-body font-normal text-slate-500 dark:text-[hsl(0_0%_60%)]">
          Live crime data and safety trends for your area.
        </p>
      </div>

      <!-- Country Cards: Trinidad (with pulse) + Coming Soon -->
      <div class="flex flex-col items-center gap-8 sm:gap-10" role="list" aria-label="Countries">

        <!-- Trinidad: Unified card (image + live stats) -->
        <div role="listitem">
          <a
            href={routes.trinidad.dashboard}
            class="group relative block w-full max-w-[280px] sm:max-w-xs rounded-2xl shadow-sm overflow-hidden dark:ring-1 dark:ring-white/15 bg-white/70 dark:bg-[var(--ch-surface)] hover:shadow-lg transition-shadow duration-300 cursor-pointer"
          >
            <!-- Card header: country name + LIVE badge -->
            <div class="flex items-center justify-between px-3 pt-2.5 pb-2">
              <h2 class="text-caption font-bold text-slate-700 dark:text-[var(--ch-text-strong)]">🇹🇹 Trinidad & Tobago</h2>
              <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-rose-600/90 backdrop-blur-sm text-white text-[10px] font-bold tracking-wide uppercase">
                <span class="relative flex h-1.5 w-1.5">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-white opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-white"></span>
                </span>
                Live
              </span>
            </div>

            <!-- Island image: hover lifts + scales slightly -->
            <div class="w-full aspect-square overflow-hidden bg-white/70 dark:bg-transparent">
              <Image
                src={trinidadImg}
                alt="Trinidad & Tobago map"
                class="w-full h-full object-cover block dark:hidden transition-transform duration-300 ease-out group-hover:scale-[1.04] group-hover:-translate-y-1"
                loading="eager"
                width={280}
                height={280}
                format="webp"
                quality={80}
              />
              <Image
                src={trinidadDarkImg}
                alt="Trinidad & Tobago map"
                class="w-full h-full object-cover hidden dark:block transition-transform duration-300 ease-out group-hover:scale-[1.04] group-hover:-translate-y-1"
                loading="eager"
                width={280}
                height={280}
                format="webp"
                quality={80}
              />
            </div>

            <!-- Live stats embedded inline -->
            <HomepagePulse embedded countryName="Trinidad & Tobago" dashboardUrl={routes.trinidad.dashboard} />
          </a>
        </div>

        <!-- Coming Soon Countries -->
        <div class="flex gap-6 sm:gap-8">

          <!-- Jamaica: countdown card -->
          <div
            class="w-full max-w-[200px] sm:max-w-[220px] rounded-2xl shadow-sm overflow-hidden dark:ring-1 dark:ring-white/15 bg-white/70 dark:bg-[var(--ch-surface)] opacity-90 cursor-not-allowed"
            role="listitem"
          >
            <div aria-disabled="true" role="button" tabindex="-1">
              <!-- Card header -->
              <div class="flex items-center justify-between px-3 pt-2.5 pb-2">
                <h2 class="text-caption font-bold text-slate-600 dark:text-[hsl(0_0%_70%)]">🇯🇲 Jamaica</h2>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full bg-amber-100 dark:bg-amber-950/40 text-amber-700 dark:text-amber-400 text-[10px] font-bold tracking-wide uppercase">
                  Jul 2026
                </span>
              </div>
              <!-- Island image: full colour, no grayscale -->
              <div class="w-full aspect-square overflow-hidden bg-white dark:bg-transparent relative">
                <Image
                  src={jamaicaImg}
                  alt="Jamaica map"
                  class="w-full h-full object-cover"
                  loading="lazy"
                  width={220}
                  height={220}
                  format="webp"
                  quality={70}
                />
              </div>
              <!-- Countdown (populated by JS) -->
              <div id="jm-countdown" class="py-4 px-3 text-center">
                <div class="flex items-end justify-center gap-2">
                  <div class="flex flex-col items-center min-w-[32px]">
                    <span id="jm-days" class="text-xl font-bold tabular-nums text-slate-700 dark:text-[var(--ch-text-strong)] leading-none">--</span>
                    <span class="text-[9px] text-slate-400 dark:text-[hsl(0_0%_45%)] uppercase tracking-wide mt-0.5">days</span>
                  </div>
                  <span class="text-slate-300 dark:text-[hsl(0_0%_28%)] text-base font-light pb-3.5">:</span>
                  <div class="flex flex-col items-center min-w-[28px]">
                    <span id="jm-hours" class="text-xl font-bold tabular-nums text-slate-700 dark:text-[var(--ch-text-strong)] leading-none">--</span>
                    <span class="text-[9px] text-slate-400 dark:text-[hsl(0_0%_45%)] uppercase tracking-wide mt-0.5">hrs</span>
                  </div>
                  <span class="text-slate-300 dark:text-[hsl(0_0%_28%)] text-base font-light pb-3.5">:</span>
                  <div class="flex flex-col items-center min-w-[28px]">
                    <span id="jm-mins" class="text-xl font-bold tabular-nums text-slate-700 dark:text-[var(--ch-text-strong)] leading-none">--</span>
                    <span class="text-[9px] text-slate-400 dark:text-[hsl(0_0%_45%)] uppercase tracking-wide mt-0.5">min</span>
                  </div>
                </div>
                <p class="text-[10px] text-slate-400 dark:text-[hsl(0_0%_45%)] mt-1.5 tracking-wide">until launch</p>
              </div>
              <!-- Fallback: shown when countdown hits zero (hidden by default) -->
              <div id="jm-countdown-fallback" class="hidden pb-5 px-3 text-center">
                <span class="inline-block px-5 py-1 rounded-full bg-slate-200 dark:bg-[hsl(0_0%_12%)] text-xs text-slate-500 dark:text-[var(--ch-text-faint)] font-medium">
                  Launching soon
                </span>
              </div>
            </div>
          </div>

          <!-- Remaining coming-soon countries (Guyana, Barbados) -->
          {countries.filter(c => !c.available && c.id !== 'jm').map(country => (
            <div
              class="w-full max-w-[200px] sm:max-w-[220px] rounded-2xl shadow-sm overflow-hidden dark:ring-1 dark:ring-white/15 bg-white/70 dark:bg-[var(--ch-surface)] opacity-60 cursor-not-allowed"
              role="listitem"
            >
              <div aria-disabled="true" role="button" tabindex="-1">
                <!-- Card header: matches Jamaica layout -->
                <div class="flex items-center justify-between px-3 pt-2.5 pb-2">
                  <h2 class="text-caption font-bold text-slate-600 dark:text-[hsl(0_0%_70%)]">{country.flag} {country.name}</h2>
                </div>
                <!-- Image -->
                <div class="w-full aspect-square overflow-hidden bg-slate-200 dark:bg-[var(--ch-surface-sub)] relative">
                  {country.image !== null ? (
                    <>
                      <Image
                        src={country.image}
                        alt={`${country.name} map`}
                        class="w-full h-full object-cover grayscale block dark:hidden"
                        loading="lazy"
                        width={220}
                        height={220}
                        format="webp"
                        quality={60}
                      />
                      <Image
                        src={country.darkImage!}
                        alt={`${country.name} map`}
                        class="w-full h-full object-cover grayscale hidden dark:block"
                        loading="lazy"
                        width={220}
                        height={220}
                        format="webp"
                        quality={60}
                      />
                    </>
                  ) : (
                    <div class="absolute inset-0 flex items-center justify-center bg-gradient-to-br from-slate-200 to-slate-300 dark:from-[hsl(0_0%_12%)] dark:to-[hsl(0_0%_8%)]">
                      <span class="text-5xl select-none" aria-hidden="true">{country.flag}</span>
                    </div>
                  )}
                  <div class="absolute inset-0 bg-slate-300/20 dark:bg-slate-900/30"></div>
                </div>
                <!-- Footer: matches Jamaica countdown section height -->
                <div class="py-4 px-3 text-center">
                  <span class="inline-block px-5 py-1 rounded-full bg-slate-200 dark:bg-[hsl(0_0%_12%)] text-xs text-slate-500 dark:text-[var(--ch-text-faint)] font-medium">
                    Coming Soon
                  </span>
                  <p class="text-[10px] text-transparent mt-1.5">–</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Explore Section -->
      <div class="max-w-3xl w-full mx-auto px-4 sm:px-6 lg:px-8 mt-12 mb-6">
        <div class="text-center mb-6">
          <span class="inline-block px-3 py-0.5 rounded-full bg-rose-100 dark:bg-rose-950/50 text-rose-700 dark:text-rose-400 text-xs font-semibold tracking-wide uppercase mb-3">
            Explore
          </span>
          <h2 class="text-heading font-bold text-slate-800 dark:text-[var(--ch-text)]">
            Where do you want to start?
          </h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 text-left">
          <a href={routes.trinidad.areas} class="group bg-white/70 dark:bg-[var(--ch-surface)] backdrop-blur-md rounded-2xl shadow-sm border border-slate-100 dark:border-[hsl(0_0%_12%)] p-5 flex flex-col gap-2 hover:shadow-md transition-shadow">
            <p class="text-body font-bold text-slate-800 dark:text-[var(--ch-text)] leading-snug">See your area's risk level</p>
            <p class="text-xs text-slate-500 dark:text-[hsl(0_0%_60%)] leading-relaxed flex-1">Check how your area ranks across Trinidad by crime count and risk score.</p>
            <span class="inline-flex items-center gap-1 text-xs text-rose-600 dark:text-rose-400 font-medium group-hover:text-rose-700 dark:group-hover:text-rose-300 transition-colors">
              Browse areas
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </span>
          </a>

          <a href={routes.trinidad.murderCount} class="group bg-white/70 dark:bg-[var(--ch-surface)] backdrop-blur-md rounded-2xl shadow-sm border border-slate-100 dark:border-[hsl(0_0%_12%)] p-5 flex flex-col gap-2 hover:shadow-md transition-shadow">
            <p class="text-body font-bold text-slate-800 dark:text-[var(--ch-text)] leading-snug">Track the murder count</p>
            <p class="text-xs text-slate-500 dark:text-[hsl(0_0%_60%)] leading-relaxed flex-1">Follow the 2026 running total with a week-by-week breakdown and trend line.</p>
            <span class="inline-flex items-center gap-1 text-xs text-rose-600 dark:text-rose-400 font-medium group-hover:text-rose-700 dark:group-hover:text-rose-300 transition-colors">
              View count
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </span>
          </a>

          <a href={routes.blog} class="group bg-white/70 dark:bg-[var(--ch-surface)] backdrop-blur-md rounded-2xl shadow-sm border border-slate-100 dark:border-[hsl(0_0%_12%)] p-5 flex flex-col gap-2 hover:shadow-md transition-shadow">
            <p class="text-body font-bold text-slate-800 dark:text-[var(--ch-text)] leading-snug">Read this week's report</p>
            <p class="text-xs text-slate-500 dark:text-[hsl(0_0%_60%)] leading-relaxed flex-1">Weekly crime analysis covering incidents, trends, and what's changed across the island.</p>
            <span class="inline-flex items-center gap-1 text-xs text-rose-600 dark:text-rose-400 font-medium group-hover:text-rose-700 dark:group-hover:text-rose-300 transition-colors">
              Read report
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </span>
          </a>
        </div>
      </div>

      <QuickAnswers />
    </section>
  </main>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const daysEl = document.getElementById('jm-days');
    const hoursEl = document.getElementById('jm-hours');
    const minsEl = document.getElementById('jm-mins');
    const countdownEl = document.getElementById('jm-countdown');
    const fallbackEl = document.getElementById('jm-countdown-fallback');

    if (!daysEl || !hoursEl || !minsEl) return;

    const target = new Date('2026-07-04T00:00:00');

    function update() {
      const diff = target.getTime() - Date.now();

      if (diff <= 0) {
        if (countdownEl) countdownEl.classList.add('hidden');
        if (fallbackEl) fallbackEl.classList.remove('hidden');
        return;
      }

      const days = Math.floor(diff / 86400000);
      const hours = Math.floor((diff % 86400000) / 3600000);
      const mins = Math.floor((diff % 3600000) / 60000);

      daysEl.textContent = String(days);
      hoursEl.textContent = String(hours).padStart(2, '0');
      minsEl.textContent = String(mins).padStart(2, '0');
    }

    update();
    setInterval(update, 60000);
  });
</script>

<script
  type="application/ld+json"
  set:html={`
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Crime Hotspots",
      "url": "https://crimehotspots.com",
      "description": "Real-time crime statistics and interactive dashboards for the Caribbean",
      "publisher": {
        "@type": "Organization",
        "name": "Crime Hotspots",
        "url": "https://crimehotspots.com"
      }
    }
  `}
/>
