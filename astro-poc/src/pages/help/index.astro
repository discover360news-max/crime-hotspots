---
/**
 * Help Centre Index
 * Search bar + section cards + links to FAQ, Methodology, Contact
 */

export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Hero from '../../components/Hero.astro';
import { getCollection } from 'astro:content';
import { routes } from '../../config/routes';

const title = "Help Centre — Crime Hotspots";
const description = "Find answers about how to use Crime Hotspots, understand the data, submit reports, and more. Browse articles or search by topic.";

const allArticles = await getCollection('help');
allArticles.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

// Build section map
const SECTIONS = ['Getting Started', 'Understanding the Data', 'Using the Dashboard', 'Safety Tips', 'Crime Reports', 'For Researchers', 'Technical'] as const;

type SectionName = typeof SECTIONS[number];

const sectionMap = new Map<SectionName, typeof allArticles>();
for (const s of SECTIONS) {
  sectionMap.set(s, allArticles.filter(a => a.data.section === s));
}

// Serialise for client-side search
const helpIndex = allArticles.map(a => ({
  slug: a.slug,
  title: a.data.title,
  section: a.data.section,
  summary: a.data.summary,
}));

const collectionPageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Help Centre — Crime Hotspots",
  "description": description,
  "url": "https://crimehotspots.com/help/",
  "publisher": {
    "@type": "Organization",
    "name": "Crime Hotspots",
    "url": "https://crimehotspots.com"
  }
};
---

<Layout title={title} description={description}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(collectionPageSchema)} />
  <Hero
    compact
    narrowContainer={true}
    title="Help Centre"
    subtitle="How can we help?"
  >
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'Help Centre' }
    ]} slot="before" />
  </Hero>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-6">

    <!-- Search bar -->
    <div class="relative mb-10 max-w-2xl mx-auto">
      <label for="help-search" class="sr-only">Search help articles</label>
      <div class="absolute inset-y-0 left-4 flex items-center pointer-events-none">
        <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </div>
      <input
        id="help-search"
        type="search"
        placeholder="Search help articles..."
        autocomplete="off"
        class="w-full pl-12 pr-4 py-3.5 rounded-xl border border-slate-200 dark:border-[var(--ch-border-card)] bg-white dark:bg-[var(--ch-surface)] text-slate-700 dark:text-[var(--ch-text)] text-body placeholder-slate-400 dark:placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-rose-400 dark:focus:ring-rose-600 shadow-sm"
        aria-label="Search help articles"
      />
    </div>

    <!-- Search results (hidden until user types) -->
    <div id="help-results" hidden class="mb-10 max-w-2xl mx-auto">
      <p id="help-results-count" class="text-caption text-slate-400 dark:text-[var(--ch-text-muted)] mb-3"></p>
      <ul id="help-results-list" class="space-y-3"></ul>
    </div>

    <!-- Section cards grid -->
    <div id="help-sections">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-12">
        {SECTIONS.map(section => {
          const articles = sectionMap.get(section) ?? [];
          if (articles.length === 0) return null;
          return (
            <div class="bg-white/70 dark:bg-[hsl(0_0%_8%_/_0.7)] backdrop-blur-md rounded-xl border border-slate-100 dark:border-[var(--ch-border-card)] p-5 shadow-sm flex flex-col">
              <div class="mb-3">
                <h2 class="text-body font-bold text-slate-800 dark:text-[var(--ch-text-strong)]">{section}</h2>
                <p class="text-caption text-slate-400 dark:text-[var(--ch-text-muted)] mt-0.5">{articles.length} article{articles.length !== 1 ? 's' : ''}</p>
              </div>
              <ul class="space-y-1.5 flex-1">
                {articles.slice(0, 3).map(article => (
                  <li>
                    <a
                      href={`/help/${article.slug}/`}
                      class="text-caption text-rose-600 dark:text-rose-400 hover:text-rose-700 dark:hover:text-rose-300 hover:underline leading-snug block"
                    >
                      {article.data.title}
                    </a>
                  </li>
                ))}
                {articles.length > 3 && (
                  <li class="pt-1">
                    <span class="text-caption text-slate-400 dark:text-[var(--ch-text-muted)]">
                      +{articles.length - 3} more
                    </span>
                  </li>
                )}
              </ul>
            </div>
          );
        })}
      </div>

      <!-- Footer CTA cards -->
      <div class="border-t border-slate-200 dark:border-[var(--ch-border)] pt-8">
        <h3 class="text-body font-bold text-slate-700 dark:text-[var(--ch-text)] mb-4">More resources</h3>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <a href={routes.faq} class="block bg-white/70 dark:bg-[hsl(0_0%_8%_/_0.7)] rounded-xl border border-slate-100 dark:border-[var(--ch-border-card)] p-4 hover:border-rose-300 dark:hover:border-rose-800 transition group">
            <p class="text-caption font-bold text-slate-700 dark:text-[var(--ch-text-strong)] group-hover:text-rose-600 dark:group-hover:text-rose-400">FAQ</p>
            <p class="text-caption text-slate-400 dark:text-[var(--ch-text-muted)] mt-1">Quick answers to common questions</p>
          </a>
          <a href={routes.methodology} class="block bg-white/70 dark:bg-[hsl(0_0%_8%_/_0.7)] rounded-xl border border-slate-100 dark:border-[var(--ch-border-card)] p-4 hover:border-rose-300 dark:hover:border-rose-800 transition group">
            <p class="text-caption font-bold text-slate-700 dark:text-[var(--ch-text-strong)] group-hover:text-rose-600 dark:group-hover:text-rose-400">Methodology</p>
            <p class="text-caption text-slate-400 dark:text-[var(--ch-text-muted)] mt-1">How we collect and process data</p>
          </a>
          <a href={routes.contact} class="block bg-white/70 dark:bg-[hsl(0_0%_8%_/_0.7)] rounded-xl border border-slate-100 dark:border-[var(--ch-border-card)] p-4 hover:border-rose-300 dark:hover:border-rose-800 transition group">
            <p class="text-caption font-bold text-slate-700 dark:text-[var(--ch-text-strong)] group-hover:text-rose-600 dark:group-hover:text-rose-400">Contact Us</p>
            <p class="text-caption text-slate-400 dark:text-[var(--ch-text-muted)] mt-1">Get in touch with our team</p>
          </a>
        </div>
      </div>
    </div>

  </div>
</Layout>

<script define:vars={{ helpIndex }}>
  document.addEventListener('DOMContentLoaded', () => {
    const input = document.getElementById('help-search');
    const results = document.getElementById('help-results');
    const resultsList = document.getElementById('help-results-list');
    const resultsCount = document.getElementById('help-results-count');
    const sections = document.getElementById('help-sections');

    if (!input || !results || !resultsList || !resultsCount || !sections) return;

    function renderResults(matches, q) {
      resultsList.innerHTML = '';
      resultsCount.textContent = matches.length === 0
        ? 'No articles found'
        : `${matches.length} article${matches.length !== 1 ? 's' : ''} found`;

      for (const article of matches) {
        const li = document.createElement('li');
        li.className = 'bg-white/70 dark:bg-[hsl(0_0%_8%_/_0.7)] rounded-xl border border-slate-100 dark:border-[hsl(0_0%_18%)] p-4';
        li.innerHTML = `
          <a href="/help/${article.slug}/" class="block">
            <p class="text-body font-bold text-rose-600 dark:text-rose-400 hover:underline leading-snug">${escapeHtml(article.title)}</p>
            <p class="text-caption text-slate-400 dark:text-[hsl(0_0%_50%)] mt-1">${escapeHtml(article.section)}</p>
            <p class="text-caption text-slate-600 dark:text-[hsl(0_0%_60%)] mt-1.5 leading-relaxed">${escapeHtml(article.summary)}</p>
          </a>
        `;
        resultsList.appendChild(li);
      }
    }

    function escapeHtml(str) {
      return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    input.addEventListener('input', () => {
      const q = input.value.trim().toLowerCase();
      if (!q) {
        results.hidden = true;
        sections.hidden = false;
        return;
      }
      const matches = helpIndex.filter(a =>
        a.title.toLowerCase().includes(q) ||
        a.summary.toLowerCase().includes(q) ||
        a.section.toLowerCase().includes(q)
      );
      renderResults(matches, q);
      results.hidden = false;
      sections.hidden = true;
    });
  });
</script>
