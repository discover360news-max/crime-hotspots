---
/**
 * Help Article Detail
 * Individual help article with breadcrumbs, sidebar, prev/next nav, and "Was this helpful?" CTA
 */

export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Hero from '../../components/Hero.astro';
import SocialProofStrip from '../../components/SocialProofStrip.astro';
import { getCollection } from 'astro:content';
import { routes } from '../../config/routes';

export async function getStaticPaths() {
  const articles = await getCollection('help');
  return articles.map(article => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await article.render();

// Get all articles for sidebar + prev/next
const allArticles = await getCollection('help');
allArticles.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const sectionArticles = allArticles.filter(a => a.data.section === article.data.section);
const globalIndex = allArticles.findIndex(a => a.slug === article.slug);
const prevArticle = globalIndex > 0 ? allArticles[globalIndex - 1] : null;
const nextArticle = globalIndex < allArticles.length - 1 ? allArticles[globalIndex + 1] : null;

// Resolve related articles from slugs, excluding same-section (shown in sidebar already)
const relatedArticles = (article.data.related ?? [])
  .map(slug => allArticles.find(a => a.slug === slug))
  .filter((a): a is NonNullable<typeof a> => a !== undefined);

// Cross-section related: only articles from a different section
const crossSectionRelated = relatedArticles.filter(a => a.data.section !== article.data.section);

const title = `${article.data.title} — Help Centre | Crime Hotspots`;
const description = article.data.summary;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": article.data.title,
  "description": article.data.summary,
  "url": `https://crimehotspots.com/help/${article.slug}/`,
  "articleSection": article.data.section,
  ...(article.data.date_updated && { "dateModified": article.data.date_updated.toISOString() }),
  "author": {
    "@type": "Organization",
    "name": "Crime Hotspots",
    "url": "https://crimehotspots.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Crime Hotspots",
    "url": "https://crimehotspots.com"
  }
};
---

<Layout title={title} description={description}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(articleSchema)} />
  <Hero
    compact
    narrowContainer={true}
    title={article.data.title}
    subtitle={article.data.section}
  >
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'Help Centre', href: '/help/' },
      { label: article.data.section, href: `/help/#${article.data.section.toLowerCase().replace(/\s+/g, '-')}` },
      { label: article.data.title }
    ]} slot="before" />
  </Hero>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 pb-6">
    <SocialProofStrip variant="strip" />
  </div>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-6">
    <div class="flex gap-8 items-start">

      <!-- Article content -->
      <article class="flex-1 min-w-0">
        <div class="bg-white/70 dark:bg-[hsl(0_0%_8%_/_0.7)] backdrop-blur-md rounded-xl border border-slate-100 dark:border-[var(--ch-border-card)] shadow-sm p-6 sm:p-8">
          <!-- Section + updated date -->
          <div class="flex items-center gap-3 mb-6">
            <span class="text-caption text-slate-400 dark:text-[var(--ch-text-muted)] bg-slate-100 dark:bg-[hsl(0_0%_13%)] rounded-full px-3 py-1">
              {article.data.section}
            </span>
            {article.data.date_updated && (
              <span class="text-caption text-slate-400 dark:text-[var(--ch-text-faint)]">
                Updated {article.data.date_updated.toLocaleDateString('en-TT', { year: 'numeric', month: 'long', day: 'numeric' })}
              </span>
            )}
          </div>

          <!-- Rendered markdown content -->
          <div class="prose-help">
            <Content />
          </div>
        </div>

        <!-- Related articles panel -->
        {relatedArticles.length > 0 && (
          <div class="mt-6 bg-white/70 dark:bg-[hsl(0_0%_8%_/_0.7)] rounded-xl border border-slate-100 dark:border-[var(--ch-border-card)] p-5">
            <h2 class="text-body font-bold text-slate-700 dark:text-[var(--ch-text-strong)] mb-4">Related articles</h2>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
              {relatedArticles.map(a => (
                <a href={`/help/${a.slug}/`} class="group block rounded-lg border border-slate-100 dark:border-[var(--ch-border-card)] bg-slate-50/60 dark:bg-[hsl(0_0%_10%)] p-3 hover:border-rose-300 dark:hover:border-rose-800 transition">
                  <p class="text-caption font-bold text-rose-600 dark:text-rose-400 group-hover:underline leading-snug">{a.data.title}</p>
                  <p class="text-caption text-slate-400 dark:text-[var(--ch-text-faint)] mt-1">{a.data.section}</p>
                </a>
              ))}
            </div>
          </div>
        )}

        <!-- Prev / Next navigation -->
        {(prevArticle || nextArticle) && (
          <nav class="mt-6 grid grid-cols-2 gap-4" aria-label="Article navigation">
            {prevArticle ? (
              <a href={`/help/${prevArticle.slug}/`} class="group bg-white/70 dark:bg-[hsl(0_0%_8%_/_0.7)] rounded-xl border border-slate-100 dark:border-[var(--ch-border-card)] p-4 hover:border-rose-300 dark:hover:border-rose-800 transition col-start-1">
                <p class="text-caption text-slate-400 dark:text-[var(--ch-text-muted)] mb-1">Previous</p>
                <p class="text-caption font-bold text-rose-600 dark:text-rose-400 group-hover:underline leading-snug">{prevArticle.data.title}</p>
              </a>
            ) : <div />}
            {nextArticle && (
              <a href={`/help/${nextArticle.slug}/`} class="group bg-white/70 dark:bg-[hsl(0_0%_8%_/_0.7)] rounded-xl border border-slate-100 dark:border-[var(--ch-border-card)] p-4 hover:border-rose-300 dark:hover:border-rose-800 transition text-right col-start-2">
                <p class="text-caption text-slate-400 dark:text-[var(--ch-text-muted)] mb-1">Next</p>
                <p class="text-caption font-bold text-rose-600 dark:text-rose-400 group-hover:underline leading-snug">{nextArticle.data.title}</p>
              </a>
            )}
          </nav>
        )}

        <!-- Was this helpful? CTA -->
        <div class="mt-6 bg-white/70 dark:bg-[hsl(0_0%_8%_/_0.7)] rounded-xl border border-slate-100 dark:border-[var(--ch-border-card)] p-5 text-center">
          <p class="text-body font-bold text-slate-700 dark:text-[var(--ch-text-strong)] mb-2">Was this article helpful?</p>
          <p class="text-caption text-slate-400 dark:text-[var(--ch-text-muted)] mb-4">
            If you couldn't find what you were looking for, get in touch.
          </p>
          <a
            href={routes.contact}
            class="inline-block px-5 py-2 rounded-lg bg-rose-600 text-white hover:bg-rose-700 active:bg-rose-800 transition text-caption font-bold"
          >
            Contact Us
          </a>
        </div>
      </article>

      <!-- Sidebar: section nav + cross-section related + Ko-fi (desktop only) -->
      <aside class="hidden lg:block w-64 shrink-0 sticky top-24 space-y-4">

        <!-- Section navigation -->
        <div class="bg-white/70 dark:bg-[hsl(0_0%_8%_/_0.7)] rounded-xl border border-slate-100 dark:border-[var(--ch-border-card)] p-4">
          <h3 class="text-caption font-bold text-slate-700 dark:text-[var(--ch-text-strong)] uppercase tracking-wider mb-3">
            {article.data.section}
          </h3>
          <ul class="space-y-1">
            {sectionArticles.map(a => (
              <li>
                <a
                  href={`/help/${a.slug}/`}
                  class={`block text-caption py-1.5 px-2 rounded-lg leading-snug transition ${
                    a.slug === article.slug
                      ? 'bg-rose-50 dark:bg-rose-950/40 text-rose-600 dark:text-rose-400 font-bold'
                      : 'text-slate-600 dark:text-[var(--ch-text-muted)] hover:text-rose-600 dark:hover:text-rose-400 hover:bg-slate-50 dark:hover:bg-[hsl(0_0%_12%)]'
                  }`}
                >
                  {a.data.title}
                </a>
              </li>
            ))}
          </ul>
          <div class="mt-4 pt-4 border-t border-slate-100 dark:border-[var(--ch-border-card)]">
            <a href="/help/" class="text-caption text-rose-600 dark:text-rose-400 hover:underline">
              All help articles
            </a>
          </div>
        </div>

        <!-- Cross-section related articles -->
        {crossSectionRelated.length > 0 && (
          <div class="bg-white/70 dark:bg-[hsl(0_0%_8%_/_0.7)] rounded-xl border border-slate-100 dark:border-[var(--ch-border-card)] p-4">
            <h3 class="text-caption font-bold text-slate-700 dark:text-[var(--ch-text-strong)] uppercase tracking-wider mb-3">
              Related
            </h3>
            <ul class="space-y-2">
              {crossSectionRelated.map(a => (
                <li>
                  <a href={`/help/${a.slug}/`} class="block group">
                    <p class="text-caption text-rose-600 dark:text-rose-400 group-hover:underline leading-snug">{a.data.title}</p>
                    <p class="text-caption text-slate-400 dark:text-[var(--ch-text-faint)] mt-0.5">{a.data.section}</p>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}

        <!-- Ko-fi support card -->
        <div class="bg-white/70 dark:bg-[hsl(0_0%_8%_/_0.7)] rounded-xl border border-slate-100 dark:border-[var(--ch-border-card)] p-4">
          <p class="text-caption font-bold text-slate-700 dark:text-[var(--ch-text-strong)] mb-1">Support this project</p>
          <p class="text-caption text-slate-400 dark:text-[var(--ch-text-muted)] mb-3 leading-relaxed">
            Crime Hotspots is free and independent. Help keep it that way.
          </p>
          <a
            href="https://ko-fi.com/crimehotspots"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-3 py-1.5 rounded-lg border border-slate-200 dark:border-[hsl(0_0%_20%)] text-slate-600 dark:text-[hsl(0_0%_65%)] text-caption font-bold hover:border-amber-400 hover:text-amber-700 dark:hover:text-amber-400 dark:hover:border-amber-700 transition"
          >
            <svg class="w-4 h-4 text-amber-500 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M23.881 8.948c-.773-4.085-4.859-4.593-4.859-4.593H.723c-.604 0-.679.798-.679.798s-.082 7.324-.022 11.822c.164 2.424 2.586 2.672 2.586 2.672s8.267-.023 11.966-.049c2.438-.426 2.683-2.566 2.658-3.734 4.352.24 7.422-2.831 6.649-6.916zm-11.062 3.511c-1.246 1.453-4.011 3.976-4.011 3.976s-.121.119-.31.023c-.076-.057-.108-.09-.108-.09-.443-.441-3.368-3.049-4.034-3.954-.709-.965-1.041-2.7-.091-3.71.951-1.01 3.005-1.086 4.363.407 0 0 1.565-1.782 3.468-.963 1.904.82 1.832 3.011.723 4.311zm6.173.478c-.928.116-1.682.028-1.682.028V7.284h1.77s1.971.551 1.971 2.638c0 1.913-.985 2.667-2.059 3.015z"/>
            </svg>
            Support on Ko-fi
          </a>
        </div>

      </aside>

    </div>
  </div>
</Layout>

<style is:global>
  /* Prose styles for help article markdown content */
  .prose-help h2 {
    font-size: var(--text-heading);
    font-weight: 700;
    color: hsl(0 0% 20%);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    line-height: 1.35;
    letter-spacing: -0.01em;
  }

  .dark .prose-help h2 {
    color: hsl(0 0% 88%);
  }

  .prose-help h2:first-child {
    margin-top: 0;
  }

  .prose-help p {
    font-size: var(--text-body);
    line-height: var(--text-body--line-height);
    color: hsl(0 0% 30%);
    margin-bottom: 1.25rem;
  }

  .dark .prose-help p {
    color: hsl(0 0% 75%);
  }

  .prose-help ul,
  .prose-help ol {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .prose-help ul {
    list-style-type: disc;
  }

  .prose-help ol {
    list-style-type: decimal;
  }

  .prose-help li {
    font-size: var(--text-body);
    line-height: var(--text-body--line-height);
    color: hsl(0 0% 30%);
    margin-bottom: 0.35rem;
  }

  .dark .prose-help li {
    color: hsl(0 0% 75%);
  }

  .prose-help a {
    color: hsl(347 72% 50%); /* rose-600 */
    text-decoration: underline;
  }

  .dark .prose-help a {
    color: hsl(351 74% 69%); /* rose-400 */
  }

  .prose-help a:hover {
    color: hsl(347 77% 38%); /* rose-700 */
  }

  .dark .prose-help a:hover {
    color: hsl(351 77% 79%); /* rose-300 */
  }

  .prose-help strong {
    font-weight: 700;
    color: hsl(0 0% 15%);
  }

  .dark .prose-help strong {
    color: hsl(0 0% 88%);
  }

  .prose-help code {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.875em;
    background: hsl(0 0% 94%);
    color: hsl(347 72% 50%);
    padding: 0.1em 0.35em;
    border-radius: 4px;
  }

  .dark .prose-help code {
    background: hsl(0 0% 16%);
    color: hsl(351 74% 69%);
  }

  /* Tables */
  .prose-help table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
    font-size: var(--text-caption);
  }

  .prose-help th {
    text-align: left;
    font-weight: 700;
    color: hsl(0 0% 20%);
    border-bottom: 2px solid hsl(0 0% 88%);
    padding: 0.5rem 0.75rem;
  }

  .dark .prose-help th {
    color: hsl(0 0% 85%);
    border-bottom-color: hsl(0 0% 22%);
  }

  .prose-help td {
    color: hsl(0 0% 30%);
    border-bottom: 1px solid hsl(0 0% 92%);
    padding: 0.5rem 0.75rem;
  }

  .dark .prose-help td {
    color: hsl(0 0% 70%);
    border-bottom-color: hsl(0 0% 16%);
  }
</style>
