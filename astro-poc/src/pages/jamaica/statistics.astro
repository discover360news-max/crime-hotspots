---
/**
 * Jamaica Crime Statistics Hub
 * Authority page for Jamaica crime statistics
 * Target keyword: "jamaica crime statistics"
 *
 * Features:
 * - Auto-updates daily via Astro SSG + GitHub Actions rebuild
 * - Indexable text content for SEO
 * - Year-over-year comparisons
 * - TODO: wire to Jamaica D1 — replace empty allCrimes with getAllCrimesFromD1(db, 'JM')
 *   when Jamaica DB binding is configured in wrangler.toml
 */

import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Hero from '../../components/Hero.astro';
import StatCards from '../../components/StatCards.astro';
import DataTable from '../../components/DataTable.astro';
import { countCrimeType, calculateInsights } from '../../lib/dashboardHelpers';
import { JAMAICA_CSV_URL } from '../../config/csvUrls';
import { routes } from '../../config/routes';
import {
  compareYearToDate,
  getTopRegions,
  getTotalCrimeCount,
  filterToSamePeriod,
  formatPercentChange,
  getCurrentPeriodDescription,
  TRACKED_CRIME_TYPES
} from '../../lib/statisticsHelpers';
import NewsletterSignup from '../../components/NewsletterSignup.astro';
import type { Crime } from '../../lib/crimeData';

Astro.response.headers.set('CDN-Cache-Control', 'max-age=82800');
Astro.response.headers.set('Cache-Control', 'public, max-age=3600, must-revalidate');

// TODO: wire to Jamaica D1 when pipeline is live
// Replace: const allCrimes = db ? await getAllCrimesFromD1(db, 'JM') : [];
const allCrimes: Crime[] = [];

// Dynamic year handling
const currentYear = new Date().getFullYear();
const previousYear = currentYear - 1;

// Filter by year
const crimesCurrent = allCrimes.filter(c => c.year === currentYear);
const crimesPrevious = allCrimes.filter(c => c.year === previousYear);

// Calculate statistics
const yoyComparisons = compareYearToDate(crimesCurrent, crimesPrevious, currentYear, previousYear);
const topRegions = getTopRegions(crimesCurrent);
const totalCrimesCurrent = getTotalCrimeCount(crimesCurrent);
const totalCrimesPrevious = getTotalCrimeCount(crimesPrevious);

// Key crime counts for current year
const murderCount = countCrimeType(crimesCurrent, 'Murder');
const robberyCount = countCrimeType(crimesCurrent, 'Robbery');
const shootingCount = countCrimeType(crimesCurrent, 'Shooting');

// Previous year final counts
const murderCountPrevious = countCrimeType(crimesPrevious, 'Murder');
const robberyCountPrevious = countCrimeType(crimesPrevious, 'Robbery');

// YTD same-period comparison
const crimes2YTD = filterToSamePeriod(crimesCurrent, currentYear);
const crimesPrevSamePeriod = filterToSamePeriod(crimesPrevious, previousYear);
const totalCurrentYTD = getTotalCrimeCount(crimes2YTD);
const totalPrevSamePeriod = getTotalCrimeCount(crimesPrevSamePeriod);
const totalYoYChange = totalPrevSamePeriod > 0
  ? ((totalCurrentYTD - totalPrevSamePeriod) / totalPrevSamePeriod) * 100
  : 0;

// Extract YoY comparisons
const murderComp = yoyComparisons.find(c => c.type === 'Murder') ?? { countPrevious: 0, percentChange: 0, direction: 'flat' as const };
const robberyComp = yoyComparisons.find(c => c.type === 'Robbery') ?? { countPrevious: 0, percentChange: 0, direction: 'flat' as const };
const shootingComp = yoyComparisons.find(c => c.type === 'Shooting') ?? { countPrevious: 0, percentChange: 0, direction: 'flat' as const };

// Stat cards
const statsPageUrl = 'https://crimehotspots.com/jamaica/statistics/';
function buildShareText(count: number, noun: string, direction: string, change: number): string {
  const trend = direction === 'up'
    ? `up ${Math.round(Math.abs(change))}% vs ${previousYear}`
    : direction === 'down'
      ? `down ${Math.round(Math.abs(change))}% vs ${previousYear}`
      : `similar to ${previousYear}`;
  return `Jamaica: ${count} ${noun} in ${currentYear} — ${trend}. Track it live: ${statsPageUrl}`;
}

const statCardsData = [
  {
    label: 'Murders',
    current: murderCount,
    previous: murderComp.countPrevious,
    yoyChange: murderComp.percentChange,
    direction: murderComp.direction,
    shareText: buildShareText(murderCount, 'murders', murderComp.direction, murderComp.percentChange),
  },
  {
    label: 'Robberies',
    current: robberyCount,
    previous: robberyComp.countPrevious,
    yoyChange: robberyComp.percentChange,
    direction: robberyComp.direction,
    shareText: buildShareText(robberyCount, 'robberies', robberyComp.direction, robberyComp.percentChange),
  },
  {
    label: 'Shootings',
    current: shootingCount,
    previous: shootingComp.countPrevious,
    yoyChange: shootingComp.percentChange,
    direction: shootingComp.direction as 'flat' | 'up' | 'down' | 'same',
  },
  {
    label: 'All Crimes',
    current: totalCurrentYTD,
    previous: totalPrevSamePeriod,
    yoyChange: totalYoYChange,
    direction: (totalYoYChange < -0.5 ? 'down' : totalYoYChange > 0.5 ? 'up' : 'flat') as 'flat' | 'up' | 'down' | 'same',
  }
];

// Current period description
const periodDescription = getCurrentPeriodDescription();

// Last updated = build time
const lastUpdated = new Date().toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric'
});

// Crime rate calculations — Jamaica population ~2.8 million (2024 estimate)
const POPULATION = 2800000;

// Previous year FINAL rates
const murderRatePrevious = ((murderCountPrevious / POPULATION) * 100000).toFixed(1);
const robberyRatePrevious = ((robberyCountPrevious / POPULATION) * 100000).toFixed(1);
const totalCrimeRatePrevious = ((totalCrimesPrevious / POPULATION) * 100000).toFixed(1);

// Projection calculations
const startOfYear = new Date(`${currentYear}-01-01`);
const now = new Date();
const daysElapsed = Math.max(1, Math.floor((now.getTime() - startOfYear.getTime()) / (1000 * 60 * 60 * 24)));
const daysInYear = 365;

const murderProjected = Math.round((murderCount / daysElapsed) * daysInYear);
const robberyProjected = Math.round((robberyCount / daysElapsed) * daysInYear);
const totalCrimesProjected = Math.round((totalCrimesCurrent / daysElapsed) * daysInYear);

const murderRateProjected = ((murderProjected / POPULATION) * 100000).toFixed(1);
const robberyRateProjected = ((robberyProjected / POPULATION) * 100000).toFixed(1);
const totalCrimeRateProjected = ((totalCrimesProjected / POPULATION) * 100000).toFixed(1);

const canonicalUrl = 'https://crimehotspots.com/jamaica/statistics/';

// SEO
const title = `Jamaica Crime Statistics & Crime Rate ${currentYear} - Live Data | Crime Hotspots`;
const description = `Jamaica ${currentYear} crime statistics: ${totalCurrentYTD} total crimes — ${murderCount} murders, ${robberyCount} robberies, ${shootingCount} shootings (murder rate ${murderRateProjected} per 100k annualized, ${murderProjected} projected annually). ${previousYear} final: ${murderRatePrevious} per 100k. Updated daily.`;

// Structured Data — Dataset
const structuredData = {
  "@context": "https://schema.org",
  "@type": "Dataset",
  "name": `Jamaica Crime Statistics ${currentYear}`,
  "description": `Jamaica crime statistics ${currentYear}: ${totalCurrentYTD} total crimes, ${murderCount} murders, ${robberyCount} robberies, ${shootingCount} shootings. ${previousYear} final murder rate: ${murderRatePrevious} per 100k. Updated daily from verified news sources.`,
  "url": canonicalUrl,
  "license": "https://creativecommons.org/licenses/by/4.0/",
  "creator": {
    "@type": "Organization",
    "name": "Crime Hotspots",
    "url": "https://crimehotspots.com"
  },
  "distribution": [
    {
      "@type": "DataDownload",
      "encodingFormat": "text/csv",
      "contentUrl": JAMAICA_CSV_URL
    }
  ],
  "temporalCoverage": `${previousYear}/${currentYear}`,
  "spatialCoverage": {
    "@type": "Place",
    "name": "Jamaica",
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 18.1096,
      "longitude": -77.2975
    }
  },
  "dateModified": new Date().toISOString()
};

// FAQ structured data — targets "People Also Ask" for Jamaica crime queries
const topCrimeType = ['Murder', 'Robbery', 'Shooting', 'Home Invasion', 'Theft']
  .map(t => ({ type: t, count: countCrimeType(crimesCurrent, t) }))
  .sort((a, b) => b.count - a.count)[0]?.type ?? 'Robbery';
const yoyDirection = totalYoYChange > 5 ? 'up' : totalYoYChange < -5 ? 'down' : 'similar';
const yoyFaqText = yoyDirection === 'up'
  ? `${currentYear} is tracking higher — ${totalCurrentYTD} crimes YTD vs ${totalPrevSamePeriod} over the same period in ${previousYear} (up ${Math.round(totalYoYChange)}%).`
  : yoyDirection === 'down'
    ? `${currentYear} is tracking lower — ${totalCurrentYTD} crimes YTD vs ${totalPrevSamePeriod} over the same period in ${previousYear} (down ${Math.round(Math.abs(totalYoYChange))}%).`
    : `${currentYear} is tracking similar to ${previousYear} — ${totalCurrentYTD} crimes YTD vs ${totalPrevSamePeriod} over the same period last year.`;

const faqData = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": `How many murders in Jamaica in ${currentYear}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Jamaica has recorded ${murderCount} murders so far in ${currentYear} (as of ${lastUpdated}). At the current pace, the annualized murder rate is ${murderRateProjected} per 100,000 population, with ${murderProjected} murders projected by year end.`
      }
    },
    {
      "@type": "Question",
      "name": `What is the crime rate in Jamaica in ${currentYear}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Jamaica's annualized murder rate in ${currentYear} is ${murderRateProjected} per 100,000 population (${murderCount} murders in ${daysElapsed} days as of ${lastUpdated}). The ${previousYear} final murder rate was ${murderRatePrevious} per 100,000. Total crimes tracked in ${currentYear}: ${totalCurrentYTD}, including ${robberyCount} robberies and ${shootingCount} shootings.`
      }
    },
    {
      "@type": "Question",
      "name": `What is the most common crime in Jamaica in ${currentYear}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `${topCrimeType} is the most frequently recorded crime type in Jamaica in ${currentYear}, based on verified news reports tracked by Crime Hotspots. Other major crime types include murder (${murderCount}), robbery (${robberyCount}), and shootings (${shootingCount}).`
      }
    },
    {
      "@type": "Question",
      "name": `How does Jamaica's ${currentYear} crime rate compare to ${previousYear}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `${yoyFaqText} The ${previousYear} final murder rate was ${murderRatePrevious} per 100,000 — consistently one of the highest in the Caribbean. Data is updated daily from verified news sources.`
      }
    }
  ]
};

// Breadcrumb structured data
const breadcrumbData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://crimehotspots.com/" },
    { "@type": "ListItem", "position": 2, "name": "Jamaica", "item": "https://crimehotspots.com/jamaica/dashboard/" },
    { "@type": "ListItem", "position": 3, "name": "Statistics" }
  ]
};
---

<Layout title={title} description={description} noindex={true}>
  <Hero
    compact
    narrowContainer={true}
    title="Jamaica Crime Statistics"
    subtitle="Real-time crime statistics and data analysis for Jamaica. Track the crime rate, murder statistics, robbery trends, and parish crime data. Updated daily from verified sources."
    badge={`Updated daily • Last updated: ${lastUpdated}`}
    primaryCTA={{
      text: "View Interactive Dashboard",
      href: routes.jamaica.dashboard,
      icon: "dashboard"
    }}
    secondaryCTA={{
      text: `Download ${currentYear} Data`,
      href: JAMAICA_CSV_URL,
      icon: "download",
      target: "_blank",
      rel: "noopener noreferrer"
    }}
  >
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'Jamaica', href: routes.jamaica.dashboard },
      { label: 'Statistics' }
    ]} slot="before" />
  </Hero>

  <main class="max-w-3xl mx-auto px-4 py-8">

    <!-- Quick Answer box — structured for Google featured snippet capture -->
    <!-- Targets: "jamaica crime rate 2026", "jamaica crime statistics 2026" -->
    <section class="mb-8 p-4 rounded-lg border border-slate-200 dark:border-[var(--ch-border-subtle)] bg-slate-50 dark:bg-[hsl(0_0%_9%)]">
      <p class="text-xs font-semibold uppercase tracking-wide text-slate-400 dark:text-[hsl(0_0%_45%)] mb-3">Quick Answer — {currentYear} Crime Statistics</p>
      {allCrimes.length === 0 ? (
        <p class="text-sm text-slate-500 dark:text-[hsl(0_0%_60%)] leading-relaxed">
          Jamaica crime statistics are updated daily once the data pipeline is live. Check back soon.
        </p>
      ) : (
        <p class="text-sm text-slate-700 dark:text-[var(--ch-text-strong)] leading-relaxed">
          Jamaica has recorded <strong class="text-slate-900 dark:text-white">{totalCurrentYTD} crimes</strong> in {currentYear} as of {lastUpdated}, including <strong class="text-rose-600 dark:text-rose-400">{murderCount} murders</strong> (annualized rate: {murderRateProjected}/100k), {robberyCount} robberies, and {shootingCount} shootings.
          {previousYear} ended with a murder rate of <strong class="text-slate-900 dark:text-white">{murderRatePrevious} per 100,000</strong> — one of the highest in the Caribbean.
          {yoyDirection === 'up'
            ? `Crime in ${currentYear} is tracking ${Math.round(totalYoYChange)}% higher than the same period in ${previousYear}.`
            : yoyDirection === 'down'
              ? `Crime in ${currentYear} is tracking ${Math.round(Math.abs(totalYoYChange))}% lower than the same period in ${previousYear}.`
              : `Crime in ${currentYear} is tracking similar to the same period in ${previousYear}.`
          }
        </p>
      )}
    </section>

    <!-- Current Year Summary -->
    <section class="mb-10">
      <h2 class="text-body font-bold text-slate-500 dark:text-[var(--ch-text-muted)] mb-4">
        {currentYear} Year-to-Date Summary
      </h2>
      <p class="text-sm text-slate-500 dark:text-[hsl(0_0%_60%)] mb-4">
        {periodDescription}
      </p>
      <StatCards stats={statCardsData} />
    </section>

    <!-- Jamaica Crime Rate -->
    <section class="mb-10">
      <h2 class="text-body font-bold text-slate-500 dark:text-[var(--ch-text-muted)] mb-4">
        Jamaica Crime Rate {currentYear}
      </h2>
      <p class="text-sm text-slate-500 dark:text-[hsl(0_0%_60%)] mb-4">
        Crime rates per 100,000 population (based on ~2.8 million population)
      </p>

      <!-- Previous Year Final (Official Rate) -->
      <div class="mb-6">
        <h3 class="text-body font-bold text-slate-700 dark:text-[var(--ch-text)] mb-3">
          {previousYear} Final Crime Rate (Official)
        </h3>
        <div class="bg-white dark:bg-[var(--ch-surface)] rounded-lg border border-slate-200 dark:border-[hsl(0_0%_12%)] p-5 shadow-sm">
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <div class="text-center p-3 bg-slate-50 dark:bg-[var(--ch-surface-sub)] rounded-lg">
              <div class="text-xs text-slate-500 dark:text-[hsl(0_0%_60%)] font-medium mb-1">Murder Rate</div>
              <div class="text-2xl font-bold text-rose-600 dark:text-rose-400">{murderRatePrevious}</div>
              <div class="text-xs text-slate-400 dark:text-[var(--ch-text-faint)] mt-1">{murderCountPrevious} murders</div>
            </div>
            <div class="text-center p-3 bg-slate-50 dark:bg-[var(--ch-surface-sub)] rounded-lg">
              <div class="text-xs text-slate-500 dark:text-[hsl(0_0%_60%)] font-medium mb-1">Robbery Rate</div>
              <div class="text-2xl font-bold text-slate-700 dark:text-[var(--ch-text)]">{robberyRatePrevious}</div>
              <div class="text-xs text-slate-400 dark:text-[var(--ch-text-faint)] mt-1">{robberyCountPrevious} robberies</div>
            </div>
            <div class="text-center p-3 bg-slate-50 dark:bg-[var(--ch-surface-sub)] rounded-lg">
              <div class="text-xs text-slate-500 dark:text-[hsl(0_0%_60%)] font-medium mb-1">Overall Rate</div>
              <div class="text-2xl font-bold text-slate-700 dark:text-[var(--ch-text)]">{totalCrimeRatePrevious}</div>
              <div class="text-xs text-slate-400 dark:text-[var(--ch-text-faint)] mt-1">{totalCrimesPrevious} crimes</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Current Year Annualized Rate -->
      <div>
        <h3 class="text-body font-bold text-slate-700 dark:text-[var(--ch-text)] mb-3">
          {currentYear} Annualized Rate (at current pace)
        </h3>
        <div class="bg-white dark:bg-[var(--ch-surface)] rounded-lg border border-slate-200 dark:border-[hsl(0_0%_12%)] p-5 shadow-sm">
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <div class="text-center p-3 bg-rose-50 dark:bg-rose-950/30 rounded-lg">
              <div class="text-xs text-slate-500 dark:text-[hsl(0_0%_60%)] font-medium mb-1">Murder Rate</div>
              <div class="text-2xl font-bold text-rose-600 dark:text-rose-400">{murderRateProjected}</div>
              <div class="text-xs text-slate-400 dark:text-[var(--ch-text-faint)] mt-1">{murderCount} murders in {daysElapsed} days</div>
            </div>
            <div class="text-center p-3 bg-slate-50 dark:bg-[var(--ch-surface-sub)] rounded-lg">
              <div class="text-xs text-slate-500 dark:text-[hsl(0_0%_60%)] font-medium mb-1">Robbery Rate</div>
              <div class="text-2xl font-bold text-slate-700 dark:text-[var(--ch-text)]">{robberyRateProjected}</div>
              <div class="text-xs text-slate-400 dark:text-[var(--ch-text-faint)] mt-1">{robberyCount} robberies in {daysElapsed} days</div>
            </div>
            <div class="text-center p-3 bg-slate-50 dark:bg-[var(--ch-surface-sub)] rounded-lg">
              <div class="text-xs text-slate-500 dark:text-[hsl(0_0%_60%)] font-medium mb-1">Overall Rate</div>
              <div class="text-2xl font-bold text-slate-700 dark:text-[var(--ch-text)]">{totalCrimeRateProjected}</div>
              <div class="text-xs text-slate-400 dark:text-[var(--ch-text-faint)] mt-1">{totalCrimesCurrent} crimes in {daysElapsed} days</div>
            </div>
          </div>
          <p class="text-xs text-slate-500 dark:text-[hsl(0_0%_60%)] mt-3 text-center">
            Rates annualized from {daysElapsed} days of data ({lastUpdated}). Assumes current pace continues through year end.
          </p>
        </div>
      </div>

      <p class="text-xs text-slate-500 dark:text-[hsl(0_0%_60%)] mt-4">
        The Jamaica crime rate is calculated per 100,000 population to enable fair comparison with other countries and historical trends.
      </p>
    </section>

    <!-- Crime by Type -->
    <section class="mb-10">
      <h2 class="text-body font-bold text-slate-500 dark:text-[var(--ch-text-muted)] mb-4">
        Crime by Type ({currentYear})
      </h2>
      <div class="bg-white dark:bg-[var(--ch-surface)] rounded-lg border border-slate-200 dark:border-[hsl(0_0%_12%)] overflow-hidden shadow-sm">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="bg-slate-50 dark:bg-[var(--ch-surface-sub)] border-b border-slate-200 dark:border-[hsl(0_0%_12%)]">
              <tr>
                <th class="text-left px-4 py-3 font-semibold text-slate-700 dark:text-[var(--ch-text-strong)]">Crime Type</th>
                <th class="text-right px-4 py-3 font-semibold text-slate-700 dark:text-[var(--ch-text-strong)]">{currentYear} Count</th>
                <th class="text-right px-4 py-3 font-semibold text-slate-700 dark:text-[var(--ch-text-strong)]">{previousYear} (Same Period)</th>
                <th class="text-right px-4 py-3 font-semibold text-slate-700 dark:text-[var(--ch-text-strong)]">Change</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 dark:divide-[hsl(0_0%_12%)]">
              {yoyComparisons.filter(c => c.countCurrent > 0 || c.countPrevious > 0).length === 0 ? (
                <tr>
                  <td colspan="4" class="px-4 py-8 text-center text-sm text-slate-400 dark:text-[var(--ch-text-faint)]">
                    Data will appear here once the Jamaica pipeline is live.
                  </td>
                </tr>
              ) : (
                yoyComparisons.filter(c => c.countCurrent > 0 || c.countPrevious > 0).map(comparison => (
                  <tr class="hover:bg-slate-50 dark:hover:bg-[hsl(0_0%_10%)]">
                    <td class="px-4 py-3 text-slate-700 dark:text-[var(--ch-text-strong)] font-medium">{comparison.type}</td>
                    <td class="px-4 py-3 text-right text-slate-700 dark:text-[var(--ch-text-strong)]">{comparison.countCurrent}</td>
                    <td class="px-4 py-3 text-right text-slate-500 dark:text-[hsl(0_0%_60%)]">{comparison.countPrevious}</td>
                    <td class={`px-4 py-3 text-right font-medium ${comparison.direction === 'down' ? 'text-emerald-600 dark:text-emerald-400' : comparison.direction === 'up' ? 'text-rose-600 dark:text-rose-400' : 'text-slate-400 dark:text-[var(--ch-text-faint)]'}`}>
                      {comparison.direction === 'down' ? '↓' : comparison.direction === 'up' ? '↑' : '→'}
                      {formatPercentChange(comparison.percentChange)}
                    </td>
                  </tr>
                ))
              )}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Parish Breakdown -->
    <section class="mb-10">
      <h2 class="text-body font-bold text-slate-500 dark:text-[var(--ch-text-muted)] mb-4">
        Parish Breakdown ({currentYear})
      </h2>
      <p class="text-sm text-slate-500 dark:text-[hsl(0_0%_60%)] mb-4">
        Top 5 parishes by crime count
      </p>
      <div class="bg-white dark:bg-[var(--ch-surface)] rounded-lg border border-slate-200 dark:border-[hsl(0_0%_12%)] overflow-hidden shadow-sm">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="bg-slate-50 dark:bg-[var(--ch-surface-sub)] border-b border-slate-200 dark:border-[hsl(0_0%_12%)]">
              <tr>
                <th class="text-left px-4 py-3 font-semibold text-slate-700 dark:text-[var(--ch-text-strong)]">Parish</th>
                <th class="text-right px-4 py-3 font-semibold text-slate-700 dark:text-[var(--ch-text-strong)]">Crimes</th>
                <th class="text-right px-4 py-3 font-semibold text-slate-700 dark:text-[var(--ch-text-strong)]">% of Total</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 dark:divide-[hsl(0_0%_12%)]">
              {topRegions.length === 0 ? (
                <tr>
                  <td colspan="3" class="px-4 py-8 text-center text-sm text-slate-400 dark:text-[var(--ch-text-faint)]">
                    Parish data will appear here once the Jamaica pipeline is live.
                  </td>
                </tr>
              ) : (
                topRegions.map((region, index) => (
                  <tr class="hover:bg-slate-50 dark:hover:bg-[hsl(0_0%_10%)]">
                    <td class="px-4 py-3 text-slate-700 dark:text-[var(--ch-text-strong)]">
                      <span class="inline-flex items-center">
                        <span class="w-5 h-5 flex items-center justify-center bg-slate-100 dark:bg-[var(--ch-surface)] rounded text-xs font-medium text-slate-500 dark:text-[var(--ch-text-muted)] mr-2">
                          {index + 1}
                        </span>
                        {region.region}
                      </span>
                    </td>
                    <td class="px-4 py-3 text-right text-slate-700 dark:text-[var(--ch-text-strong)] font-medium">{region.count}</td>
                    <td class="px-4 py-3 text-right text-slate-500 dark:text-[hsl(0_0%_60%)]">{region.percentage.toFixed(1)}%</td>
                  </tr>
                ))
              )}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Download Data -->
    <section class="mb-10">
