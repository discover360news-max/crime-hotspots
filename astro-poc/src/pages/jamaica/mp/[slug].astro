---
/**
 * Jamaica MP Profile Page
 * Static profile for each Member of Parliament.
 * Generates 63 pages at /jamaica/mp/[nameSlug]/
 * Crime stats omitted until Jamaica D1 is configured.
 */

export const prerender = true;

import Layout from '../../../layouts/Layout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Hero from '../../../components/Hero.astro';
import mpsData from '../../../data/mps-jamaica.json';
import { sanitizeUrl } from '../../../lib/escapeHtml';
import { routes } from '../../../config/routes';

export function getStaticPaths() {
  return mpsData.map((mp) => ({
    params: { slug: mp.nameSlug },
    props: { mp },
  }));
}

const { mp } = Astro.props;

const displayName = mp.honorific ? `${mp.honorific} ${mp.fullName}` : mp.fullName;
const photoSrc = mp.photo ? `/images/mps/${mp.photo}` : '/images/mps/placeholder.svg';

const partyBadgeClass: Record<string, string> = {
  JLP: 'bg-green-50 dark:bg-green-950/30 text-green-700 dark:text-green-400',
  PNP: 'bg-orange-50 dark:bg-orange-950/30 text-orange-700 dark:text-orange-400',
};
const partyBadge = partyBadgeClass[mp.party] ?? 'bg-slate-100 dark:bg-[hsl(0_0%_15%)] text-slate-600 dark:text-[hsl(0_0%_65%)]';

const hasSocials = mp.socials.facebook || mp.socials.instagram || mp.socials.x || mp.socials.youtube || mp.socials.tiktok;

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Jamaica', href: routes.jamaica.dashboard },
  { label: 'MPs', href: routes.jamaica.mps },
  { label: mp.fullName },
];

const pageTitle = `${mp.fullName} MP — ${mp.constituency} | Crime Hotspots`;
const pageDescription = `${mp.fullName} is the MP for ${mp.constituency} (${mp.party}), Jamaica. Elected in ${mp.electionYear}.`;

const personSchema: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  'name': displayName,
  'jobTitle': 'Member of Parliament',
  'worksFor': {
    '@type': 'Organization',
    'name': 'Parliament of Jamaica',
    'url': 'https://www.japarliament.gov.jm',
  },
  'url': `https://crimehotspots.com/jamaica/mp/${mp.nameSlug}/`,
  ...(mp.contact.parliamentProfile ? { 'sameAs': [sanitizeUrl(mp.contact.parliamentProfile)] } : {}),
  ...(mp.contact.email ? { 'email': `mailto:${mp.contact.email}` } : {}),
  ...(mp.contact.phone ? { 'telephone': mp.contact.phone } : {}),
};
---

<Layout title={pageTitle} description={pageDescription} ogType="profile">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  </Fragment>

  <Hero
    compact
    narrowContainer={true}
    title={mp.fullName}
    subtitle={`MP for ${mp.constituency}`}
    badge={`${mp.partyFull} · Elected ${mp.electionYear}`}
    primaryCTA={{ text: 'All MPs', href: routes.jamaica.mps, icon: 'arrow' }}
  >
    <Breadcrumbs items={breadcrumbs} slot="before" />
  </Hero>

  <main class="max-w-3xl mx-auto px-4 sm:px-6 py-5" data-pagefind-body>

    <!-- 2-column profile + contact card -->
    <div class="mt-2 bg-white dark:bg-[var(--ch-surface-sub)] rounded-lg border border-slate-200 dark:border-[var(--ch-border-card)] overflow-hidden">
      <div class="grid grid-cols-1 sm:grid-cols-2">

        <!-- Left: image -->
        <div class="relative sm:border-r border-slate-100 dark:border-[var(--ch-border-subtle)] min-h-[500px] bg-slate-100 dark:bg-[hsl(0_0%_15%)]">
          <img
            src={photoSrc}
            alt={mp.photo ? `${mp.fullName}, MP for ${mp.constituency}` : ''}
            class="absolute inset-0 w-full h-full object-cover"
            loading="lazy"
          />
        </div>

        <!-- Right: identity + contact -->
        <section class="border-t sm:border-t-0 border-slate-100 dark:border-[var(--ch-border-subtle)] divide-y divide-slate-100 dark:divide-[hsl(0_0%_15%)]" aria-label="Contact information">

          <!-- Identity row -->
          <div class="px-4 py-3">
            <h2 class="text-base font-bold text-slate-800 dark:text-[hsl(0_0%_95%)] leading-tight">{displayName}</h2>
            <p class="text-sm text-slate-500 dark:text-[hsl(0_0%_60%)] mt-0.5">{mp.constituency}</p>
            <div class="flex flex-wrap items-center gap-2 mt-2">
              <span class={`px-2 py-0.5 rounded-full text-xs font-medium ${partyBadge}`}>{mp.party}</span>
              <span class="text-xs text-slate-400 dark:text-[var(--ch-text-faint)]">MP since {mp.electionYear}</span>
            </div>
          </div>

          {mp.contact.email && (
            <div class="flex items-start gap-3 px-4 py-3">
              <svg class="w-4 h-4 mt-0.5 shrink-0 text-slate-400 dark:text-[hsl(0_0%_45%)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              <div class="min-w-0">
                <div class="text-xs text-slate-400 dark:text-[hsl(0_0%_45%)] mb-0.5">Email</div>
                <a href={`mailto:${mp.contact.email}`} class="text-sm text-slate-700 dark:text-[hsl(0_0%_80%)] hover:text-rose-600 dark:hover:text-rose-400 transition break-all">{mp.contact.email}</a>
              </div>
            </div>
          )}

          {mp.contact.emailAlt && (
            <div class="flex items-start gap-3 px-4 py-3">
              <svg class="w-4 h-4 mt-0.5 shrink-0 text-slate-400 dark:text-[hsl(0_0%_45%)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              <div class="min-w-0">
                <div class="text-xs text-slate-400 dark:text-[hsl(0_0%_45%)] mb-0.5">Email (Personal)</div>
                <a href={`mailto:${mp.contact.emailAlt}`} class="text-sm text-slate-700 dark:text-[hsl(0_0%_80%)] hover:text-rose-600 dark:hover:text-rose-400 transition break-all">{mp.contact.emailAlt}</a>
              </div>
            </div>
          )}

          {mp.contact.phone && (
            <div class="flex items-start gap-3 px-4 py-3">
              <svg class="w-4 h-4 mt-0.5 shrink-0 text-slate-400 dark:text-[hsl(0_0%_45%)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              <div class="min-w-0">
                <div class="text-xs text-slate-400 dark:text-[hsl(0_0%_45%)] mb-0.5">Phone</div>
                <span class="text-sm text-slate-700 dark:text-[hsl(0_0%_80%)]">{mp.contact.phone}</span>
              </div>
            </div>
          )}

          {mp.contact.whatsapp && (
            <div class="flex items-start gap-3 px-4 py-3">
              <svg class="w-4 h-4 mt-0.5 shrink-0 text-slate-400 dark:text-[hsl(0_0%_45%)]" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              <div class="min-w-0">
                <div class="text-xs text-slate-400 dark:text-[hsl(0_0%_45%)] mb-0.5">WhatsApp</div>
                <a href={`https://wa.me/${mp.contact.whatsapp.replace(/\D/g, '')}`} target="_blank" rel="noopener noreferrer" class="text-sm text-slate-700 dark:text-[hsl(0_0%_80%)] hover:text-rose-600 dark:hover:text-rose-400 transition">{mp.contact.whatsapp}</a>
              </div>
            </div>
          )}

          {mp.contact.office && (
            <div class="flex items-start gap-3 px-4 py-3">
              <svg class="w-4 h-4 mt-0.5 shrink-0 text-slate-400 dark:text-[hsl(0_0%_45%)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              <div class="min-w-0">
                <div class="text-xs text-slate-400 dark:text-[hsl(0_0%_45%)] mb-0.5">Office</div>
                <span class="text-sm text-slate-700 dark:text-[hsl(0_0%_80%)]">{mp.contact.office}</span>
              </div>
            </div>
          )}

          {mp.contact.parliamentProfile && (
            <div class="flex items-start gap-3 px-4 py-3">
              <svg class="w-4 h-4 mt-0.5 shrink-0 text-slate-400 dark:text-[hsl(0_0%_45%)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
              <div class="min-w-0">
                <div class="text-xs text-slate-400 dark:text-[hsl(0_0%_45%)] mb-0.5">Parliament Profile</div>
                <a href={sanitizeUrl(mp.contact.parliamentProfile)} target="_blank" rel="noopener noreferrer" class="text-sm text-slate-700 dark:text-[hsl(0_0%_80%)] hover:text-rose-600 dark:hover:text-rose-400 transition">View on japarliament.gov.jm ↗</a>
              </div>
            </div>
          )}

          {mp.website && (
            <div class="flex items-start gap-3 px-4 py-3">
              <svg class="w-4 h-4 mt-0.5 shrink-0 text-slate-400 dark:text-[hsl(0_0%_45%)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>
              <div class="min-w-0">
                <div class="text-xs text-slate-400 dark:text-[hsl(0_0%_45%)] mb-0.5">Website</div>
                <a href={sanitizeUrl(mp.website)} target="_blank" rel="noopener noreferrer" class="text-sm text-slate-700 dark:text-[hsl(0_0%_80%)] hover:text-rose-600 dark:hover:text-rose-400 transition break-all">{mp.website}</a>
              </div>
            </div>
          )}

          {hasSocials && (
            <div class="flex items-center gap-3 px-4 py-3">
              <svg class="w-4 h-4 shrink-0 text-slate-400 dark:text-[hsl(0_0%_45%)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
              <div class="flex items-center gap-3">
                {mp.socials.facebook && (
                  <a href={sanitizeUrl(mp.socials.facebook)} target="_blank" rel="noopener noreferrer" class="text-slate-400 dark:text-[hsl(0_0%_45%)] hover:text-rose-600 dark:hover:text-rose-400 transition" aria-label="Facebook" title="Facebook">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                  </a>
                )}
                {mp.socials.instagram && (
                  <a href={sanitizeUrl(mp.socials.instagram)} target="_blank" rel="noopener noreferrer" class="text-slate-400 dark:text-[hsl(0_0%_45%)] hover:text-rose-600 dark:hover:text-rose-400 transition" aria-label="Instagram" title="Instagram">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                  </a>
                )}
                {mp.socials.x && (
                  <a href={sanitizeUrl(mp.socials.x)} target="_blank" rel="noopener noreferrer" class="text-slate-400 dark:text-[hsl(0_0%_45%)] hover:text-rose-600 dark:hover:text-rose-400 transition" aria-label="X (Twitter)" title="X (Twitter)">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                  </a>
                )}
                {mp.socials.youtube && (
                  <a href={sanitizeUrl(mp.socials.youtube)} target="_blank" rel="noopener noreferrer" class="text-slate-400 dark:text-[hsl(0_0%_45%)] hover:text-rose-600 dark:hover:text-rose-400 transition" aria-label="YouTube" title="YouTube">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                  </a>
                )}
                {mp.socials.tiktok && (
                  <a href={sanitizeUrl(mp.socials.tiktok)} target="_blank" rel="noopener noreferrer" class="text-slate-400 dark:text-[hsl(0_0%_45%)] hover:text-rose-600 dark:hover:text-rose-400 transition" aria-label="TikTok" title="TikTok">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
                  </a>
                )}
              </div>
            </div>
          )}

        </section>
      </div>
    </div>

    <!-- Crime data placeholder (pending Jamaica D1) -->
    <div class="mt-8 flex items-start gap-2.5 p-4 rounded-lg bg-slate-50 dark:bg-[var(--ch-surface)] border border-slate-200 dark:border-[var(--ch-border-card)]">
      <svg class="w-4 h-4 mt-0.5 shrink-0 text-slate-400 dark:text-[hsl(0_0%_45%)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p class="text-sm text-slate-500 dark:text-[var(--ch-text-muted)]">
        Crime statistics for this constituency will appear here once the Jamaica data pipeline is live.
        <a href={routes.jamaica.dashboard} class="ml-1 text-rose-600 dark:text-rose-400 hover:underline">View dashboard</a>
      </p>
    </div>

  </main>
</Layout>
