---
/**
 * Jamaica Individual Crime Page — SSR + Cloudflare CDN 24h cache
 * Route: /jamaica/crime/[slug]
 *
 * Mirrors /trinidad/crime/[slug].astro but uses JM_DB.
 * Differences from T&T:
 *  - env.JM_DB binding
 *  - No idRedirectOverrides (Jamaica DB is clean — no dedup yet)
 *  - Jamaica area aliases loaded from baked JSON, not CSV fetch
 *  - TrendingHotspots omitted (hardcoded T&T area/region routes)
 *  - No archive breadcrumb (C5 not built yet)
 *  - addressCountry: "JM" in structured data
 */

import Layout from '../../../layouts/Layout.astro';
import { getAllCrimesFromD1, type Crime } from '../../../lib/crimeData';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import ReportIssueModal from '../../../components/ReportIssueModal.astro';
import AreaNameTooltip from '../../../components/AreaNameTooltip.astro';
import SafetyContext from '../../../components/SafetyContext.astro';
import FeedbackToggle from '../../../components/FeedbackToggle.astro';
import RelatedCrimes from '../../../components/RelatedCrimes.astro';
import CompactTipCard from '../../../components/CompactTipCard.astro';
import CrimeLocationMap from '../../../components/CrimeLocationMap.astro';
import { getLocalName } from '../../../lib/areaAliases';
import { getSafetyContext } from '../../../lib/safetyHelpers';
import { getCrimeTypeThumbnailUrl } from '../../../lib/generateCrimeTypeThumbnails';
import { getCollection } from 'astro:content';
import { normalizedCrimeType, sortTipsByAreaRelevance } from '../../../lib/safetyTipsHelpers';
import { routes } from '../../../config/routes';
import jamaicaAliasesJson from '../../../data/area-aliases-jamaica.json';
import { env } from 'cloudflare:workers';

const { slug } = Astro.params;
const db = env.JM_DB as D1Database | undefined;
const allCrimes = db ? await getAllCrimesFromD1(db) : [];
const crime = allCrimes.find(c => c.slug === slug);

// Fallback: check oldSlug → 301
if (!crime) {
  const redirect = allCrimes.find(c => c.oldSlug === slug);
  if (redirect) {
    return Astro.redirect(`/jamaica/crime/${redirect.slug}/`, 301);
  }
}

// Fuzzy fallback: strip leading digits and match on word portion
if (!crime && slug && /^\d+-/.test(slug)) {
  const slugWords = slug.replace(/^\d+-/, '');
  const fuzzyMatch = allCrimes.find(c => c.slug.replace(/^\d+-/, '') === slugWords);
  if (fuzzyMatch) {
    return Astro.redirect(`/jamaica/crime/${fuzzyMatch.slug}/`, 301);
  }
}

if (!crime) {
  Astro.response.status = 404;
}

// Prev/next navigation
const sortedCrimes = crime ? [...allCrimes].sort((a, b) => b.dateObj.getTime() - a.dateObj.getTime()) : [];
const crimeIndex = crime ? sortedCrimes.findIndex(c => c.slug === slug) : -1;
const prevCrime = crimeIndex > 0 ? sortedCrimes[crimeIndex - 1] : null;
const nextCrime = crimeIndex > -1 && crimeIndex < sortedCrimes.length - 1 ? sortedCrimes[crimeIndex + 1] : null;

// Jamaica area aliases (baked JSON — no network fetch needed)
const jamaicaAliasMap = new Map(Object.entries(jamaicaAliasesJson));
const localName = crime ? getLocalName(jamaicaAliasMap, crime.area) : '';

// Safety context
const safetyContext = crime ? getSafetyContext(crime.area, allCrimes, crime.primaryCrimeType || crime.crimeType) : null;

// CDN cache only for valid pages
if (crime) {
  Astro.response.headers.set('CDN-Cache-Control', 'max-age=86400');
  Astro.response.headers.set('Cache-Control', 'public, max-age=3600, must-revalidate');
}

const truncatedHeadline = crime
  ? crime.headline.split(' ').slice(0, 5).join(' ') + (crime.headline.split(' ').length > 5 ? '...' : '')
  : '';

// Safety tips matched by crime type + area
let matchedTips: Awaited<ReturnType<typeof getCollection<'tips'>>> = [];
if (crime) {
  const tipCategory = normalizedCrimeType(crime.primaryCrimeType || crime.crimeType);
  const allTips = await getCollection('tips', ({ data }) =>
    data.status === 'published' && data.category === tipCategory
  );
  matchedTips = sortTipsByAreaRelevance(allTips, crime.area).slice(0, 3);
}

const thumbnailPath = crime ? getCrimeTypeThumbnailUrl(crime.crimeType, '') : '';

// Crime type chip counts
const primaryType = crime ? (crime.primaryCrimeType || crime.crimeType) : '';
let primaryTotalCount = 1;
const relatedTypeCounts = new Map<string, number>();
if (crime?.relatedCrimeTypes?.trim()) {
  for (const t of crime.relatedCrimeTypes.split(',').map(t => t.trim()).filter(Boolean)) {
    if (t === primaryType) {
      primaryTotalCount++;
    } else {
      relatedTypeCounts.set(t, (relatedTypeCounts.get(t) ?? 0) + 1);
    }
  }
}

// Incident composition summary
let incidentSummaryText: string | null = null;
if (crime && (relatedTypeCounts.size > 0 || primaryTotalCount > 1)) {
  const allCounts = new Map(relatedTypeCounts);
  if (primaryType === 'Murder') {
    allCounts.set('Murder', (allCounts.get('Murder') ?? 0) + primaryTotalCount);
  } else if (primaryType === 'Attempted Murder') {
    allCounts.set('Attempted Murder', (allCounts.get('Attempted Murder') ?? 0) + primaryTotalCount);
  }
  const killed = allCounts.get('Murder') ?? 0;
  const injured = allCounts.get('Attempted Murder') ?? 0;
  if (killed > 0 || injured > 0) {
    const total = [...allCounts.values()].reduce((a, b) => a + b, 0);
    const parts: string[] = [];
    if (killed > 0) parts.push(`${killed} killed`);
    if (injured > 0) parts.push(`${injured} injured`);
    incidentSummaryText = `${total} ${total === 1 ? 'person' : 'people'} involved — ${parts.join(' · ')}`;
  }
}

// SEO
const pageAbsoluteUrl = `https://crimehotspots.com/jamaica/crime/${slug}/`;

function buildCrimeDescription(summary: string, area: string, crimeType: string, date: string): string {
  const base = summary || `${crimeType} in ${area} on ${date}. View details, location, and related crimes.`;
  const MAX = 155;
  const prefix = `${area} — `;
  const budget = MAX - prefix.length;
  let firstSentence = base;
  const periodIdx = base.indexOf('. ');
  if (periodIdx !== -1 && periodIdx + 1 <= budget) {
    firstSentence = base.slice(0, periodIdx + 1);
  } else if (base.length > budget) {
    firstSentence = base.slice(0, budget).trimEnd() + '…';
  }
  return prefix + firstSentence;
}

const title = crime ? `${crime.headline} | Crime Hotspots Jamaica` : 'Story Not Found | Crime Hotspots Jamaica';
const description = crime
  ? buildCrimeDescription(crime.summary, crime.area, crime.crimeType, crime.date)
  : 'This story may have been updated or removed. Browse our latest Jamaica crime reports.';
const ogImage = crime ? getCrimeTypeThumbnailUrl(crime.crimeType) : undefined;
---

{crime ? (
<Layout title={title} description={description} ogImage={ogImage} ogType="article" includeLeaflet={true}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "NewsArticle",
    "headline": crime.headline,
    "datePublished": (crime.datePublished ?? crime.dateObj).toISOString(),
    "dateModified": (crime.dateUpdated ?? crime.datePublished ?? crime.dateObj).toISOString(),
    "articleSection": crime.crimeType,
    "keywords": [crime.crimeType, crime.area, crime.region, "crime jamaica", "jamaica news"].filter(Boolean).join(", "),
    "mainEntityOfPage": { "@type": "WebPage", "@id": pageAbsoluteUrl },
    "image": getCrimeTypeThumbnailUrl(crime.crimeType),
    "locationCreated": {
      "@type": "Place",
      "name": crime.area,
      "address": { "@type": "PostalAddress", "addressRegion": crime.region, "addressCountry": "JM" }
    },
    "description": crime.summary,
    "url": pageAbsoluteUrl,
    "author": crime.source
      ? { "@type": "NewsMediaOrganization", "name": crime.source, ...(crime.url ? { "url": crime.url } : {}) }
      : { "@type": "Organization", "name": "Crime Hotspots", "url": "https://crimehotspots.com" },
    "publisher": {
      "@type": "Organization",
      "name": "Crime Hotspots",
      "url": "https://crimehotspots.com",
      "logo": { "@type": "ImageObject", "url": "https://crimehotspots.com/og-image.jpg" }
    }
  })} />

  <main class="max-w-4xl mx-auto px-4 sm:px-6 py-5">

    <Breadcrumbs items={[
      { label: 'Home', href: routes.home },
      { label: 'Jamaica', href: routes.jamaica.dashboard },
      { label: 'Headlines', href: routes.jamaica.headlines },
      { label: truncatedHeadline }
    ]} />

    <header class="mt-4 mb-5">
      {(relatedTypeCounts.size > 0 || incidentSummaryText) ? (
        <div class="mb-4 p-3 rounded-xl bg-white/85 dark:bg-[hsl(0_0%_100%_/_0.04)] backdrop-blur-md border border-slate-200/80 dark:border-[hsl(0_0%_100%_/_0.08)]" data-pagefind-ignore>
          <div class="flex flex-wrap items-center gap-1.5">
            <span class="inline-flex items-center px-3 py-1 rounded-full bg-rose-600 text-white text-xs font-semibold uppercase tracking-wide">
              {crime.crimeType}{primaryTotalCount > 1 && <span class="ml-1 opacity-70 font-normal">×{primaryTotalCount}</span>}
            </span>
            {[...relatedTypeCounts.entries()].map(([type, count]) => (
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-slate-200 dark:bg-[hsl(0_0%_20%)] text-slate-600 dark:text-[var(--ch-text-strong)] text-xs font-medium">
                {type}{count > 1 && <span class="ml-1 opacity-50 font-normal">×{count}</span>}
              </span>
            ))}
          </div>
          {incidentSummaryText && (
            <p class="mt-2 text-xs text-slate-500 dark:text-[var(--ch-text-muted)]">{incidentSummaryText}</p>
          )}
        </div>
      ) : (
        <div class="mb-2" data-pagefind-ignore>
          <span class="inline-flex items-center px-3 py-1 rounded-full bg-rose-600 text-white text-xs font-semibold uppercase tracking-wide">
            {crime.crimeType}
          </span>
        </div>
      )}

      <h1 class="text-2xl sm:text-3xl font-black text-slate-800 dark:text-[var(--ch-text-heading)] leading-tight mb-3">
        {crime.headline}
      </h1>

      <div class="flex flex-wrap items-center gap-x-2 gap-y-1 text-xs text-slate-500 dark:text-[var(--ch-text-muted)]" data-pagefind-ignore>
        <time datetime={crime.dateObj.toISOString()}>
          {crime.dateObj.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <span class="text-slate-300 dark:text-[hsl(0_0%_30%)]">&middot;</span>
        <span>
          {crime.street ? `${crime.street}, ` : ''}<AreaNameTooltip area={crime.area} localName={localName} />
          {crime.region && crime.area !== crime.region ? `, ${crime.region}` : ''}
        </span>
        {crime.source && (
          <>
            <span class="text-slate-300 dark:text-[hsl(0_0%_30%)]">&middot;</span>
            {crime.url ? (
              <a href={crime.url} target="_blank" rel="noopener"
                class="hover:text-rose-600 dark:hover:text-rose-400 border-b border-dotted border-slate-300 dark:border-[hsl(0_0%_40%)] hover:border-rose-600 dark:hover:border-rose-400 transition">
                {crime.source}
              </a>
            ) : (
              <span>{crime.source}</span>
            )}
          </>
        )}
      </div>
    </header>

    <div class="mb-5 rounded-xl overflow-hidden bg-slate-100 dark:bg-[hsl(0_0%_12%)]" data-pagefind-ignore>
      <CrimeLocationMap
        latitude={crime.latitude}
        longitude={crime.longitude}
        crimeType={crime.primaryCrimeType || crime.crimeType}
        hasStreet={!!crime.street}
      />
    </div>

    <!-- Nav row -->
    <div class="flex items-center gap-2 mb-4 flex-wrap" data-pagefind-ignore>
      <a href={routes.jamaica.dashboard}
        class="px-4 py-1.5 min-h-[32px] flex items-center justify-center border border-slate-300 dark:border-[hsl(0_0%_30%)] text-slate-600 dark:text-[var(--ch-text-strong)] hover:border-rose-600 dark:hover:border-rose-500 hover:text-rose-600 dark:hover:text-rose-400 rounded-lg transition font-medium text-xs whitespace-nowrap">
        Dashboard
      </a>
      <a href={routes.jamaica.headlines}
        class="px-4 py-1.5 min-h-[32px] flex items-center justify-center border border-slate-300 dark:border-[hsl(0_0%_30%)] text-slate-600 dark:text-[var(--ch-text-strong)] hover:border-rose-600 dark:hover:border-rose-500 hover:text-rose-600 dark:hover:text-rose-400 rounded-lg transition font-medium text-xs whitespace-nowrap">
        Headlines
      </a>
      <a href={routes.trinidad.safetyTips}
        class="px-4 py-1.5 min-h-[32px] flex items-center justify-center border border-slate-300 dark:border-[hsl(0_0%_30%)] text-slate-600 dark:text-[var(--ch-text-strong)] hover:border-rose-600 dark:hover:border-rose-500 hover:text-rose-600 dark:hover:text-rose-400 rounded-lg transition font-medium text-xs whitespace-nowrap">
        Safety Tips
      </a>
    </div>

    <!-- Article body + sidebar -->
    <div class="lg:grid lg:grid-cols-[1fr_256px] lg:gap-8 lg:items-start mt-4">

      <article>
        {crime.summary && (
          <p class="text-body text-slate-700 dark:text-[var(--ch-text-strong)] leading-relaxed whitespace-pre-line mb-6">
            {crime.summary.replace(/\|\|/g, '\n\n')}
          </p>
        )}

        <!-- Report Issue -->
        <div class="mb-6 p-4 bg-white dark:bg-[var(--ch-surface)] rounded-lg border border-slate-200 dark:border-[var(--ch-border-card)]" data-pagefind-ignore>
          <div class="mb-3">
            <p class="text-sm font-bold text-slate-700 dark:text-[var(--ch-text-heading)]">Found incorrect information?</p>
            <p class="text-xs text-slate-500 dark:text-[var(--ch-text-muted)] mt-1">Help us keep our data accurate by reporting issues.</p>
          </div>
          <div class="flex gap-2 flex-wrap">
            <ReportIssueModal
              showButton={true}
              crimeSlug={crime.slug}
              crimeHeadline={crime.headline}
              crimeDate={crime.date}
              crimeType={crime.crimeType}
              crimeArea={crime.area}
              crimeRegion={crime.region}
              crimeStreet={crime.street}
              crimeSummary={crime.summary}
              crimeSource={crime.source}
              crimeUrl={crime.url}
            />
            <a href={routes.report}
              class="px-4 py-1.5 min-h-[22px] flex items-center justify-center gap-2 border-2 border-slate-300 dark:border-[hsl(0_0%_30%)] text-slate-700 dark:text-[var(--ch-text-strong)] hover:border-rose-600 dark:hover:border-rose-500 hover:text-rose-600 dark:hover:text-rose-400 active:bg-rose-50 dark:active:bg-rose-950/40 rounded-lg transition font-medium text-xs whitespace-nowrap">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
              </svg>
              Report a Crime
            </a>
          </div>
        </div>

        {safetyContext && (
          <SafetyContext
            areaName={crime.area}
            score={safetyContext.score}
            level={safetyContext.level}
            tip={safetyContext.tip}
            positiveNote={safetyContext.positiveNote}
            primaryCrimeType={safetyContext.primaryCrimeType}
          />
        )}

        {matchedTips.length > 0 && (
          <div class="mt-4 mb-6 bg-white dark:bg-[var(--ch-surface)] border border-slate-200 dark:border-[var(--ch-border-card)] rounded-lg p-4">
            <div class="flex items-center justify-between mb-3">
              <h3 class="text-xs font-bold text-slate-700 dark:text-[hsl(0_0%_88%)] uppercase tracking-wider">Safety Tips</h3>
              <a href="/safety-tips/" class="text-caption text-rose-600 dark:text-rose-400 hover:underline">View all →</a>
            </div>
            {matchedTips.map(tip => <CompactTipCard tip={tip} />)}
          </div>
        )}

        <FeedbackToggle
          areaName={crime.area}
          pageUrl={pageAbsoluteUrl}
          pageTitle={crime.headline}
        />

        <!-- Prev/Next navigation -->
        {(prevCrime || nextCrime) && (
          <nav class="mt-6 grid grid-cols-2 gap-4" aria-label="Crime navigation">
            <div class="text-left">
              {prevCrime && (
                <a href={`/jamaica/crime/${prevCrime.slug}/`}
                  class="block p-4 bg-white dark:bg-[var(--ch-surface)] rounded-lg shadow-sm border border-slate-200 dark:border-[var(--ch-border-card)] hover:border-rose-600 dark:hover:border-rose-700 active:bg-rose-50 dark:active:bg-rose-950/40 transition group">
                  <div class="text-xs text-slate-500 dark:text-[var(--ch-text-muted)] mb-1">&larr; Previous Crime</div>
                  <div class="text-sm font-medium text-slate-700 dark:text-[hsl(0_0%_88%)] group-hover:text-rose-600 dark:group-hover:text-rose-400 transition line-clamp-2">{prevCrime.headline}</div>
                  <div class="text-xs text-slate-500 dark:text-[var(--ch-text-muted)] mt-1">
                    {prevCrime.dateObj.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                  </div>
                </a>
              )}
            </div>
            <div class="text-right">
              {nextCrime && (
                <a href={`/jamaica/crime/${nextCrime.slug}/`}
                  class="block p-4 bg-white dark:bg-[var(--ch-surface)] rounded-lg shadow-sm border border-slate-200 dark:border-[var(--ch-border-card)] hover:border-rose-600 dark:hover:border-rose-700 active:bg-rose-50 dark:active:bg-rose-950/40 transition group">
                  <div class="text-xs text-slate-500 dark:text-[var(--ch-text-muted)] mb-1">Next Crime &rarr;</div>
                  <div class="text-sm font-medium text-slate-700 dark:text-[hsl(0_0%_88%)] group-hover:text-rose-600 dark:group-hover:text-rose-400 transition line-clamp-2">{nextCrime.headline}</div>
                  <div class="text-xs text-slate-500 dark:text-[var(--ch-text-muted)] mt-1">
                    {nextCrime.dateObj.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                  </div>
                </a>
              )}
            </div>
          </nav>
        )}
      </article>

      <!-- Sidebar -->
      <aside class="mt-8 lg:mt-0 space-y-4" data-pagefind-ignore>

        <!-- Share -->
        <div class="p-4 bg-white dark:bg-[var(--ch-surface)] rounded-lg border border-slate-200 dark:border-[var(--ch-border-card)]">
          <p class="text-xs font-bold text-slate-500 dark:text-[var(--ch-text-muted)] uppercase tracking-wide mb-3">Share this report</p>
          <div class="flex gap-2">
            <button id="shareTwitterBtn" class="flex-1 p-2.5 rounded-lg border border-slate-300 dark:border-[var(--ch-border)] text-slate-600 dark:text-[hsl(0_0%_65%)] hover:bg-slate-50 dark:hover:bg-[hsl(0_0%_12%)] active:bg-slate-100 dark:active:bg-[hsl(0_0%_15%)] transition" title="Share on X" aria-label="Share on X">
              <svg class="w-4 h-4 mx-auto" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </button>
            <button id="shareFacebookBtn" class="flex-1 p-2.5 rounded-lg border border-slate-300 dark:border-[var(--ch-border)] text-slate-600 dark:text-[hsl(0_0%_65%)] hover:bg-slate-50 dark:hover:bg-[hsl(0_0%_12%)] active:bg-slate-100 dark:active:bg-[hsl(0_0%_15%)] transition" title="Share on Facebook" aria-label="Share on Facebook">
              <svg class="w-4 h-4 mx-auto" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </button>
            <button id="shareWhatsAppBtn" class="flex-1 p-2.5 rounded-lg border border-slate-300 dark:border-[var(--ch-border)] text-slate-600 dark:text-[hsl(0_0%_65%)] hover:bg-slate-50 dark:hover:bg-[hsl(0_0%_12%)] active:bg-slate-100 dark:active:bg-[hsl(0_0%_15%)] transition" title="Share on WhatsApp" aria-label="Share on WhatsApp">
              <svg class="w-4 h-4 mx-auto" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
            </button>
          </div>
        </div>

        <RelatedCrimes
          currentCrime={crime}
          allCrimes={allCrimes}
          maxCards={5}
          crimePath="/jamaica/crime/"
        />

        <!-- Support -->
        <div class="p-4 bg-white dark:bg-[var(--ch-surface)] rounded-lg border border-slate-200 dark:border-[var(--ch-border-card)]">
          <p class="text-sm font-bold text-slate-700 dark:text-[var(--ch-text-heading)] mb-1">Support this project</p>
          <p class="text-xs text-slate-500 dark:text-[var(--ch-text-muted)] mb-3">Free, ad-free, and independent. Help keep it that way.</p>
          <a href="https://ko-fi.com/crimehotspots" target="_blank" rel="noopener noreferrer"
            class="px-4 py-1.5 min-h-[22px] inline-flex items-center gap-2 border-2 border-slate-300 dark:border-[hsl(0_0%_30%)] text-slate-700 dark:text-[var(--ch-text-strong)] hover:border-amber-400 dark:hover:border-amber-600 hover:text-amber-700 dark:hover:text-amber-400 active:bg-amber-50 dark:active:bg-amber-950/40 rounded-lg transition font-medium text-xs whitespace-nowrap">
            <svg class="w-4 h-4 text-amber-500" viewBox="0 0 24 24" fill="currentColor"><path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
            Support the Project
          </a>
        </div>

      </aside>
    </div>

  </main>
</Layout>
) : (
<Layout title={title} description={description}>
  <div class="min-h-screen flex items-center justify-center px-4 py-16">
    <div class="max-w-2xl w-full text-center">
      <h1 class="text-9xl font-bold text-rose-600 mb-4">404</h1>
      <h2 class="text-display font-bold text-slate-700 dark:text-[var(--ch-text)] mb-4">Story Not Found</h2>
      <p class="text-xs text-slate-500 dark:text-[var(--ch-text-muted)] mb-8">
        This story may have been updated or removed. Browse our latest Jamaica crime reports.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href={routes.jamaica.headlines}
          class="inline-flex items-center gap-2 px-6 py-3 bg-rose-600 text-white rounded-lg hover:bg-rose-700 active:bg-rose-800 transition font-medium text-xs">
          Browse Headlines
        </a>
        <a href={routes.jamaica.statistics}
          class="inline-flex items-center gap-2 px-6 py-3 border border-rose-600 text-rose-600 rounded-lg hover:bg-rose-50 dark:hover:bg-rose-950/40 active:bg-rose-100 dark:active:bg-rose-950/60 transition font-medium text-xs">
          Statistics Page
        </a>
      </div>
    </div>
  </div>
</Layout>
)}

<script define:vars={{ crimeHeadline: crime?.headline ?? '', crimeSlug: crime?.slug ?? '' }}>
  document.addEventListener('DOMContentLoaded', () => {
    const pageUrl = `https://crimehotspots.com/jamaica/crime/${crimeSlug}/`;

    document.getElementById('shareTwitterBtn')?.addEventListener('click', () => {
      window.open(`https://twitter.com/intent/tweet?text=${encodeURIComponent(crimeHeadline)}&url=${encodeURIComponent(pageUrl)}`, '_blank', 'width=550,height=420');
    });
    document.getElementById('shareFacebookBtn')?.addEventListener('click', () => {
      window.open(`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(pageUrl)}`, '_blank', 'width=550,height=420');
    });
    document.getElementById('shareWhatsAppBtn')?.addEventListener('click', () => {
      window.open(`https://wa.me/?text=${encodeURIComponent(`${crimeHeadline} - ${pageUrl}`)}`, '_blank');
    });
  });
</script>
