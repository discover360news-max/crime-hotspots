---
/**
 * Jamaica Area Detail Page
 * Individual area crime statistics with risk level, headlines, and breakdown.
 * Target keywords: "crime in {area} jamaica", "{area} crime statistics", "is {area} safe"
 */

import Layout from '../../../layouts/Layout.astro';
import GradientStatCard from '../../../components/GradientStatCard.astro';
import StatCards from '../../../components/StatCards.astro';
import DataTable from '../../../components/DataTable.astro';
import SafetyContext from '../../../components/SafetyContext.astro';
import FeedbackToggle from '../../../components/FeedbackToggle.astro';
import NewsletterSignup from '../../../components/NewsletterSignup.astro';
import AreaNarrative from '../../../components/AreaNarrative.astro';
import MPSidebar from '../../../components/MPSidebar.astro';
import SocialProofStrip from '../../../components/SocialProofStrip.astro';
import DarkHero from '../../../components/DarkHero.astro';
import { getAllCrimesFromD1, getCrimesByAreaFromD1, generateNameSlug } from '../../../lib/crimeData';
import { loadFullJamaicaAreaData } from '../../../lib/areaAliases';
import { getSafetyContext } from '../../../lib/safetyHelpers';
import { countCrimeType } from '../../../lib/dashboardHelpers';
import {
  TRACKED_CRIME_TYPES,
  calculatePercentChange,
  filterToSamePeriod,
  getTotalCrimeCount,
} from '../../../lib/statisticsHelpers';
import { escapeHtml } from '../../../lib/escapeHtml';
import { routes, buildRoute } from '../../../config/routes';
import mpsJamaicaData from '../../../data/mps-jamaica.json';

const { slug } = Astro.params;

// Resolve slug → area metadata
const areaData = await loadFullJamaicaAreaData();
const areaInfo = areaData.find(a => generateNameSlug(a.area) === slug);

if (!areaInfo) {
  return Astro.redirect('/jamaica/parishes/', 302);
}

const { area: areaName, region: parishName, division, knownAs } = areaInfo;

Astro.response.headers.set('CDN-Cache-Control', 'max-age=82800');
Astro.response.headers.set('Cache-Control', 'public, max-age=3600, must-revalidate');

import { env } from 'cloudflare:workers';
const jmDb = env.JM_DB as D1Database | undefined;

if (!jmDb) {
  return Astro.redirect('/jamaica/parishes/', 302);
}

const allCrimes = await getAllCrimesFromD1(jmDb);
const areaCrimes = await getCrimesByAreaFromD1(jmDb, areaName);

// Date ranges
const currentYear = new Date().getFullYear();
const previousYear = currentYear - 1;
const cutoff90d = new Date();
cutoff90d.setDate(cutoff90d.getDate() - 90);
const cutoff30d = new Date();
cutoff30d.setDate(cutoff30d.getDate() - 30);
const cutoff7d = new Date();
cutoff7d.setDate(cutoff7d.getDate() - 7);
const cutoff14d = new Date();
cutoff14d.setDate(cutoff14d.getDate() - 14);

const recentCrimes90d = areaCrimes.filter(c => (c.datePublished ?? c.dateObj) >= cutoff90d);
const recentCrimes30d = areaCrimes.filter(c => (c.datePublished ?? c.dateObj) >= cutoff30d);
const thisWeekCrimes  = areaCrimes.filter(c => (c.datePublished ?? c.dateObj) >= cutoff7d);
const lastWeekCrimes  = areaCrimes.filter(c => { const d = c.datePublished ?? c.dateObj; return d >= cutoff14d && d < cutoff7d; });

const crimesCurrent = areaCrimes.filter(c => c.year === currentYear);
const crimesPrevious = areaCrimes.filter(c => c.year === previousYear);
const crimesCurrentYTD = filterToSamePeriod(crimesCurrent, currentYear);
const crimesPreviousYTD = filterToSamePeriod(crimesPrevious, previousYear);

// Safety context
const safety = getSafetyContext(areaName, allCrimes);

// Crime type breakdown
const crimeTypeBreakdown = TRACKED_CRIME_TYPES.map(type => {
  const currentCount = countCrimeType(crimesCurrentYTD, type);
  const previousCount = countCrimeType(crimesPreviousYTD, type);
  const change = calculatePercentChange(previousCount, currentCount);
  return {
    type,
    currentCount,
    previousCount,
    change,
    direction: change > 0.5 ? 'up' : change < -0.5 ? 'down' : 'same',
  };
}).filter(c => c.currentCount > 0 || c.previousCount > 0);

// Helper to build a YoY stat card
function makeYoYCard(label: string, currentCount: number, previousCount: number) {
  const yoyChange = calculatePercentChange(previousCount, currentCount);
  return {
    label,
    current: currentCount,
    previous: previousCount,
    yoyChange,
    direction: (currentCount > previousCount ? 'up' : currentCount < previousCount ? 'down' : 'flat') as 'up' | 'down' | 'flat',
  };
}

const murderYTDCount = countCrimeType(crimesCurrentYTD, 'Murder');

const extraStatCards = [
  makeYoYCard('Shootings (YTD)', countCrimeType(crimesCurrentYTD, 'Shooting'), countCrimeType(crimesPreviousYTD, 'Shooting')),
  makeYoYCard('Assaults (YTD)', countCrimeType(crimesCurrentYTD, 'Assault'), countCrimeType(crimesPreviousYTD, 'Assault')),
  makeYoYCard('Robberies (YTD)', countCrimeType(crimesCurrentYTD, 'Robbery'), countCrimeType(crimesPreviousYTD, 'Robbery')),
  makeYoYCard('Burglaries (YTD)', countCrimeType(crimesCurrentYTD, 'Burglary'), countCrimeType(crimesPreviousYTD, 'Burglary')),
  makeYoYCard('Thefts (YTD)', countCrimeType(crimesCurrentYTD, 'Theft'), countCrimeType(crimesPreviousYTD, 'Theft')),
  makeYoYCard('Kidnappings (YTD)', countCrimeType(crimesCurrentYTD, 'Kidnapping'), countCrimeType(crimesPreviousYTD, 'Kidnapping')),
].filter(c => c.current > 0 || c.previous > 0);

// Recent headlines grouped by date
const headlinesByDate = new Map<string, typeof areaCrimes>();
recentCrimes30d.forEach(crime => {
  const dateKey = crime.dateObj.toLocaleDateString('en-JM', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
  if (!headlinesByDate.has(dateKey)) headlinesByDate.set(dateKey, []);
  headlinesByDate.get(dateKey)!.push(crime);
});

// Related areas in the same parish
const parishSlug = generateNameSlug(parishName);
const relatedAreas = areaData
  .filter(a => a.region === parishName && a.area !== areaName)
  .map(a => ({
    name: a.area,
    slug: generateNameSlug(a.area),
    knownAs: a.knownAs,
    hasCrimes: allCrimes.some(c => c.area === a.area),
    crimeCount: allCrimes.filter(c => c.area === a.area).length,
  }))
  .sort((a, b) => b.crimeCount - a.crimeCount)
  .slice(0, 6);

// Suggested compare: same-parish area with most recent crime
const suggestedCompare = relatedAreas
  .filter(a => a.hasCrimes)
  .map(a => ({
    ...a,
    recentCount: allCrimes.filter(c => c.area === a.name && (c.datePublished ?? c.dateObj) >= cutoff90d).length,
  }))
  .sort((a, b) => b.recentCount - a.recentCount)[0];

// Top areas from other parishes (for cross-linking)
const otherParishAreas = areaData
  .filter(a => a.region !== parishName && a.area !== areaName && allCrimes.some(c => c.area === a.area))
  .map(a => ({
    name: a.area,
    slug: generateNameSlug(a.area),
    knownAs: a.knownAs,
    parish: a.region,
    crimeCount: allCrimes.filter(c => c.area === a.area).length,
  }))
  .sort((a, b) => b.crimeCount - a.crimeCount)
  .slice(0, 3);

// Jamaica MPs for this parish
const parishMPs = mpsJamaicaData.filter((mp: any) => mp.parishSlugs?.includes(parishSlug));

// SEO
const totalCrimesCurrentYTD = getTotalCrimeCount(crimesCurrentYTD);
const totalCrimesPreviousYTD = getTotalCrimeCount(crimesPreviousYTD);
const topCrimeType = [...crimeTypeBreakdown].sort((a, b) => b.currentCount - a.currentCount)[0]?.type;
const areaYoYChange = totalCrimesPreviousYTD > 0
  ? ((totalCrimesCurrentYTD - totalCrimesPreviousYTD) / totalCrimesPreviousYTD) * 100
  : 0;
const areaYoYText = areaYoYChange > 5
  ? `Up ${Math.round(areaYoYChange)}% vs ${previousYear}`
  : areaYoYChange < -5
    ? `Down ${Math.round(Math.abs(areaYoYChange))}% vs ${previousYear}`
    : `Similar to ${previousYear}`;

const subtitle = knownAs && knownAs !== areaName ? `${areaName} (${knownAs})` : areaName;

const pageTitle = `${areaName} Crime Statistics ${currentYear} - Risk Level ${safety.score.toFixed(1)}/10 | Crime Hotspots`;
const pl = (n: number, word: string) => `${n} ${word}${n === 1 ? '' : 's'}`;
const topCount = topCrimeType && topCrimeType !== 'Murder' ? countCrimeType(crimesCurrentYTD, topCrimeType) : 0;
const pageDescription = totalCrimesCurrentYTD > 0
  ? `${areaName} ${currentYear}: ${totalCrimesCurrentYTD} crimes YTD — ${pl(murderYTDCount, 'murder')}${topCrimeType && topCrimeType !== 'Murder' && topCount > 0 ? `, ${pl(topCount, topCrimeType.toLowerCase())}` : ''}. Risk level ${safety.score.toFixed(1)}/10. ${areaYoYText}. Updated daily.`
  : `Crime statistics for ${areaName}, ${parishName} Parish, Jamaica. Risk Level: ${safety.score.toFixed(1)}/10. ${recentCrimes90d.length} incidents in the last 90 days. Updated daily.`;

const schemaData = {
  "@context": "https://schema.org",
  "@type": "Place",
  "name": areaName,
  "description": pageDescription,
  "containedInPlace": {
    "@type": "AdministrativeArea",
    "name": `${parishName} Parish, Jamaica`,
  },
  "additionalType": "https://schema.org/Dataset",
  "url": `https://crimehotspots.com/jamaica/area/${slug}/`,
};

const lastUpdated = new Date().toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
---

<Layout title={pageTitle} description={pageDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />

  <!-- Beta banner -->
  <div class="w-full bg-amber-50 dark:bg-amber-950/30 border-b border-amber-200 dark:border-amber-900/40 px-4 py-2 text-center">
    <p class="text-xs text-amber-700 dark:text-amber-400">
      Jamaica data is in beta. Coverage and accuracy improve daily as the pipeline matures.
    </p>
  </div>

  <DarkHero
    title={areaName}
    subtitle={`${parishName} Parish · ${division ? `${division} · ` : ''}Jamaica`}
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Jamaica', href: routes.jamaica.dashboard },
      { label: `${parishName} Parish`, href: buildRoute.jamaicaParish(parishSlug) },
      { label: areaName },
    ]}
    ctas={[
      { text: 'View Dashboard', href: routes.jamaica.dashboard, variant: 'primary' },
      { text: 'View Headlines', href: routes.jamaica.headlines },
    ]}
    freshness={`Data as of ${lastUpdated}`}
  >
    <Fragment slot="pulse">
      Risk score <strong class="text-white">{safety.score.toFixed(1)}/10</strong> — {recentCrimes90d.length} incidents in the last 90 days.
    </Fragment>
    <SocialProofStrip slot="right" variant="hero" incidentCount={allCrimes.length} />
  </DarkHero>

  <!-- Vitals Row -->
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-6 pb-2">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4">
      <GradientStatCard variant="amber"   value={safety.score.toFixed(1)} label="Risk Score"     sublabel="out of 10" />
      <GradientStatCard variant="slate"   value={recentCrimes90d.length}  label="Incidents"      sublabel="last 90 days" />
      <GradientStatCard variant="crimson" value={murderYTDCount}           label="Murders"        sublabel="year to date" />
      <GradientStatCard variant="violet"  value={topCrimeType ?? '—'}     label="Top Crime Type" sublabel={`${currentYear} YTD`} />
    </div>
  </div>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-5">
  <div class="lg:grid lg:grid-cols-[1fr_256px] lg:gap-8 lg:items-start">
  <main class="min-w-0" data-pagefind-body>

    <!-- Area Narrative -->
    <AreaNarrative
      areaName={areaName}
      areaSlug={slug!}
      thisWeekCount={thisWeekCrimes.length}
      lastWeekCount={lastWeekCrimes.length}
      primaryCrimeType={safety.primaryCrimeType || 'General Crime'}
      total90d={recentCrimes90d.length}
      compareUrl={undefined}
    />

    {extraStatCards.length > 0 && (
      <div class="mt-6">
        <button
          id="moreStatsToggle"
          class="w-full flex items-center justify-center gap-1 py-2 text-xs font-medium text-slate-400 dark:text-[var(--ch-text-faint)] hover:text-rose-600 transition cursor-pointer"
        >
          <span id="moreStatsLabel">More stats</span>
          <svg id="moreStatsChevron" class="w-4 h-4 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div id="moreStatsContent" class="more-stats-content mt-2">
          <StatCards stats={extraStatCards} />
        </div>
      </div>
    )}

    <!-- Safety Context -->
    <SafetyContext
      areaName={areaName}
      score={safety.score}
      level={safety.level}
      tip={safety.tip}
      positiveNote={safety.positiveNote}
      primaryCrimeType={safety.primaryCrimeType}
    />

    <!-- Safety Insight Feedback -->
    <FeedbackToggle
      areaName={areaName}
      pageUrl={`https://crimehotspots.com/jamaica/area/${slug}/`}
      pageTitle={`Crime Statistics for ${areaName}, Jamaica`}
    />

    <!-- Email Signup -->
    <div class="mt-4 mb-6">
      <NewsletterSignup areaName={areaName} source="area-page" />
    </div>

    <!-- Crime Type Breakdown -->
    {crimeTypeBreakdown.length > 0 && (
      <section class="mt-6">
        <h2 class="text-body font-bold text-slate-800 dark:text-[var(--ch-text-heading)] mb-4">Crime Breakdown (Year-to-Date)</h2>
        <DataTable headers={['Crime Type', String(currentYear), String(previousYear), 'Change']}>
          {crimeTypeBreakdown.map(row => (
            <tr class="hover:bg-slate-50 dark:hover:bg-[hsl(0_0%_10%)]">
              <td class="px-4 py-3 text-sm font-medium text-slate-700 dark:text-[var(--ch-text-heading)]">{row.type}</td>
              <td class="px-4 py-3 text-sm text-right text-slate-700 dark:text-[var(--ch-text-heading)]">{row.currentCount}</td>
              <td class="px-4 py-3 text-sm text-right text-slate-500 dark:text-[var(--ch-text-muted)]">{row.previousCount}</td>
              <td class={`px-4 py-3 text-sm text-right font-medium ${
                row.direction === 'up' ? 'text-rose-600' :
                row.direction === 'down' ? 'text-emerald-600' :
                'text-slate-400'
              }`}>
                {row.direction === 'up' ? '↑' : row.direction === 'down' ? '↓' : '→'}
                {Math.abs(row.change).toFixed(1)}%
              </td>
            </tr>
          ))}
        </DataTable>
      </section>
    )}

    <!-- Recent Headlines -->
    {recentCrimes30d.length > 0 ? (
      <section class="mt-8" data-pagefind-ignore>
        <h2 class="text-body font-bold text-slate-800 dark:text-[var(--ch-text-heading)] mb-4">
          Recent Headlines
          <span class="text-sm font-normal text-slate-500 dark:text-[var(--ch-text-muted)] ml-2">Last 30 days</span>
        </h2>

        <div class="space-y-2">
          {Array.from(headlinesByDate.entries()).map(([dateStr, crimes]) => (
            <div class="bg-white dark:bg-[var(--ch-surface)] rounded-lg border border-slate-200 dark:border-[var(--ch-border-subtle)] overflow-hidden">
              <button
                class="accordion-toggle w-full flex items-center justify-between px-4 py-3 hover:bg-slate-50 dark:hover:bg-[hsl(0_0%_10%)] transition cursor-pointer"
                aria-expanded="false"
              >
                <div class="flex items-center gap-2">
                  <svg class="accordion-chevron w-4 h-4 text-slate-400 dark:text-[var(--ch-text-faint)] transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                  <span class="text-sm font-medium text-slate-700 dark:text-[var(--ch-text-heading)]">{dateStr}</span>
                </div>
                <span class="text-xs text-slate-400 dark:text-[var(--ch-text-faint)]">{crimes.length} incident{crimes.length !== 1 ? 's' : ''}</span>
              </button>

              <div class="accordion-content">
                <div class="border-t border-slate-100 dark:border-[var(--ch-border-subtle)] px-4 py-3 space-y-3">
                  {crimes.map(crime => (
                    <a
                      href={buildRoute.jamaicaCrime(crime.slug)}
                      data-crime-slug={crime.slug}
                      class="crime-card-link block p-3 rounded-lg hover:bg-slate-50 dark:hover:bg-[hsl(0_0%_12%)] transition group"
                    >
                      <div class="text-sm font-medium text-slate-700 dark:text-[var(--ch-text-heading)] group-hover:text-rose-600 transition">
                        {escapeHtml(crime.headline)}
                      </div>
                      <div class="flex items-center gap-2 mt-1 text-xs text-slate-400 dark:text-[var(--ch-text-faint)]">
                        <span class="px-1.5 py-0.5 rounded bg-slate-100 dark:bg-[hsl(0_0%_12%)] text-slate-500 dark:text-[var(--ch-text-muted)]">{crime.primaryCrimeType || crime.crimeType}</span>
                        {crime.street && <span>{escapeHtml(crime.street)}</span>}
                      </div>
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>
      </section>
    ) : (
      <section class="mt-8">
        <div class="bg-slate-50 dark:bg-[var(--ch-surface)] rounded-lg border border-slate-200 dark:border-[var(--ch-border-subtle)] p-6 text-center">
          <p class="text-sm text-slate-500 dark:text-[var(--ch-text-muted)]">No incidents recorded in {areaName} in the last 30 days.</p>
        </div>
      </section>
    )}

    <!-- Related Areas -->
    {(relatedAreas.length > 0 || otherParishAreas.length > 0) && (
      <div class="mt-8 bg-slate-50 dark:bg-[var(--ch-surface)] rounded-lg border border-slate-200 dark:border-[var(--ch-border-subtle)] p-5 sm:p-6">
        {relatedAreas.length > 0 && (
          <section>
            <h2 class="text-body font-bold text-slate-800 dark:text-[var(--ch-text-heading)] mb-4">
              Other Areas in {parishName} Parish
            </h2>
            <div class="grid grid-cols-2 gap-3">
              {relatedAreas.map(a => (
                <a
                  href={a.hasCrimes ? buildRoute.jamaicaArea(a.slug) : '#'}
                  class={`block px-4 py-3 rounded-lg border text-sm font-medium transition ${
                    a.hasCrimes
                      ? 'bg-white dark:bg-[var(--ch-surface)] border-slate-200 dark:border-[var(--ch-border-subtle)] text-slate-700 dark:text-[var(--ch-text-heading)] hover:bg-rose-50 dark:hover:bg-rose-950/30 hover:border-rose-300 dark:hover:border-rose-800 hover:text-rose-600 dark:hover:text-rose-400'
                      : 'bg-white/50 dark:bg-[var(--ch-surface)]/50 border-slate-100 dark:border-[hsl(0_0%_12%)] text-slate-400 dark:text-[hsl(0_0%_40%)] cursor-default'
                  }`}
                >
                  <span>{a.name}</span>
                  {a.knownAs && a.knownAs !== a.name && (
                    <span class="block text-xs text-slate-400 dark:text-[var(--ch-text-faint)] mt-0.5">Also known as: {a.knownAs}</span>
                  )}
                </a>
              ))}
            </div>
          </section>
        )}

        {otherParishAreas.length > 0 && (
          <section class={relatedAreas.length > 0 ? 'mt-6 pt-6 border-t border-slate-200 dark:border-[var(--ch-border-card)]' : ''}>
            <h2 class="text-body font-bold text-slate-800 dark:text-[var(--ch-text-heading)] mb-4">
              Other Areas in Jamaica
            </h2>
            <div class="grid grid-cols-2 gap-3">
              {otherParishAreas.map(a => (
                <a
                  href={buildRoute.jamaicaArea(a.slug)}
                  class="block px-4 py-3 rounded-lg border bg-white dark:bg-[var(--ch-surface)] border-slate-200 dark:border-[var(--ch-border-subtle)] text-sm font-medium text-slate-700 dark:text-[var(--ch-text-heading)] hover:bg-rose-50 dark:hover:bg-rose-950/30 hover:border-rose-300 dark:hover:border-rose-800 hover:text-rose-600 dark:hover:text-rose-400 transition"
                >
                  <span>{a.name}</span>
                  <span class="block text-xs text-slate-400 dark:text-[var(--ch-text-faint)] mt-0.5">
                    {a.parish} Parish{a.knownAs && a.knownAs !== a.name ? ` · ${a.knownAs}` : ''}
                  </span>
                </a>
              ))}
            </div>
          </section>
        )}
      </div>
    )}
  </main>

  <MPSidebar
    mps={parishMPs}
    regionName={parishName}
    areaDisplayName={subtitle}
    safetyScore={safety.score.toFixed(1)}
    pageUrl={`https://crimehotspots.com/jamaica/area/${slug}/`}
    mpBasePath="/jamaica/mp/"
  />
  </div>
  </div>
</Layout>

<style>
  .accordion-content,
  .more-stats-content {
    height: 0;
    overflow: hidden;
    transition: height 300ms ease;
  }
  .accordion-content.is-open,
  .more-stats-content.is-open {
    height: auto;
  }
</style>

<div id="areaPageData" class="hidden"
  data-slug={slug}
  data-name={subtitle}
  data-safety={safety.score.toFixed(1)}
></div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.accordion-toggle').forEach(button => {
      button.addEventListener('click', function(this: HTMLElement) {
        const content = this.nextElementSibling as HTMLElement;
        const chevron = this.querySelector('.accordion-chevron') as HTMLElement;
        const isOpen = this.getAttribute('aria-expanded') === 'true';
        this.setAttribute('aria-expanded', String(!isOpen));
        if (isOpen) {
          content.classList.remove('is-open');
        } else {
          content.getBoundingClientRect();
          content.classList.add('is-open');
        }
        chevron.style.transform = isOpen ? '' : 'rotate(90deg)';
      });
    });

    const moreStatsToggle = document.getElementById('moreStatsToggle');
    const moreStatsContent = document.getElementById('moreStatsContent');
    const moreStatsLabel = document.getElementById('moreStatsLabel');
    const moreStatsChevron = document.getElementById('moreStatsChevron');
    if (moreStatsToggle && moreStatsContent && moreStatsLabel && moreStatsChevron) {
      moreStatsToggle.addEventListener('click', () => {
        const isOpen = moreStatsContent.classList.contains('is-open');
        moreStatsContent.classList.toggle('is-open');
        (moreStatsChevron as HTMLElement).style.transform = isOpen ? '' : 'rotate(180deg)';
        moreStatsLabel.textContent = isOpen ? 'More stats' : 'Less stats';
      });
    }

    const dataEl = document.getElementById('areaPageData');
    if (!dataEl) return;
    const slug = dataEl.dataset.slug || '';
    try {
      localStorage.setItem(`crimehotspots_area_visit_${slug}`, String(Date.now()));
    } catch(e) { /* localStorage unavailable */ }
  });
</script>
