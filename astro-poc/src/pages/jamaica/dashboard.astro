---
/**
 * Jamaica Crime Dashboard
 * SSR — data from JM_DB binding, CDN-cached ~23h.
 * No Leaflet map (area coordinates pending Phase D3).
 * No year filter (single year of data; add when historical years accumulate).
 */

export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import GradientStatCard from '../../components/GradientStatCard.astro';
import StatCard from '../../components/StatCard.astro';
import QuickInsightsCard from '../../components/QuickInsightsCard.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';
import DashboardInfoCards from '../../components/DashboardInfoCards.astro';
import SocialProofStrip from '../../components/SocialProofStrip.astro';
import DarkHero from '../../components/DarkHero.astro';
import { getAllCrimesFromD1 } from '../../lib/crimeData';
import { countCrimeType, calculateInsights } from '../../lib/dashboardHelpers';
import { getTotalCrimeCount } from '../../lib/statisticsHelpers';
import { getRiskWeight } from '../../config/riskWeights';
import { usesVictimCount } from '../../config/crimeTypeConfig';
import { routes } from '../../config/routes';
import { env } from 'cloudflare:workers';
import '../../styles/dashboard.css';

Astro.response.headers.set('CDN-Cache-Control', 'max-age=82800');
Astro.response.headers.set('Cache-Control', 'public, max-age=3600, must-revalidate');

const db = env.JM_DB as D1Database | undefined;
const allCrimes = db ? await getAllCrimesFromD1(db) : [];

const currentYear = new Date().getFullYear();
const crimes = allCrimes.filter(c => c.year === currentYear);
const insights = calculateInsights(crimes);

// This-week / last-week pulse
const now = new Date();
const weekAgo = new Date(); weekAgo.setDate(now.getDate() - 7); weekAgo.setHours(0, 0, 0, 0);
const twoWeeksAgo = new Date(); twoWeeksAgo.setDate(now.getDate() - 14); twoWeeksAgo.setHours(0, 0, 0, 0);
const thisWeekCrimes = allCrimes.filter(c => (c.datePublished ?? c.dateObj) >= weekAgo);
const lastWeekCrimes = allCrimes.filter(c => { const d = c.datePublished ?? c.dateObj; return d >= twoWeeksAgo && d < weekAgo; });
const murdersThisWeek = countCrimeType(thisWeekCrimes, 'Murder');
const murdersLastWeek = countCrimeType(lastWeekCrimes, 'Murder');
const murderChange = murdersLastWeek > 0
  ? Math.round(((murdersThisWeek - murdersLastWeek) / murdersLastWeek) * 100)
  : 0;
const weekChange = lastWeekCrimes.length > 0
  ? Math.round(((thisWeekCrimes.length - lastWeekCrimes.length) / lastWeekCrimes.length) * 100)
  : 0;
const areaCountMap = new Map<string, number>();
thisWeekCrimes.forEach(c => {
  const a = c.area || 'Unknown';
  if (a !== 'Unknown') areaCountMap.set(a, (areaCountMap.get(a) || 0) + 1);
});
const topArea = Array.from(areaCountMap.entries()).sort((a, b) => b[1] - a[1])[0];

// Freshness
const latestCrimeDate = allCrimes[0]?.dateObj ?? now;
const freshnessText = latestCrimeDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });

// Top parishes by weighted risk score
const regionWeightedScores = new Map<string, number>();
const regionCrimeCounts = new Map<string, number>();
crimes.forEach(c => {
  const region = (c.region || '').trim();
  if (!region || region === 'Unknown') return;
  let score = 0;
  const primaryType = c.primaryCrimeType || c.crimeType;
  if (primaryType) {
    score += getRiskWeight(primaryType) * (usesVictimCount(primaryType) && c.victimCount ? c.victimCount : 1);
  }
  if (c.relatedCrimeTypes) {
    c.relatedCrimeTypes.split(',').map(t => t.trim()).filter(Boolean).forEach(t => { score += getRiskWeight(t); });
  }
  regionWeightedScores.set(region, (regionWeightedScores.get(region) || 0) + score);
  let count = primaryType ? 1 : 0;
  if (c.relatedCrimeTypes) count += c.relatedCrimeTypes.split(',').map(t => t.trim()).filter(Boolean).length;
  regionCrimeCounts.set(region, (regionCrimeCounts.get(region) || 0) + count);
});
const topRegions = Array.from(regionWeightedScores.entries())
  .map(([region, weightedScore]) => ({ region, crimeCount: regionCrimeCounts.get(region) ?? 0, weightedScore }))
  .sort((a, b) => b.weightedScore - a.weightedScore)
  .slice(0, 10);
const maxScore = topRegions[0]?.weightedScore ?? 1;

function getRiskLevelText(barWidth: number): string {
  if (barWidth <= 10) return 'Low';
  if (barWidth <= 25) return 'Medium';
  if (barWidth <= 45) return 'Concerning';
  if (barWidth <= 65) return 'High';
  if (barWidth <= 85) return 'Dangerous';
  return 'Extremely Dangerous';
}
function getRiskTextColor(barWidth: number): string {
  if (barWidth <= 25) return 'text-green-600';
  if (barWidth <= 65) return 'text-yellow-600';
  return 'text-rose-600';
}

const showBeta = now < new Date('2026-07-04T00:00:00');

const title = `Jamaica Crime Dashboard ${currentYear} — Statistics, Murders & Hotspots | Crime Hotspots`;
const description = `Jamaica crime statistics ${currentYear}. Live murder count, robbery data, and parish crime breakdown. Updated daily from verified sources.`;
---

<Layout title={title} description={description} noindex={false}>

  <DarkHero padding="py-8 sm:py-10" pagefindIgnore={true}>

      <!-- Breadcrumb -->
      <nav aria-label="Breadcrumb" class="mb-4">
        <ol class="flex items-center gap-1.5 text-xs text-slate-500">
          <li><a href="/" class="hover:text-slate-300 transition">Home</a></li>
          <li><svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></li>
          <li class="text-slate-400">Jamaica</li>
        </ol>
      </nav>

      <div class="grid sm:grid-cols-[1fr_200px] gap-6 items-center">

        <!-- Left: title + pulse + CTAs -->
        <div>
          <div class="flex items-center gap-2.5 mb-2">
            <h1 class="text-4xl sm:text-5xl font-black text-white leading-tight">Jamaica</h1>
            {showBeta && (
              <span class="inline-block px-2 py-0.5 rounded text-[10px] font-bold uppercase tracking-widest bg-amber-400 text-amber-900 self-center">Beta</span>
            )}
          </div>
          <p class="text-slate-400 text-sm mb-5">
            Crime Statistics Dashboard <span class="font-medium text-slate-300">for {currentYear}</span>
          </p>

          <!-- Live this-week pulse -->
          {thisWeekCrimes.length > 0 && (
            <div class="flex items-start gap-2.5 mb-5 bg-white/5 rounded-lg px-4 py-3 border border-white/10">
              <span class="relative flex h-2 w-2 mt-1 shrink-0">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-rose-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-rose-500"></span>
              </span>
              <p class="text-slate-300 text-sm leading-relaxed">
                This week: <strong class="text-white font-bold">{thisWeekCrimes.length} crimes</strong>
                {weekChange !== 0 && (
                  <span class={weekChange > 0 ? 'text-rose-400' : 'text-emerald-400'}>
                    {' '}({weekChange > 0 ? '+' : ''}{weekChange}% vs last week)
                  </span>
                )}.
                {topArea && <> <span class="text-white font-medium">{topArea[0]}</span> leads with {topArea[1]}.</>}
                {murdersThisWeek > 0 && murderChange !== 0 && (
                  <> Murders{' '}
                    <span class={murderChange > 0 ? 'font-medium text-rose-400' : 'font-medium text-emerald-400'}>
                      {murderChange > 0 ? 'up' : 'down'} {Math.abs(murderChange)}%
                    </span> WoW.
                  </>
                )}
              </p>
            </div>
          )}

          <!-- CTAs -->
          <div class="flex gap-3 items-center flex-wrap mb-5">
            <a href={routes.jamaica.murderCount}
              class="px-4 py-2 inline-flex items-center gap-2 rounded-lg bg-rose-600 text-white hover:bg-rose-500 active:bg-rose-700 transition font-medium text-xs shadow-sm whitespace-nowrap">
              Murder Count
            </a>
            <a href={routes.jamaica.statistics}
              class="px-4 py-2 inline-flex items-center gap-2 rounded-lg border border-slate-500 text-slate-300 hover:border-slate-400 hover:text-white active:bg-white/5 transition font-medium text-xs whitespace-nowrap">
              Statistics
            </a>
            <a href={routes.jamaica.mps}
              class="px-4 py-2 inline-flex items-center gap-2 rounded-lg border border-slate-500 text-slate-300 hover:border-slate-400 hover:text-white active:bg-white/5 transition font-medium text-xs whitespace-nowrap">
              MPs
            </a>
          </div>

          <!-- Data freshness -->
          <p class="text-slate-500 text-xs flex items-center gap-1">
            <svg class="w-3 h-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Data as of {freshnessText}
          </p>
        </div>

        <!-- Right: social proof -->
        <div class="flex flex-col gap-3">
          <SocialProofStrip variant="sidebar" incidentCount={allCrimes.length} />
        </div>

      </div>
    </div>
  </DarkHero>


  <!-- ═══════════════════════════════════════════════════════════════
       ZONE 1 — Vitals + Crime Breakdown
       ═══════════════════════════════════════════════════════════════ -->
  <div class="max-w-5xl mx-auto px-4 sm:px-6 pt-6 pb-2" data-pagefind-ignore>

    <!-- Vitals row -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4 mb-8">
      <GradientStatCard
        variant="slate"
        value={getTotalCrimeCount(crimes)}
        label="Total Crimes"
        sublabel="year to date"
        id="totalIncidents"
      />
      <GradientStatCard
        variant="crimson"
        value={countCrimeType(crimes, 'Murder')}
        label="Murders"
        sublabel="year to date"
        id="vitals-murders"
      />
      <GradientStatCard
        variant="amber"
        value={Number.isNaN(+insights.avgPerDay) ? '—' : insights.avgPerDay}
        label="Crimes / Day"
        sublabel={Number.isNaN(+insights.victimsPerDay) ? '— victims/day' : `${insights.victimsPerDay} victims/day`}
        id="vitals-daily"
      />
      <GradientStatCard
        variant="violet"
        value={insights.mostDangerousRegionCount}
        label="Hottest Parish"
        sublabel={insights.mostDangerousRegion}
        id="vitals-hotspot"
      />
    </div>

    <!-- Crime Breakdown -->
    <div class="flex items-center gap-1 px-1 mb-2">
      <h2 class="text-sm font-bold text-slate-500 dark:text-[var(--ch-text-muted)]">Crime Breakdown</h2>
    </div>

    <div class="stats-wrapper relative min-h-[140px] overflow-hidden mb-6">
      <div class="stats-scroll-container">
        <StatCard value={countCrimeType(crimes, 'Murder')} label="Murders" crimeType="Murder" />
        <StatCard value={countCrimeType(crimes, 'Attempted Murder')} label="Attempted Murders" crimeType="Attempted Murder" />
        <StatCard value={countCrimeType(crimes, 'Shooting')} label="Shootings" crimeType="Shooting" />
        <StatCard value={countCrimeType(crimes, 'Robbery')} label="Robberies" crimeType="Robbery" />
        <StatCard value={countCrimeType(crimes, 'Carjacking')} label="Carjackings" crimeType="Carjacking" />
        <StatCard value={countCrimeType(crimes, 'Home Invasion')} label="Home Invasions" crimeType="Home Invasion" />
        <StatCard value={countCrimeType(crimes, 'Burglary')} label="Burglaries" crimeType="Burglary" />
        <StatCard value={countCrimeType(crimes, 'Theft')} label="Thefts" crimeType="Theft" />
        <StatCard value={countCrimeType(crimes, 'Assault')} label="Assaults" crimeType="Assault" />
        <StatCard value={countCrimeType(crimes, 'Kidnapping')} label="Kidnappings" crimeType="Kidnapping" />
      </div>
      <!-- Scroll hint -->
      <div class="absolute right-0 top-0 bottom-0 w-16 bg-gradient-to-l from-white via-white/90 to-transparent dark:from-[var(--ch-bg)] dark:via-[hsl(0_0%_8%_/_0.9)] pointer-events-none flex items-center justify-end pr-2">
        <svg class="w-4 h-4 text-rose-600 animate-pulse" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </div>
    </div>

  </div>


  <!-- ═══════════════════════════════════════════════════════════════
       DARK SEPARATOR BAND
       ═══════════════════════════════════════════════════════════════ -->
  <div class="w-full bg-slate-900 dark:bg-[hsl(0_0%_5%)] py-4" data-pagefind-ignore>
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest">Live Data</p>
      <h2 class="text-white font-black text-lg mt-0.5">Parish Breakdown &amp; Insights</h2>
    </div>
  </div>


  <!-- ═══════════════════════════════════════════════════════════════
       ZONE 2 — Top Parishes + Quick Insights
       ═══════════════════════════════════════════════════════════════ -->
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-6" data-pagefind-ignore>

    <div class="grid lg:grid-cols-2 gap-6 mb-8 items-start">

      <!-- Top Parishes -->
      <div>
        <div class="flex items-center gap-2 mb-3">
          <h3 class="text-sm font-bold text-slate-500 dark:text-[var(--ch-text-muted)]">Top Parishes</h3>
          <span class="ml-auto text-xs text-slate-400 dark:text-[hsl(0_0%_40%)]">by risk score</span>
        </div>
        {topRegions.length > 0 ? (
          <div class="bg-white/85 dark:bg-[var(--ch-surface)]/85 backdrop-blur-md rounded-lg p-4 shadow-md border border-slate-100 dark:border-[var(--ch-border-subtle)]">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-3">
              {topRegions.map(({ region, crimeCount, weightedScore }, index) => {
                const barWidth = maxScore > 0 ? Math.round((weightedScore / maxScore) * 100) : 0;
                const riskLevelText = getRiskLevelText(barWidth);
                const riskTextColor = getRiskTextColor(barWidth);
                const mobileHidden = index >= 5 ? 'hidden sm:flex' : '';
                return (
                  <div class={`${mobileHidden} flex flex-col gap-1 pb-3 border-b border-slate-200 dark:border-[var(--ch-border-card)] px-2 py-2`}>
                    <div class="flex justify-between items-center gap-2">
                      <span class="text-xs text-slate-500 dark:text-[var(--ch-text-muted)] truncate flex-1">{region}</span>
                      <span class="text-xs text-slate-400 dark:text-[hsl(0_0%_40%)] shrink-0">{crimeCount}</span>
                    </div>
                    <div class="relative w-full h-2 bg-slate-200 dark:bg-[hsl(0_0%_18%)] rounded-full overflow-hidden">
                      <div class="absolute top-0 left-0 h-full overflow-hidden transition-all duration-300" style={`width: ${barWidth}%`}>
                        <div class="h-full bg-gradient-to-r from-green-500 via-yellow-500 to-rose-600" style={`width: ${barWidth > 0 ? Math.round((100 / barWidth) * 100) : 100}%`}></div>
                      </div>
                    </div>
                    <span class={`text-xs font-medium ${riskTextColor}`}>Risk: {riskLevelText}</span>
                  </div>
                );
              })}
            </div>
            <p class="text-xs text-slate-400 dark:text-[hsl(0_0%_40%)] mt-3 pt-3 border-t border-slate-100 dark:border-[var(--ch-border-subtle)]">
              Parish detail pages coming soon.
            </p>
          </div>
        ) : (
          <div class="bg-white/85 dark:bg-[var(--ch-surface)]/85 rounded-lg p-6 border border-slate-100 dark:border-[var(--ch-border-subtle)] text-center">
            <p class="text-sm text-slate-500 dark:text-[var(--ch-text-muted)]">Parish data will appear as crimes are recorded.</p>
          </div>
        )}
      </div>

      <!-- Quick Insights -->
      <div>
        <div class="flex items-center gap-2 mb-3">
          <h3 class="text-sm font-bold text-slate-500 dark:text-[var(--ch-text-muted)]">Quick Insights</h3>
          <a href={routes.jamaica.statistics} class="ml-auto text-xs text-rose-600 hover:text-rose-700 font-medium transition">
            Full Statistics
            <svg class="w-3 h-3 inline-block ml-0.5 -mt-px" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>
        <QuickInsightsCard insights={insights} />
      </div>

    </div>

    <!-- Newsletter -->
    <div class="mb-8">
      <NewsletterSignup variant="inline" source="jamaica-dashboard" />
    </div>

    <!-- Info Cards -->
    <DashboardInfoCards />

    <!-- Related Resources -->
    <div class="mt-8">
      <h2 class="text-sm font-bold text-slate-500 dark:text-[var(--ch-text-muted)] px-1 mb-4">Related Resources</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
        <a href={routes.jamaica.statistics} class="block bg-white/85 dark:bg-[var(--ch-surface)]/85 backdrop-blur-md rounded-lg border border-slate-200 dark:border-[var(--ch-border-subtle)] p-4 hover:border-rose-300 dark:hover:border-rose-800 hover:shadow-sm transition">
          <h3 class="font-bold text-caption text-slate-800 dark:text-[var(--ch-text-heading)]">Crime Statistics &amp; Rate</h3>
          <p class="text-xs text-slate-500 dark:text-[var(--ch-text-muted)] mt-1">Year-over-year analysis and crime rate per 100k population</p>
        </a>
        <a href={routes.jamaica.murderCount} class="block bg-rose-50 dark:bg-rose-950/40 rounded-lg border border-rose-200 dark:border-rose-900/50 p-4 hover:border-rose-400 dark:hover:border-rose-700 hover:shadow-md transition">
          <div class="flex items-center gap-1.5 mb-1">
            <svg class="w-4 h-4 text-rose-500" fill="currentColor" viewBox="0 0 24 24"><path d="M12 23c-3.6 0-8-3.13-8-8.46C4 9.5 9.04 3.18 11.14.97a1.15 1.15 0 011.72 0C15 3.18 20 9.5 20 14.54 20 19.87 15.6 23 12 23zm0-19.73C9.64 6.1 6 11.47 6 14.54 6 18.62 9.07 21 12 21s6-2.38 6-6.46c0-3.07-3.64-8.44-6-11.27z"/><path d="M12 19a3.5 3.5 0 01-3.5-3.5c0-1.56 1.84-3.88 3.08-5.12a.58.58 0 01.84 0c1.24 1.24 3.08 3.56 3.08 5.12A3.5 3.5 0 0112 19z"/></svg>
            <h3 class="font-bold text-caption text-rose-700 dark:text-rose-400">Murder Count {currentYear}</h3>
          </div>
          <p class="text-xs text-rose-600/70 dark:text-rose-400/70">Live murder count with year-over-year comparison</p>
        </a>
        <a href={routes.jamaica.mps} class="block bg-white/85 dark:bg-[var(--ch-surface)]/85 backdrop-blur-md rounded-lg border border-slate-200 dark:border-[var(--ch-border-subtle)] p-4 hover:border-rose-300 dark:hover:border-rose-800 hover:shadow-sm transition">
          <h3 class="font-bold text-caption text-slate-800 dark:text-[var(--ch-text-heading)]">MPs &amp; Representatives</h3>
          <p class="text-xs text-slate-500 dark:text-[var(--ch-text-muted)] mt-1">Browse all 63 Jamaica Members of Parliament</p>
        </a>
      </div>
    </div>

  </div>

</Layout>
