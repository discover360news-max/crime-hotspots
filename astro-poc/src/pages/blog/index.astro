---
/**
 * Blog Index Page — Magazine layout with hero featured post (JNEWS-style)
 * Hero = sortedPosts[0], Secondary grid = posts[1-3], List = posts[4+]
 */

import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SocialProofStrip from '../../components/SocialProofStrip.astro';

const BATCH_SIZE = 6;

const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const heroPost = sortedPosts[0];
const secondaryPosts = sortedPosts.slice(1, 4);
const listPosts = sortedPosts.slice(4);

const title = "Crime Statistics Blog — Weekly Crime Reports & Analysis | Crime Hotspots Caribbean";
const description = "Read in-depth Caribbean crime analysis and weekly reports. We uncover emerging crime trends in Trinidad and Guyana. Browse our latest data insights.";

function formatDate(date: Date) {
  return new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

function formatShortDate(date: Date) {
  return new Date(date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
---

<Layout title={title} description={description}>
  <main class="max-w-5xl mx-auto px-4 sm:px-6 py-6">

    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-3 mb-6">
      <div>
        <Breadcrumbs items={[
          { label: 'Home', href: '/' },
          { label: 'Blog' }
        ]} />
        <h1 class="text-2xl font-bold text-slate-900 dark:text-[var(--ch-text-heading)] mt-1">Crime Statistics Blog</h1>
        <p class="text-sm text-slate-500 dark:text-[var(--ch-text-muted)] mt-1">Weekly data-driven analysis of crime trends across the Caribbean.</p>
      </div>
      <div class="flex items-center gap-2 shrink-0">
        <div class="flex gap-1.5">
          <button id="filter-all" class="px-3 py-1.5 rounded-lg bg-rose-600 text-white text-xs font-semibold hover:bg-rose-700 active:bg-rose-800 transition">
            All
          </button>
          <button id="filter-tt" class="px-3 py-1.5 rounded-lg border border-slate-300 dark:border-[var(--ch-border)] text-slate-600 dark:text-[var(--ch-text-muted)] text-xs font-semibold hover:bg-slate-50 dark:hover:bg-[hsl(0_0%_14%)] transition">
            Trinidad &amp; Tobago
          </button>
        </div>
        <a
          href="/rss.xml"
          class="flex items-center gap-1 px-2.5 py-1.5 rounded-lg border border-slate-300 dark:border-[var(--ch-border)] text-slate-500 dark:text-[var(--ch-text-muted)] hover:text-rose-600 dark:hover:text-rose-400 hover:border-rose-300 dark:hover:border-rose-800 transition text-xs"
          title="Subscribe via RSS"
        >
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M6.18 15.64a2.18 2.18 0 012.18 2.18C8.36 19.01 7.37 20 6.18 20 5 20 4 19.01 4 17.82a2.18 2.18 0 012.18-2.18M4 4.44A15.56 15.56 0 0119.56 20h-2.83A12.73 12.73 0 004 7.27V4.44m0 5.66a9.9 9.9 0 019.9 9.9h-2.83A7.07 7.07 0 004 12.93V10.1z"/>
          </svg>
          RSS
        </a>
      </div>
    </div>

    <!-- ========== HERO POST ========== -->
    {heroPost && (
      <a href={`/blog/${heroPost.slug}/`} class="block relative rounded-2xl overflow-hidden mb-5 group" aria-label={`Read: ${heroPost.data.title}`}>
        <img
          src={heroPost.data.image}
          alt={heroPost.data.countryName}
          class="w-full h-[320px] sm:h-[420px] md:h-[480px] object-cover transition-transform duration-500 group-hover:scale-[1.02]"
          loading="eager"
          width="1280"
          height="480"
        />
        <!-- Gradient overlay -->
        <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/30 to-black/5 pointer-events-none" />
        <!-- Latest badge -->
        <div class="absolute top-4 left-4">
          <span class="text-[10px] font-bold uppercase tracking-widest bg-rose-600 text-white px-2.5 py-1 rounded">Latest</span>
        </div>
        <!-- Article meta — overlaid at bottom -->
        <div class="absolute bottom-0 left-0 right-0 p-5 sm:p-8">
          <div class="flex items-center gap-2 mb-2">
            <span class="text-[11px] font-semibold text-white/80 border border-white/30 px-2 py-0.5 rounded-full">{heroPost.data.countryName}</span>
          </div>
          <h2 class="text-xl sm:text-2xl md:text-3xl font-bold text-white leading-tight mb-2 line-clamp-2 group-hover:underline decoration-white/60 underline-offset-2">
            {heroPost.data.title}
          </h2>
          <p class="text-white/70 text-xs sm:text-sm">
            {formatDate(heroPost.data.date)} &middot; {heroPost.data.readTime}
          </p>
        </div>
      </a>
    )}

    <!-- ========== SECONDARY GRID (posts 1–3) ========== -->
    {secondaryPosts.length > 0 && (
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
        {secondaryPosts.map(post => (
          <a
            href={`/blog/${post.slug}/`}
            class="group block bg-white dark:bg-[var(--ch-surface)] rounded-xl overflow-hidden border border-slate-200 dark:border-[var(--ch-border-card)] hover:shadow-md hover:border-rose-200 dark:hover:border-rose-900 transition-all"
          >
            <div class="overflow-hidden">
              <img
                src={post.data.image}
                alt={post.data.countryName}
                class="w-full h-36 object-cover transition-transform duration-300 group-hover:scale-[1.04]"
                loading="lazy"
                width="640"
                height="144"
              />
            </div>
            <div class="p-3.5">
              <div class="flex items-center gap-1.5 mb-1.5 flex-wrap">
                <span class="text-[10px] font-bold uppercase tracking-wide text-rose-600 dark:text-rose-400">{post.data.countryName}</span>
                <span class="text-[10px] text-slate-300 dark:text-[var(--ch-border)]">&middot;</span>
                <span class="text-[10px] text-slate-400 dark:text-[var(--ch-text-faint)]">{formatShortDate(post.data.date)}</span>
              </div>
              <h3 class="text-sm font-bold text-slate-800 dark:text-[var(--ch-text-heading)] group-hover:text-rose-600 dark:group-hover:text-rose-400 transition leading-snug line-clamp-2 mb-1.5">
                {post.data.title}
              </h3>
              <span class="text-[10px] text-slate-400 dark:text-[var(--ch-text-faint)]">{post.data.readTime}</span>
            </div>
          </a>
        ))}
      </div>
    )}

    <!-- ========== SOCIAL PROOF ========== -->
    <div class="mb-6">
      <SocialProofStrip variant="strip" />
    </div>

    <!-- ========== MORE REPORTS LIST (posts 4+) ========== -->
    {listPosts.length > 0 && (
      <div>
        <!-- Section label -->
        <div class="flex items-center gap-3 mb-4">
          <h2 class="text-[11px] font-bold uppercase tracking-widest text-slate-400 dark:text-[var(--ch-text-faint)] whitespace-nowrap">More Reports</h2>
          <div class="flex-1 h-px bg-slate-200 dark:bg-[var(--ch-border-subtle)]" />
        </div>

        <div id="blog-posts" class="space-y-2">
          {listPosts.map((post, index) => (
            <article
              class={`blog-post rounded-xl border border-slate-200 dark:border-[var(--ch-border-card)] hover:border-rose-200 dark:hover:border-rose-900 hover:shadow-sm bg-white dark:bg-[var(--ch-surface)] transition-all${index >= BATCH_SIZE ? ' hidden' : ''}`}
              data-country={post.data.country}
              data-post-index={index}
            >
              <a href={`/blog/${post.slug}/`} class="flex gap-4 items-center p-3.5 group">
                <img
                  src={post.data.image}
                  alt={post.data.countryName}
                  class="w-20 h-20 object-cover rounded-lg shrink-0"
                  loading="lazy"
                  width="80"
                  height="80"
                />
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-1.5 mb-1 flex-wrap">
                    <span class="text-[10px] font-bold uppercase tracking-wide text-rose-600 dark:text-rose-400">{post.data.countryName}</span>
                    <span class="text-[10px] text-slate-300 dark:text-[var(--ch-border)]">&middot;</span>
                    <span class="text-[10px] text-slate-400 dark:text-[var(--ch-text-faint)]">{formatShortDate(post.data.date)}</span>
                  </div>
                  <h3 class="text-sm font-bold text-slate-800 dark:text-[var(--ch-text-heading)] group-hover:text-rose-600 dark:group-hover:text-rose-400 transition leading-snug line-clamp-2">
                    {post.data.title}
                  </h3>
                  <p class="text-xs text-slate-500 dark:text-[var(--ch-text-muted)] mt-0.5 line-clamp-1 hidden sm:block">
                    {post.data.excerpt}
                  </p>
                </div>
                <span class="text-[11px] text-slate-400 dark:text-[var(--ch-text-faint)] shrink-0 hidden md:block">{post.data.readTime}</span>
              </a>
            </article>
          ))}
        </div>

        <!-- Load More -->
        <div id="load-more-wrapper" class={`mt-5 text-center${listPosts.length <= BATCH_SIZE ? ' hidden' : ''}`}>
          <button
            id="load-more-btn"
            class="px-6 py-2.5 rounded-lg border border-slate-300 dark:border-[var(--ch-border)] text-slate-600 dark:text-[hsl(0_0%_70%)] text-sm font-medium hover:bg-slate-50 dark:hover:bg-[hsl(0_0%_12%)] active:bg-slate-100 dark:active:bg-[hsl(0_0%_15%)] transition"
          >
            Load more ({listPosts.length - BATCH_SIZE} remaining)
          </button>
        </div>

        <!-- Empty State -->
        <div id="empty-state" class="hidden text-center py-10">
          <p class="text-slate-500 dark:text-[var(--ch-text-muted)] text-sm">No articles found for this filter.</p>
        </div>
      </div>
    )}

    <!-- Edge case: fewer than 5 total posts — no list section, empty state if filtered -->
    {listPosts.length === 0 && (
      <div id="empty-state" class="hidden text-center py-10">
        <p class="text-slate-500 dark:text-[var(--ch-text-muted)] text-sm">No articles found for this filter.</p>
      </div>
    )}

  </main>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const BATCH_SIZE = 6;
      let currentFilter = 'all';
      let visibleCount = BATCH_SIZE;

      const loadMoreWrapper = document.getElementById('load-more-wrapper');
      const loadMoreBtn = document.getElementById('load-more-btn');
      const emptyState = document.getElementById('empty-state');

      function getFilteredPosts(): HTMLElement[] {
        const posts = Array.from(document.querySelectorAll<HTMLElement>('.blog-post'));
        return currentFilter === 'all' ? posts : posts.filter(p => p.dataset.country === currentFilter);
      }

      function render() {
        const allPosts = document.querySelectorAll<HTMLElement>('.blog-post');
        const filtered = getFilteredPosts();

        allPosts.forEach(p => p.classList.add('hidden'));
        filtered.slice(0, visibleCount).forEach(p => p.classList.remove('hidden'));

        emptyState?.classList.toggle('hidden', filtered.length > 0);

        const remaining = filtered.length - visibleCount;
        const hasMore = remaining > 0;
        loadMoreWrapper?.classList.toggle('hidden', !hasMore);
        if (hasMore && loadMoreBtn) {
          loadMoreBtn.textContent = `Load more (${remaining} remaining)`;
        }
      }

      function updateFilterButtons(activeId: string) {
        ['filter-all', 'filter-tt'].forEach(id => {
          const btn = document.getElementById(id);
          if (!btn) return;
          if (id === activeId) {
            btn.classList.remove('border', 'border-slate-300', 'text-slate-600', 'hover:bg-slate-50');
            btn.classList.add('bg-rose-600', 'text-white', 'hover:bg-rose-700');
          } else {
            btn.classList.remove('bg-rose-600', 'text-white', 'hover:bg-rose-700');
            btn.classList.add('border', 'border-slate-300', 'text-slate-600', 'hover:bg-slate-50');
          }
        });
      }

      const filterMap: Record<string, string> = { 'filter-all': 'all', 'filter-tt': 'tt' };
      Object.entries(filterMap).forEach(([buttonId, filter]) => {
        document.getElementById(buttonId)?.addEventListener('click', () => {
          currentFilter = filter;
          visibleCount = BATCH_SIZE;
          updateFilterButtons(buttonId);
          render();
        });
      });

      loadMoreBtn?.addEventListener('click', () => {
        visibleCount += BATCH_SIZE;
        render();
      });
    });
  </script>
</Layout>
