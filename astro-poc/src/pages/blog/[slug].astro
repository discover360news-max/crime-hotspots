---
/**
 * Blog Post Page
 * Dynamic route for individual blog posts
 */

// Keep blog posts static (pre-rendered at build time)
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';
import SocialProofStrip from '../../components/SocialProofStrip.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { routes, buildRoute } from '../../config/routes';

export async function getStaticPaths() {
  const blogPosts = await getCollection('blog');
  return blogPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await post.render();

const title = `${post.data.title} | Crime Hotspots Caribbean`;
const description = post.data.excerpt;

function formatDate(date: Date) {
  return new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

// Determine dashboard link based on country
const dashboardLink = post.data.country === 'tt'
  ? routes.trinidad.dashboard
  : '/guyana/dashboard/';

// Breadcrumb items
const breadcrumbItems = [
  { label: 'Home', href: routes.home },
  { label: 'Blog', href: routes.blog },
  { label: post.slug.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase()) }
];

// Get related posts (same country, most recent, excluding current)
const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter(p => p.slug !== post.slug && p.data.country === post.data.country)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

// NewsArticle Schema — required for Google News eligibility
const newsArticleSchema = {
  "@context": "https://schema.org",
  "@type": "NewsArticle",
  "headline": post.data.title,
  "description": post.data.excerpt,
  "image": [`https://crimehotspots.com${post.data.image}`],
  "datePublished": post.data.date.toISOString(),
  "dateModified": post.data.date.toISOString(),
  "author": {
    "@type": "Organization",
    "name": post.data.author,
    "url": "https://crimehotspots.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Crime Hotspots",
    "url": "https://crimehotspots.com",
    "logo": {
      "@type": "ImageObject",
      "url": "https://crimehotspots.com/assets/images/logo.png"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://crimehotspots.com/blog/${post.slug}/`
  },
  "articleSection": "Crime Statistics",
  "keywords": post.data.tags.join(", "),
  "inLanguage": "en"
};
---

<style>
  /* Blog Content Styling */
  .blog-content {
    color: #334155;
  }

  .blog-content :global(h2) {
    font-size: 1.5rem;
    line-height: 2rem;
    font-weight: 600;
    color: #334155;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .blog-content :global(h3) {
    font-size: 1.25rem;
    line-height: 1.75rem;
    font-weight: 600;
    color: #334155;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .blog-content :global(h4) {
    font-size: 1rem;
    line-height: 1.5rem;
    font-weight: 600;
    color: #475569;
    margin-top: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .blog-content :global(p) {
    font-size: 0.9375rem;
    line-height: 1.75rem;
    color: #334155;
    margin-bottom: 1.125rem;
  }

  .blog-content :global(ul),
  .blog-content :global(ol) {
    font-size: 0.9375rem;
    line-height: 1.75rem;
    color: #334155;
    margin-top: 1rem;
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }

  .blog-content :global(ul) { list-style-type: disc; }
  .blog-content :global(ol) { list-style-type: decimal; }

  .blog-content :global(li) {
    margin-top: 0.5rem;
    margin-bottom: 0.5rem;
    padding-left: 0.25rem;
  }

  .blog-content :global(li > ul),
  .blog-content :global(li > ol) {
    margin-top: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .blog-content :global(strong) {
    font-weight: 600;
    color: #1e293b;
  }

  .blog-content :global(a) {
    color: #e11d48;
    text-decoration: underline;
    font-weight: 500;
  }

  .blog-content :global(a:hover) { color: #be123c; }

  .blog-content :global(hr) {
    border: 0;
    border-top: 1px solid #e2e8f0;
    margin-top: 2rem;
    margin-bottom: 2rem;
  }

  .blog-content :global(blockquote) {
    border-left: 4px solid #e11d48;
    padding-left: 1rem;
    margin-left: 0;
    margin-top: 1.5rem;
    margin-bottom: 1.5rem;
    font-style: italic;
    color: #475569;
  }

  .blog-content :global(code) {
    background-color: #f1f5f9;
    color: #e11d48;
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.8125rem;
    font-family: 'Monaco', 'Courier New', monospace;
  }

  .blog-content :global(pre) {
    background-color: #0f172a;
    color: #f8fafc;
    padding: 1rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    margin-top: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .blog-content :global(pre code) {
    background-color: transparent;
    color: inherit;
    padding: 0;
    font-size: 0.875rem;
  }

  .blog-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-top: 1.5rem;
    margin-bottom: 1.5rem;
    font-size: 0.875rem;
  }

  .blog-content :global(th),
  .blog-content :global(td) {
    border: 1px solid #e2e8f0;
    padding: 0.75rem;
    text-align: left;
  }

  .blog-content :global(th) {
    background-color: #f8fafc;
    font-weight: 600;
    color: #334155;
  }

  .blog-content :global(td) { color: #334155; }

  /* Dark Mode */
  :global(.dark) .blog-content { color: hsl(0 0% 82%); }
  :global(.dark) .blog-content :global(h2),
  :global(.dark) .blog-content :global(h3) { color: hsl(0 0% 88%); }
  :global(.dark) .blog-content :global(h4) { color: hsl(0 0% 75%); }
  :global(.dark) .blog-content :global(p),
  :global(.dark) .blog-content :global(li) { color: hsl(0 0% 82%); }
  :global(.dark) .blog-content :global(strong) { color: hsl(0 0% 92%); }
  :global(.dark) .blog-content :global(blockquote) { color: hsl(0 0% 70%); }
  :global(.dark) .blog-content :global(hr) { border-top-color: hsl(0 0% 22%); }
  :global(.dark) .blog-content :global(code) {
    background-color: hsl(0 0% 14%);
    color: #fb7185;
  }
  :global(.dark) .blog-content :global(th) {
    background-color: hsl(0 0% 10%);
    color: hsl(0 0% 85%);
  }
  :global(.dark) .blog-content :global(td) { color: hsl(0 0% 80%); }
  :global(.dark) .blog-content :global(th),
  :global(.dark) .blog-content :global(td) { border-color: hsl(0 0% 22%); }
</style>

<Layout title={title} description={description} ogType="article" ogImage={post.data.image}>
  <!-- NewsArticle Schema — required for Google News eligibility -->
  <script type="application/ld+json" set:html={JSON.stringify(newsArticleSchema)} />

  <main class="max-w-4xl mx-auto px-4 sm:px-6 py-4 sm:py-8">

    <!-- Breadcrumbs -->
    <Breadcrumbs items={breadcrumbItems} />

    <article>
      <!-- Hero Image — larger, full container width -->
      <div class="mt-3 mb-6 sm:mb-8 rounded-2xl overflow-hidden">
        <img
          src={post.data.image}
          alt={post.data.countryName}
          class="w-full h-56 sm:h-80 md:h-[440px] object-cover"
          width="1280"
          height="440"
          loading="eager"
        />
      </div>

      <!-- Article Header -->
      <header class="mb-6 sm:mb-8">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-xs font-bold uppercase tracking-wide px-2.5 py-1 rounded bg-rose-100 dark:bg-rose-950/50 text-rose-700 dark:text-rose-400">
            {post.data.countryName}
          </span>
          <span class="text-xs text-slate-400 dark:text-[var(--ch-text-faint)]">{formatDate(post.data.date)}</span>
        </div>
        <h1 class="text-2xl sm:text-3xl md:text-4xl font-bold text-slate-900 dark:text-[hsl(0_0%_95%)] leading-tight mb-4">{post.data.title}</h1>
        <div class="flex items-center gap-3 text-sm text-slate-500 dark:text-[hsl(0_0%_60%)]">
          <span>{post.data.author}</span>
          <span class="text-slate-300 dark:text-[var(--ch-border)]">&middot;</span>
          <span>{post.data.readTime}</span>
        </div>
      </header>

      <!-- Divider -->
      <hr class="border-slate-200 dark:border-[var(--ch-border-subtle)] mb-8" />

      <!-- Article Body -->
      <div class="blog-content max-w-2xl">
        <Content />
      </div>

      <!-- Newsletter CTA -->
      <div class="mt-10 max-w-2xl">
        <NewsletterSignup variant="inline" source="blog-post" />
      </div>

      <!-- Social Share -->
      <div class="mt-8 sm:mt-10 pt-6 border-t border-slate-200 dark:border-[var(--ch-border-card)] max-w-2xl" data-post-title={post.data.title}>
        <h3 class="text-sm font-bold mb-3 text-slate-900 dark:text-[var(--ch-text)]">Share this article</h3>
        <div class="flex flex-wrap gap-2">
          <button id="share-facebook" class="px-4 py-1.5 min-h-button bg-[#1877F2] text-white rounded-lg hover:bg-[#0d6efd] transition text-xs font-bold">Facebook</button>
          <button id="share-twitter" class="px-4 py-1.5 min-h-button bg-slate-900 text-white rounded-lg hover:bg-slate-700 transition text-xs font-bold">X (Twitter)</button>
          <button id="share-whatsapp" class="px-4 py-1.5 min-h-button bg-[#25D366] text-white rounded-lg hover:bg-[#1ebe5c] transition text-xs font-bold">WhatsApp</button>
          <button id="share-copy" class="px-4 py-1.5 min-h-button bg-rose-600 text-white rounded-lg hover:bg-rose-700 transition text-xs font-bold">Copy Link</button>
        </div>
      </div>

      <!-- No-Ad Guarantee -->
      <div class="mt-6 pt-5 border-t border-slate-100 dark:border-[var(--ch-border-card)] flex items-start gap-2.5 max-w-2xl">
        <svg class="w-4 h-4 text-slate-400 dark:text-[hsl(0_0%_45%)] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
        <p class="text-xs text-slate-400 dark:text-[hsl(0_0%_48%)] leading-relaxed">
          This content is 100% ad-free. Supported by readers like you on <a href="https://ko-fi.com/crimehotspots" target="_blank" rel="noopener noreferrer" class="text-rose-500 dark:text-rose-400 hover:text-rose-600 font-medium">Ko-fi</a>.
        </p>
      </div>

      <!-- Dashboard CTA -->
      <div class="mt-6 sm:mt-8 p-4 sm:p-6 bg-rose-50/70 dark:bg-rose-950/30 rounded-xl border border-rose-200 dark:border-rose-900/60 max-w-2xl">
        <h3 class="text-sm font-bold mb-2 text-slate-900 dark:text-[var(--ch-text)]">View Interactive Dashboard</h3>
        <p class="text-xs text-slate-600 dark:text-[hsl(0_0%_70%)] mb-4">Explore the full crime statistics dashboard for detailed visualizations and filters.</p>
        <a
          href={dashboardLink}
          class="inline-block px-4 py-1.5 min-h-button bg-rose-600 text-white font-bold rounded-lg hover:bg-rose-700 active:bg-rose-800 transition text-xs"
        >
          View {post.data.countryName} Dashboard
        </a>
      </div>
    </article>

    <!-- Social Proof -->
    <div class="mt-6 max-w-2xl">
      <SocialProofStrip variant="strip" />
    </div>

    <!-- More Weekly Reports -->
    {relatedPosts.length > 0 && (
      <div class="mt-10 sm:mt-14">
        <div class="flex items-center gap-3 mb-5">
          <h2 class="text-[11px] font-bold uppercase tracking-widest text-slate-400 dark:text-[var(--ch-text-faint)] whitespace-nowrap">More Reports</h2>
          <div class="flex-1 h-px bg-slate-200 dark:bg-[var(--ch-border-subtle)]" />
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          {relatedPosts.map(related => (
            <a
              href={buildRoute.blogPost(related.slug)}
              class="group block bg-white dark:bg-[var(--ch-surface)] rounded-xl overflow-hidden border border-slate-200 dark:border-[var(--ch-border-card)] hover:shadow-md hover:border-rose-200 dark:hover:border-rose-900 transition-all"
            >
              <div class="overflow-hidden">
                <img
                  src={related.data.image}
                  alt={related.data.countryName}
                  class="w-full h-28 object-cover transition-transform duration-300 group-hover:scale-[1.04]"
                  loading="lazy"
                  width="640"
                  height="112"
                />
              </div>
              <div class="p-3">
                <span class="text-[10px] text-slate-400 dark:text-[var(--ch-text-faint)]">
                  {new Date(related.data.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                </span>
                <h4 class="text-xs font-bold text-slate-900 dark:text-[var(--ch-text-heading)] group-hover:text-rose-600 dark:group-hover:text-rose-400 transition mt-1 line-clamp-2 leading-snug">{related.data.title}</h4>
                <span class="text-[10px] text-rose-600 dark:text-rose-400 mt-2 block">{related.data.readTime}</span>
              </div>
            </a>
          ))}
        </div>
        <div class="mt-5 text-center">
          <a href={routes.blog} class="text-xs text-rose-600 hover:text-rose-700 dark:text-rose-400 dark:hover:text-rose-300 font-bold">
            View all reports &rarr;
          </a>
        </div>
      </div>
    )}

    <!-- Back to Blog -->
    <div class="mt-6 sm:mt-8">
      <a href={routes.blog} class="text-rose-600 hover:text-rose-700 dark:text-rose-400 dark:hover:text-rose-300 font-bold text-xs">
        &larr; Back to Blog
      </a>
    </div>

  </main>

  <!-- Social Share Script — reads post title from data attribute, no is:inline needed -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const url = window.location.href;
      const shareContainer = document.querySelector('[data-post-title]') as HTMLElement | null;
      const text = shareContainer?.dataset.postTitle ?? document.title;

      document.getElementById('share-facebook')?.addEventListener('click', () => {
        window.open(`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}`, '_blank', 'noopener');
      });

      document.getElementById('share-twitter')?.addEventListener('click', () => {
        window.open(`https://twitter.com/intent/tweet?url=${encodeURIComponent(url)}&text=${encodeURIComponent(text)}`, '_blank', 'noopener');
      });

      document.getElementById('share-whatsapp')?.addEventListener('click', () => {
        window.open(`https://wa.me/?text=${encodeURIComponent(text + ' ' + url)}`, '_blank', 'noopener');
      });

      document.getElementById('share-copy')?.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(url);
          const btn = document.getElementById('share-copy');
          if (!btn) return;
          const original = btn.textContent;
          btn.textContent = 'Copied!';
          setTimeout(() => { btn.textContent = original; }, 2000);
        } catch {
          // clipboard not available
        }
      });
    });
  </script>
</Layout>
